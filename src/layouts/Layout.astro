    "priceCurrency": "USD"
  },
  "keywords": "Bible verses, Christian affirmations, mind renewal, Romans 12:2, identity in Christ, I am declarations, faith app, Scripture for anxiety, Christian mental wellness",
  "inLanguage": "en-US",
  "audience": {
    "@type": "Audience",
    "audienceType": "Christians seeking mind renewal and identity in Christ"
  },
  "creator": {
    "@type": "Organization",
