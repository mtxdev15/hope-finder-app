---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<!-- ── PRIMARY SEO ── -->
<title>Declare & Believe — Scripture for Every Mindset Battle</title>
<meta name="description" content="Declare and Believe is a free Christian web tool that delivers personalized Bible verses, a faith-filled prayer, and an 'I am' declaration for any struggle — instantly, rooted in Scripture.">
<meta name="keywords" content="Bible verses for anxiety, Scripture for fear, Christian mind renewal app, Romans 12:2, faith declarations, I am statements Bible, renewing your mind, Bible verses for depression, Christian affirmations, identity in Christ, what does God say about me, Bible verses for shame, prayer for anxiety at night, speaking Scripture over yourself, Christian app for negative thoughts">
<meta name="author" content="JC Kingdom Ventures, LLC">
<meta name="robots" content="index, follow">
<link rel="canonical" href="https://www.declareandbelieve.com/">

<!-- ── OPEN GRAPH (Facebook, LinkedIn, iMessage previews) ── -->
<meta property="og:type" content="website">
<meta property="og:site_name" content="Declare and Believe">
<meta property="og:title" content="Declare & Believe — God's Word for Your Exact Struggle">
<meta property="og:description" content="Declare and Believe is a free Christian web tool that delivers personalized Bible verses, a faith-filled prayer, and an 'I am' declaration for any struggle — instantly, rooted in Scripture.">
<meta property="og:url" content="https://www.declareandbelieve.com/">
<meta property="og:image" content="https://www.declareandbelieve.com/og-image.jpg">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="Declare and Believe — Renew your mind with Scripture">
<meta property="og:locale" content="en_US">

<!-- ── TWITTER / X CARD ── -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Declare & Believe — God's Word for Your Exact Struggle">
<meta name="twitter:description" content="Declare and Believe is a free Christian web tool that delivers personalized Bible verses, a faith-filled prayer, and an 'I am' declaration for any struggle — instantly, rooted in Scripture.">
<meta name="twitter:image" content="https://www.declareandbelieve.com/og-image.jpg">
<meta name="twitter:image:alt" content="Declare and Believe — Renew your mind with Scripture">

<!-- ── AEO — Answer Engine Optimization ── -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Declare and Believe",
  "alternateName": "DeclareAndBelieve.com",
  "url": "https://www.declareandbelieve.com",
  "description": "Declare and Believe is a free Christian web tool that delivers personalized Bible verses, a faith-filled prayer, and an 'I am' declaration for any struggle — instantly, rooted in Scripture.",
  "applicationCategory": "LifestyleApplication",
  "operatingSystem": "Web, iOS, Android",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "keywords": "Bible verses, Christian affirmations, mind renewal, Romans 12:2, identity in Christ, I am declarations, faith app, Scripture for anxiety, Christian mental wellness",
  "inLanguage": "en-US",
  "audience": {
    "@type": "Audience",
    "audienceType": "Christians seeking mind renewal and identity in Christ"
  },
  "creator": {
    "@type": "Organization",
    "name": "JC Kingdom Ventures, LLC"
  },
  "featureList": [
    "Personalized Bible verses for any mindset struggle",
    "Faith-based explanation of how Scripture applies to your situation",
    "I am declarations rooted in God's Word",
    "Personal prayer written for your exact struggle",
    "Crisis support resources for suicidal thoughts",
    "Multiple Bible translations: NKJV, NLT, NIV"
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What Bible verse helps when you feel worthless?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Psalm 139:14 says you are fearfully and wonderfully made. Romans 8:38-39 says nothing can separate you from God's love. Declare and Believe finds the exact Scripture for what you're carrying right now."
      }
    },
    {
      "@type": "Question",
      "name": "What does God say when you feel like a failure?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Philippians 1:6 says God who began a good work in you will complete it. Jeremiah 29:11 says He has plans for you — plans for a future and a hope. You are not behind. You are not forgotten."
      }
    },
    {
      "@type": "Question",
      "name": "What Bible verse helps with anxiety at night?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Philippians 4:6-7, Isaiah 41:10, and 2 Timothy 1:7 speak directly to fear and anxiety. Declare and Believe pairs these with personalized declarations you can speak over yourself right now."
      }
    },
    {
      "@type": "Question",
      "name": "How do I renew my mind with Scripture?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Romans 12:2 says be transformed by the renewing of your mind. Declare and Believe makes this practical — describe your struggle, receive the exact Scripture that speaks to it, and speak it over yourself as a declaration."
      }
    },
    {
      "@type": "Question",
      "name": "Is there a Christian app for when you feel hopeless?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Declare and Believe is a free Christian web app built for exactly that moment. Describe what you're battling and receive personalized Bible verses, prayer, and identity declarations rooted in God's Word."
      }
    }
  ]
}
</script>

<!-- ── GEO — Generative Engine Optimization ── -->
<meta name="application-name" content="Declare and Believe">
<meta name="category" content="Christian Faith, Bible, Mind Renewal, Spiritual Wellness">
<meta name="classification" content="Religious, Faith-based, Christian Application">
<meta name="topic" content="Bible verses for anxiety, Christian identity declarations, mind renewal Scripture, Romans 12:2">
<meta name="summary" content="Declare and Believe is a free Christian web app that delivers personalized Bible verses, pastoral explanation, identity declarations, and prayer for any mindset struggle. Powered by AI. Rooted in Scripture. Built on Romans 12:2.">
<meta name="abstract" content="When Christians feel stuck in fear, shame, broken identity, or hopelessness, Declare and Believe speaks God's Word directly back to them. Users describe their struggle, receive 3-5 targeted Bible verses in their chosen translation, a faith-based explanation, I am declarations they can speak aloud, and a personal prayer.">

<!-- ── MOBILE AND PWA ── -->
<meta name="theme-color" content="#2D4A3E">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="Declare & Believe">
<meta name="format-detection" content="telephone=no">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
