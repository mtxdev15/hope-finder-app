---
// v3.2 base layout — the shared shell every redesigned page sits on.
// Owns the dark-cinematic head (anti-flash paint, theme resolver, fonts,
// favicons, OG) and mounts the five-tab bottom nav. Deliberately separate
// from src/layouts/Layout.astro (the legacy v1 app) so the two theme systems
// (declare.css data-theme vs. db-base/theme.css .theme-dark) never collide.
import TabBar from '../components/TabBar.astro';

const {
  title = 'Declare & Believe',
  description = "Name what's heavy and receive His Word for this moment.",
  ogImage = '/declare/brand/og.png',
  activeTab = '',
} = Astro.props;

// Google Tag Manager container id (loads GA4 via GTM). Renders nothing if unset.
const GTM_ID = import.meta.env.PUBLIC_GTM_ID;
---
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<!-- swallow benign "Transition was skipped" rejections from cross-document View Transitions -->
<script is:inline>(function(){function swallow(t){if(t){try{t.finished&&t.finished.catch(function(){});}catch(e){}try{t.ready&&t.ready.catch(function(){});}catch(e){}try{t.updateCallbackDone&&t.updateCallbackDone.catch(function(){});}catch(e){}}}addEventListener("pagereveal",function(e){swallow(e.viewTransition);});addEventListener("pageswap",function(e){swallow(e.viewTransition);});addEventListener("unhandledrejection",function(e){var r=e&&e.reason,m=(r&&(r.message||r.name))||(typeof r==="string"?r:"");if(/transition was skipped/i.test(m))e.preventDefault();});})();</script>
<meta charset="UTF-8" />
{GTM_ID && (
<script is:inline define:vars={{ GTM_ID }}>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer',GTM_ID);</script>
)}
<!-- anti-flash: paint a solid themed background on the FIRST frame so document-to-document
     navigation never blinks white (declare.css gradients layer on top once loaded) -->
<style is:inline id="anti-flash">html{background-color:#0E1A14!important;}
html[data-theme="light"]{background-color:#FAF7F2!important;}
.rl-overlay{opacity:0!important;visibility:hidden!important;}
.rl-overlay.rl-show{opacity:1!important;visibility:visible!important;}</style>
<!-- resolve the saved/system theme synchronously, before paint, so a returning
     light-mode user never sees a dark->light jump -->
<script is:inline>/*__declTheme*/(function(){try{var m=localStorage.getItem("declare-theme")||"dark";var h=new Date().getHours();var t=m==="light"?"light":m==="dark"?"dark":m==="auto"?((h<6||h>=18)?"dark":"light"):((window.matchMedia&&matchMedia("(prefers-color-scheme: dark)").matches)?"dark":"light");document.documentElement.setAttribute("data-theme",t);}catch(e){}})();</script>
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<meta name="theme-color" content="#0c130f" />

<title>{title}</title>
<meta name="description" content={description} />
<link rel="icon" type="image/png" sizes="32x32" href="/declare/brand/favicon-32.png" />
<link rel="icon" type="image/png" sizes="64x64" href="/declare/brand/favicon-64.png" />
<link rel="apple-touch-icon" href="/declare/brand/apple-touch-icon.png" />

<!-- social sharing -->
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500;1,600&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=Lora:ital,wght@0,400;0,500;0,600;1,500&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
<noscript><link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500;1,600&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=Lora:ital,wght@0,400;0,500;0,600;1,500&display=swap" rel="stylesheet" /></noscript>

<link rel="stylesheet" href="/declare/declare.css" />
<link rel="stylesheet" href="/declare/motion.css" />
<link rel="stylesheet" href="/declare/route-loader.css" />
</head>
<body class="app-shell">
{GTM_ID && (
<noscript><iframe src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`} height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
)}
  <!-- design mast: brand dot + avatar entry to /you (design-source product pages) -->
  <div class="mast">
    <a class="masthome" href="/welcome" aria-label="Declare home"><span class="dot" aria-hidden="true"></span></a>
    <a class="avatar" href="/you" aria-label="You">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="3.4"></circle><path d="M5.5 20a6.5 6.5 0 0 1 13 0"></path></svg>
    </a>
  </div>
  <slot />
  <TabBar active={activeTab} />

  <!-- shared vanilla runtime — plain external scripts, emitted verbatim so each
       module's currentScript.src (e.g. route-loader's asset BASE) resolves correctly -->
  <script is:inline src="/declare/theme.js"></script>
  <script is:inline src="/declare/motion.js"></script>
  <script is:inline src="/declare/route-loader.js" defer></script>

  <!-- Greet the signed-in user by name in the nav (the "You" tab → first name),
       so the app confirms who you are, like the welcome header does. -->
  <script>
    import { initAuth, isSignedIn, currentUser, onAuthChange } from '../app/declare/auth-store.js';
    function paintYouTab() {
      const el = document.querySelector('[data-you-label]');
      if (!el) return;
      let name = '';
      try { name = isSignedIn() ? (currentUser().firstName || '') : ''; } catch (e) {}
      el.textContent = name ? name.slice(0, 14) : 'You';
    }
    initAuth().then(paintYouTab).catch(() => {});
    onAuthChange(paintYouTab);
  </script>

  <style is:global>
    /* cinematic smooth scrolling (design system; reduced-motion forces auto) */
    html { scroll-behavior: smooth; }

    /* ── tab-to-tab page transitions (Word/Journey/Declare/Vault/You) ──
       Cross-document View Transitions: the nav chrome stays pinned while the
       page content settles in on the house expo-out curve — the unseen.co
       feel. motion.css opts in (@view-transition{navigation:auto}); browsers
       without VT fall back to declare.css's gold veil. */
    @media (prefers-reduced-motion: no-preference) {
      body > .tabbar { view-transition-name: declare-tabbar; }
      body > .mast { view-transition-name: declare-mast; }
      ::view-transition-old(root) { animation: vtLeave .34s cubic-bezier(.4, 0, 1, 1) both; }
      ::view-transition-new(root) { animation: vtArrive .62s cubic-bezier(.16, 1, .3, 1) both; }
      @keyframes vtLeave { to { opacity: 0; transform: translateY(-10px) scale(.996); } }
      @keyframes vtArrive { from { opacity: 0; transform: translateY(14px) scale(.998); } }
      /* keep the pinned chrome steady — a quick plain crossfade, no movement */
      ::view-transition-old(declare-tabbar), ::view-transition-new(declare-tabbar),
      ::view-transition-old(declare-mast), ::view-transition-new(declare-mast) { animation-duration: .25s; }
      /* tab press: a soft settle on the icon you chose */
      .tab:active svg { transform: scale(.86); transition: transform .12s ease; }
    }

    /* ── shell adaptation: design pages render inside a .screen flex column; our
       pages scroll the document. Pin the design tabbar to the viewport bottom on
       mobile (the design's own full-bleed treatment), and let declare.css's
       .app-shell rules (body class) reflow it into the fixed top bar at >=481px. */
    @media (max-width: 480px) {
      .tabbar {
        position: fixed; left: 0; right: 0; bottom: 0; z-index: 30;
        background: color-mix(in srgb, var(--bgfield) 90%, transparent);
        backdrop-filter: blur(18px) saturate(1.2); -webkit-backdrop-filter: blur(18px) saturate(1.2);
        border-top: 1px solid var(--line);
        padding-left: 14px; padding-right: 14px; padding-top: 10px;
      }
    }
    /* app->explore bridge: the mast brand dot is a link home to /welcome (logo = home),
       so the app is not a one-way door. Comfortable tap target around the small dot
       without shifting layout. */
    .mast .masthome { display: inline-flex; align-items: center; padding: 10px; margin: -10px; line-height: 0; cursor: pointer; }
    /* mast: in-flow on mobile (declare.css base), pinned into the top band on desktop
       (design Today.html/Vault.html desktop treatment) */
    @media (min-width: 481px) {
      .mast { position: fixed; top: 0; left: 0; right: 0; z-index: 31; height: 60px;
        margin: 0; padding: 0 clamp(22px, 3vw, 44px);
        display: flex; align-items: center; justify-content: space-between; pointer-events: none; }
      .mast .masthome { pointer-events: auto; }
      /* desktop: the top bar already carries the You tab — hide the mast avatar
         (duplicate profile icon, per review) */
      .mast .avatar { display: none; }
      /* design Today.html: the active center tab carries a slim gold underline in the top bar */
      .app-shell .tab.center.on::after { content: ''; position: absolute; left: 13px; right: 13px; bottom: 2px; height: 2px; border-radius: 2px;
        background: linear-gradient(90deg, transparent, var(--gold), transparent); }
      /* clear the fixed top bar on pages that start content at the top */
      .word .w-col { padding-top: 64px; }
      .you .you-col { padding-top: 64px; }
      .vault .vhero { padding-top: 96px; }
    }
  </style>
</body>
</html>
