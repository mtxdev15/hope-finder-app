    @media (min-width: 720px) and (prefers-reduced-motion: no-preference) {
      .you .yfdetail.open .yfd-card { animation: ymInC .42s cubic-bezier(.16, 1, .3, 1) both; }
    }

    /* tame Google's autocomplete dropdown into the brand */
    .pac-container { background: var(--surface); border: 1px solid var(--line2); border-radius: 14px; box-shadow: 0 30px 70px -30px rgba(0, 0, 0, .7); font-family: 'DM Sans', sans-serif; margin-top: 6px; }
    .pac-item { border-top: 1px solid var(--line); padding: 10px 14px; color: var(--text2); font-size: 13px; cursor: pointer; }
    .pac-item:hover, .pac-item-selected { background: color-mix(in srgb, var(--gold) 8%, transparent); }
    .pac-item-query { color: var(--text); font-size: 14px; }
    .pac-icon { display: none; }

    /* toast */
    .you .ytoast { position: fixed; left: 50%; bottom: 110px; transform: translate(-50%, 14px); z-index: 80; background: var(--surface); border: 1px solid var(--line2);
      color: var(--text); font-size: 13px; padding: 11px 18px; border-radius: 100px; box-shadow: var(--card-shadow); opacity: 0; visibility: hidden;
      transition: opacity .3s ease, transform .3s ease, visibility .3s; white-space: nowrap; }
