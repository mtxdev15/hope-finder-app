    @media (min-width: 720px) {
      /* editor modal -> centered (house pattern) */
      .you .ym-panel { left: 50%; right: auto; bottom: auto; top: 50%; transform: translate(-50%, -50%); width: min(480px, 92%);
        border-radius: 26px; border: 1px solid var(--line2); box-shadow: 0 50px 130px -40px rgba(0, 0, 0, .8); }
    }
    @media (min-width: 720px) and (prefers-reduced-motion: no-preference) {
      .you .ymodal.open .ym-panel { animation: ymInC .42s cubic-bezier(.16, 1, .3, 1) both; }
    }
    @keyframes ymInC { from { opacity: 0; transform: translate(-50%, -48%) scale(.965); } to { opacity: 1; transform: translate(-50%, -50%) scale(1); } }
