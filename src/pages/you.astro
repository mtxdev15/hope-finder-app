      border: 1px solid var(--line2); background: var(--field); border-radius: 999px; padding: 10px 15px; transition: border-color .18s ease, background .18s ease; }
    .you .yfd-act:hover { border-color: color-mix(in srgb, var(--gold) 36%, transparent); }
