    .you .yf-missing p { font-size: 13px; color: var(--muted); line-height: 1.6; margin-top: 10px; }
    .you .yf-missing code { color: var(--goldd); background: var(--field); padding: 2px 7px; border-radius: 6px; font-size: 12px; }
    /* ===== church detail sheet (house overlay pattern) ===== */
    .you .yfdetail { position: fixed; inset: 0; z-index: 65; display: none; }
    .you .yfdetail.open { display: block; }
    .you .yfd-card { position: absolute; left: 0; right: 0; bottom: 0; max-height: 86dvh; overflow-y: auto; background: var(--screen);
