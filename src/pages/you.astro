    /* ---------- Your giving: a signed-in user's own gift history (newest first) ---------- */
    // Stripe Customer Portal login link (Stripe → Settings → Billing → Customer portal).
    // Empty string = the "Manage giving" link stays hidden until the link is pasted here.
    const YG_PORTAL = 'https://billing.stripe.com/p/login/dRmfZidrIh248Ae5HZasg00';
    const YG_WORKER = 'https://hope-finder-worker.thinktoro.workers.dev';
    function ygMoney(cents) {
      var n = (cents || 0) / 100;
      return '$' + n.toLocaleString('en-US', { minimumFractionDigits: (cents % 100 ? 2 : 0), maximumFractionDigits: 2 });
    }
    function ygDate(ts) {
      try { return new Date(ts).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }); }
      catch (e) { return ''; }
    }
    function renderGiving() {
      const card = $('yGiving'); if (!card) return;
      if (!signedInNow()) { card.hidden = true; return; }
      myGifts().then((gifts) => {
        if (!gifts || !gifts.length) { card.hidden = true; return; }
        const totalCents = gifts.reduce((s, g) => s + (g.amountCents || 0), 0);
        $('ygTotal').textContent = ygMoney(totalCents) + ' · ' + gifts.length + (gifts.length === 1 ? ' gift' : ' gifts');
        $('ygList').innerHTML = gifts.slice(0, 8).map(function (g) {
          var badge = g.recurring ? '<span class="yg-badge">' + (g.frequency === 'semimonthly' ? 'Twice a month' : 'Monthly') + '</span>' : '';
          return '<li><span class="yg-amt">' + ygMoney(g.amountCents) + '</span>' + badge + '<span class="yg-date">' + ygDate(g.giftedAt) + '</span></li>';
        }).join('');
        var mg = $('ygManage');
        if (mg) {
          if (YG_PORTAL) { mg.href = YG_PORTAL; mg.hidden = false; }
          else mg.hidden = true;
        }
        // Next-charge line: live status for the most recent recurring gift, so a
        // canceled gift never shows a phantom date.
        var nx = $('ygNext');
        if (nx) {
          nx.hidden = true;
          var rec = null;
          for (var i = 0; i < gifts.length; i++) { if (gifts[i].recurring && gifts[i].subscriptionId) { rec = gifts[i]; break; } }
          if (rec) {
            fetch(YG_WORKER + '/give/subscription', {
              method: 'POST', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ subscriptionId: rec.subscriptionId }),
            }).then(function (r) { return r.ok ? r.json() : null; }).then(function (d) {
              if (!d || d.status !== 'active' || !d.currentPeriodEnd) return;
              var freq = rec.frequency === 'semimonthly' ? 'Twice a month' : 'Monthly';
              var when = ygDate(d.currentPeriodEnd * 1000);
              nx.textContent = d.cancelAtPeriodEnd
                ? (freq + ' · ends ' + when)
                : (freq + ' · next gift of ' + ygMoney(rec.amountCents) + ' on ' + when);
              nx.hidden = false;
            }).catch(function () {});
          }
        }
        card.hidden = false;
      }).catch(() => { card.hidden = true; });
    }
