    .you .yf-set { flex: 0 0 auto; font-size: 12px; font-weight: 700; color: var(--goldd); background: rgba(216, 184, 95, .12);
      border: 1px solid color-mix(in srgb, var(--gold) 36%, transparent); border-radius: 999px; padding: 9px 14px; cursor: pointer; font-family: inherit; transition: .18s; }
    .you .yf-set:hover { background: rgba(216, 184, 95, .2); }
    .you .yf-note { padding: 16px 4px; color: var(--muted); font-size: 13px; }
    .you .yf-missing { text-align: center; padding: 60px 24px; }
