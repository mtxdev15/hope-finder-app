    .you .yfd-set.alt { background: var(--field); color: var(--text); border: 1px solid var(--line2); box-shadow: none; }
    .you .yfd-set.alt:hover { border-color: color-mix(in srgb, var(--gold) 36%, transparent); }
    @media (min-width: 720px) {
      .you .yfd-card { left: 50%; right: auto; bottom: auto; top: 50%; transform: translate(-50%, -50%); width: min(520px, 92%); max-height: 86vh;
        border-radius: 26px; border: 1px solid var(--line2); box-shadow: 0 50px 130px -40px rgba(0, 0, 0, .8); }
      .you .yfd-photo { height: 230px; border-radius: 26px 26px 0 0; }
