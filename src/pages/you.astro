    .you .ym-panel h3 { font-size: 24px; font-weight: 600; color: var(--text); padding-right: 40px; }
    .you .ym-panel p { font-size: 13px; color: var(--muted); margin-top: 6px; line-height: 1.5; }
    .you .ym-field { width: 100%; margin-top: 16px; font-family: inherit; font-size: 16px; color: var(--text); background: var(--field); border: 1px solid var(--line2); border-radius: 13px; padding: 14px 15px; resize: none; }
    .you .ym-field:focus { outline: none; border-color: color-mix(in srgb, var(--gold) 50%, transparent); }
