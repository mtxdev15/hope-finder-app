    (function setVer(){ const el = $('yVer'); if (el && RELEASES[0]) el.textContent = (esY() ? 'DECLARE · VERSIÓN ' : 'DECLARE · VERSION ') + RELEASES[0].v; })();
    function rlsTagClass(t){ return 'yrls-tag ' + (t === 'New' ? 'is-new' : t === 'Fixed' ? 'is-fixed' : 'is-imp'); }
    function openWhatsNew() {
      const sub = $('yRlsSub'); if (sub) sub.textContent = esY() ? 'Todo lo que hemos lanzado últimamente, en lenguaje sencillo.' : 'Everything we have shipped lately, in plain language.';
      var _BADGE = { New:'Nuevo', Fixed:'Corregido', Improved:'Mejorado' };
      var _MON = { January:'enero',February:'febrero',March:'marzo',April:'abril',May:'mayo',June:'junio',July:'julio',August:'agosto',September:'septiembre',October:'octubre',November:'noviembre',December:'diciembre' };
      function rlsDate(d){ return esY() ? String(d).replace(/([A-Za-z]+)\s+(\d{4})/, function(_,mo,y){ return (_MON[mo]||mo) + ' de ' + y; }) : d; }
      $('yRlsBody').innerHTML = RELEASES.map(function(r){
        return '<div class="yrls-rel"><div class="yrls-vh"><span class="yrls-v">' + (esY() ? 'Versión ' : 'Version ') + r.v + '</span><span class="yrls-date">' + rlsDate(r.date) + '</span></div>'
          + r.items.map(function(it){ return '<div class="yrls-item"><span class="yrls-tagcol"><span class="' + rlsTagClass(it[0]) + '">' + ((esY() && _BADGE[it[0]]) ? _BADGE[it[0]] : it[0]) + '</span></span><span class="yrls-txt">' + (esY() && it[2] ? it[2] : it[1]) + '</span></div>'; }).join('')
          + '</div>';
      }).join('');
      $('yRlsModal').classList.add('open');
    }
    function closeWhatsNew() { $('yRlsModal').classList.remove('open'); }
    $('yWhatsNew') && $('yWhatsNew').addEventListener('click', openWhatsNew);
    $('yRlsX') && $('yRlsX').addEventListener('click', closeWhatsNew);
    $('yRlsBack') && $('yRlsBack').addEventListener('click', closeWhatsNew);
    document.addEventListener('keydown', function(e){ if (e.key === 'Escape' && $('yRlsModal') && $('yRlsModal').classList.contains('open')) closeWhatsNew(); });
    // footer "What's new" links land here with ?whatsnew=1 and open the log directly
    try { if (new URLSearchParams(location.search).get('whatsnew')) openWhatsNew(); } catch (e) {}

    /* ---------- church hub card reflects the saved church ---------- */
    function renderChurchHub() {
      $('hubChurchD').innerHTML = (signedInNow() && P.church)
        ? esc(P.church.name) + ' <span class="ybadge home">' + tY('you.homeBadge','Home') + '</span>'
        : tY('you.findChurchD','Discover a fellowship near you');
    }
    $('hubChurch').addEventListener('click', () => { (signedInNow() && P.church) ? openHomeChurch() : openFinder(); });

    /* ---------- real account session (Convex + Better Auth) ---------- */
    function renderAuth() {
      const signedIn = isConfigured() && isSignedIn();
      const u = signedIn ? currentUser() : null;
      // First sign-in mirrors the account's name onto this device so the rail
      // greets them right away. Only fills a blank name; never overwrites. On
      // sign-out the profile is cleared (see signOut), so the guest slate is blank.
      if (signedIn && u && u.firstName && !getProfile().name) P = setProfile({ name: u.firstName });
      $('yRole').textContent = signedIn ? ((u && u.email) || tY('you.roleSignedIn','Signed in')) : tY('you.roleGuest','Guest · not signed in');
      $('hubAuthD').textContent = signedIn ? (tY('you.signedInAs','Signed in as ') + ((u && u.email) || tY('you.you','you'))) : tY('you.signInKeep','Sign in to keep what God gives you');
      // Re-read the profile and re-render every personal surface so name, facts,
      // interests and the church hub reflect the current account/guest state.
      P = getProfile(); renderRail(); renderFacts(); renderChips(); renderChurchHub();
    }
    $('hubAuth').addEventListener('click', () => {
      if (!(isConfigured() && isSignedIn())) {
        // Julienne model: the account card opens right here
        openAuthModal({ mode: 'signin', onSuccess: () => { renderAuth(); toast(tY('you.welcomeBack','Welcome back.')); } });
        return;
      }
      const u = currentUser() || {};
      modalKey = 'auth';
      $('ymTitle').textContent = tY('you.yourAccount','Your account');
      $('ymSub').textContent = tY('you.signedInAs','Signed in as ') + (u.email || tY('you.you','you')) + tY('you.accountSub2','. Your words and verses stay on this device for now.');
      $('ymBody').innerHTML = '<button class="btn btn-ghost" id="ymSignout" style="width:100%;margin-top:16px" data-i18n="you.signOut">Sign out</button>';
      try { window.I18N && I18N.apply(); } catch (e) {}
      $('ymSave').style.display = 'none';
      document.getElementById('ymSignout').addEventListener('click', async () => {
        await signOut(); closeModal(); renderAuth(); toast(tY('you.signedOut','Signed out on this device.'));
      });
      openModal();
    });
    function tY(k, fb){ try { return window.I18N ? window.I18N.t(k, fb) : fb; } catch(e){ return fb; } }
    function esY(){ try { return !!(window.I18N && window.I18N.lang && window.I18N.lang() === 'es'); } catch(e){ return false; } }
    initAuth().then(renderAuth);
    onAuthChange(renderAuth);
    // in-app language toggle (Español | English) — persists + reloads to re-render everywhere
    (function(){
      var ctl = document.getElementById('langCtl'); if (!ctl) return;
      function paint(){ var l = (window.I18N ? I18N.lang() : 'en'); ctl.querySelectorAll('button').forEach(function(b){ b.classList.toggle('on', b.dataset.lang === l); }); }
      paint();
      // Repaint once everything has loaded and on any language change — the active
      // highlight must never show a stale language (module boot order is not a
      // guarantee that I18N was ready at first paint).
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', paint); else setTimeout(paint, 0);
      document.addEventListener('declare-lang', paint);
      ctl.addEventListener('click', function(e){
        var b = e.target.closest('button'); if (!b || !b.dataset.lang) return;
        var want = b.dataset.lang;
        if (window.I18N && I18N.lang() === want) { paint(); return; }
        try {
          if (window.I18N) { I18N.setLang(want); }
          else { // engine not ready yet: never a dead click — write the choice directly
            document.cookie = 'declare-lang=' + want + ';path=/;max-age=31536000;samesite=lax';
            localStorage.setItem('declare-lang', want);
            localStorage.setItem('declare-lang-set', '1');
            localStorage.setItem('declare-lang-push', '1');
          }
        } catch(err){}
        location.reload();
      });
    })();

    /* ---------- church finder (Google Maps + Places, lazy) ---------- */
    let gmapsLoading = null, map = null, places = null, markers = [];
    const DARK_MAP = [
      { elementType: 'geometry', stylers: [{ color: '#10201a' }] },
      { elementType: 'labels.text.fill', stylers: [{ color: '#8fa399' }] },
      { elementType: 'labels.text.stroke', stylers: [{ color: '#0b110d' }] },
      { featureType: 'poi', stylers: [{ visibility: 'off' }] },
      { featureType: 'poi.place_of_worship', stylers: [{ visibility: 'on' }] },
      { featureType: 'road', elementType: 'geometry', stylers: [{ color: '#1c2d25' }] },
      { featureType: 'water', elementType: 'geometry', stylers: [{ color: '#0c1a22' }] },
      { featureType: 'transit', stylers: [{ visibility: 'off' }] },
    ];
    function loadGmaps() {
      if (gmapsLoading) return gmapsLoading;
      gmapsLoading = new Promise((resolve, reject) => {
        if (window.google && window.google.maps) { resolve(); return; }
        const s = document.createElement('script');
        s.src = 'https://maps.googleapis.com/maps/api/js?key=' + GMAPS_KEY + '&libraries=places&v=weekly';
        s.async = true; s.onload = resolve; s.onerror = reject;
        document.head.appendChild(s);
      });
      return gmapsLoading;
    }
    function openFinder() {
      $('yFinder').classList.add('open');
      if (!GMAPS_KEY) {
        $('yfMissing').hidden = false;
        $('yfMap').style.display = 'none';
        $('yfLoc').style.display = 'none';
        document.querySelector('.yf-search').style.display = 'none';
        return;
      }
      loadGmaps().then(initFinder).catch(() => toast('Maps couldn’t load — check the key restrictions.'));
    }
    $('yfClose').addEventListener('click', () => $('yFinder').classList.remove('open'));
    function initFinder() {
      if (map) return;
      const center = P.church && P.church.loc ? P.church.loc : { lat: 39.5, lng: -98.35 };
      map = new google.maps.Map($('yfMap'), {
        center, zoom: P.church && P.church.loc ? 12 : 4,
        styles: DARK_MAP, disableDefaultUI: true, zoomControl: true,
      });
      places = new google.maps.places.PlacesService(map);
      const ac = new google.maps.places.Autocomplete($('yfInput'), { fields: ['geometry', 'name', 'formatted_address', 'place_id', 'types'] });
      ac.addListener('place_changed', () => {
        const p = ac.getPlace();
        if (!p) return;
        // Enter pressed on raw text (no suggestion picked) -> full-text church
        // search, so "pentecostal churches" or "Fuente iglesia" just works
        if (!p.geometry) { searchText(p.name); return; }
        if ((p.types || []).indexOf('church') >= 0 || (p.types || []).indexOf('place_of_worship') >= 0) {
          renderChurches([{ name: p.name, vicinity: p.formatted_address, place_id: p.place_id, geometry: p.geometry }]);
          map.setCenter(p.geometry.location); map.setZoom(14);
        } else {
          searchNear(p.geometry.location);
        }
      });
      $('yfLoc').addEventListener('click', () => {
        if (!navigator.geolocation) return;
        navigator.geolocation.getCurrentPosition(
          (pos) => searchNear(new google.maps.LatLng(pos.coords.latitude, pos.coords.longitude)),
          () => toast(esY() ? 'Ubicación no disponible — busca una ciudad.' : 'Location unavailable — search a city instead.')
        );
      });
    }
    function searchNear(loc) {
      map.setCenter(loc); map.setZoom(12);
      $('yfList').innerHTML = '<div class="yf-note">' + (esY() ? 'Buscando iglesias cerca…' : 'Looking for churches nearby…') + '</div>';
      places.nearbySearch({ location: loc, radius: 9000, type: 'church' }, (res, status) => {
        if (status !== google.maps.places.PlacesServiceStatus.OK || !res || !res.length) {
          $('yfList').innerHTML = '<div class="yf-note">' + (esY() ? 'No se encontraron iglesias aquí — amplía la búsqueda.' : 'No churches found here — try a wider search.') + '</div>';
          return;
        }
        renderChurches(res.slice(0, 10));
      });
    }
    /* free-text search: "pentecostal churches", "Fuente iglesia",
       "Fountain church in New Jersey" — Places textSearch understands all of
       these natively. Biased to the current map view so bare denominations
       ("baptist") land near the user, not across the country. */
    function searchText(q) {
      q = (q || '').trim();
      if (q.length < 2) return;
      $('yfList').innerHTML = '<div class="yf-note">' + (esY() ? 'Buscando iglesias…' : 'Searching churches…') + '</div>';
      const churchy = /church|iglesia|chapel|capilla|temple|templo|ministr|fellowship|assembl|asamblea|tabernac|cathedral|catedral|parish|parroquia|congrega/i.test(q);
      const req = { query: churchy ? q : q + ' church' };
      if (map) { req.location = map.getCenter(); req.radius = 30000; }
      places.textSearch(req, (res, status) => {
        if (status !== google.maps.places.PlacesServiceStatus.OK || !res || !res.length) {
          $('yfList').innerHTML = '<div class="yf-note">' + (esY() ? ('Nada encontrado para “' + esc(q) + '” — prueba con una ciudad o código postal.') : ('Nothing found for “' + esc(q) + '” — try adding a city or zip.')) + '</div>';
          return;
        }
        renderChurches(res.slice(0, 10));
      });
    }
    function ratingHtml(c) {
      if (!c.rating) return '';
      return '<span class="star">★</span> ' + Number(c.rating).toFixed(1)
        + (c.user_ratings_total ? ' <span class="dim">(' + c.user_ratings_total + ')</span>' : '');
    }
    function setChurch(c) {
      // Searching for churches is open to everyone; SAVING one as "My church"
      // is a kept thing — it needs an account. The card opens right here and
      // saves the moment they're in.
      if (isConfigured() && !isSignedIn()) {
        openAuthModal({ mode: 'signup', message: esY() ? 'Crea una cuenta gratis para fijar tu iglesia base.' : 'Create a free account to set your home church.', onSuccess: () => doSetChurch(c) });
        return;
      }
      doSetChurch(c);
    }
    function doSetChurch(c) {
      const loc = c.geometry ? { lat: c.geometry.location.lat(), lng: c.geometry.location.lng() } : null;
      P = setProfile({ church: { name: c.name, address: c.vicinity || c.formatted_address || '', placeId: c.place_id || '', loc } });
      toast('“' + c.name + '” ' + (esY() ? 'es tu iglesia base.' : 'is your home church.'));
      renderFacts(); renderChurchHub();
      closeDetail();
      $('yFinder').classList.remove('open');
    }
    function renderChurches(list) {
      markers.forEach((m) => m.setMap(null)); markers = [];
      const bounds = new google.maps.LatLngBounds();
      list.forEach((c) => {
        if (!c.geometry) return;
        const mk = new google.maps.Marker({ map, position: c.geometry.location, title: c.name });
        mk.addListener('click', () => openDetail(c));
        markers.push(mk); bounds.extend(c.geometry.location);
      });
      if (list.length > 1) map.fitBounds(bounds, 48);
      $('yfList').innerHTML = list.map((c, i) => {
        const r = ratingHtml(c);
        return '<div class="yf-row" style="animation-delay:' + (i * 40) + 'ms">'
          + '<button class="yf-m" data-d="' + i + '"><span class="yf-n">' + esc(c.name) + '</span><span class="yf-a">' + esc(c.vicinity || c.formatted_address || '') + '</span>'
          + (r ? '<span class="yf-r">' + r + '</span>' : '') + '</button>'
          + '<button class="yf-set" data-i="' + i + '">' + (esY() ? 'Fijar como mi iglesia' : 'Set as my church') + '</button></div>';
      }).join('');
      $('yfList').querySelectorAll('.yf-m').forEach((b) => b.addEventListener('click', () => openDetail(list[+b.dataset.d])));
      $('yfList').querySelectorAll('.yf-set').forEach((b) => b.addEventListener('click', () => setChurch(list[+b.dataset.i])));
    }

    /* ---------- church detail sheet (tap a row or a map pin) ---------- */
    const DICONS = {
      phone: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 2 .7 2.9a2 2 0 0 1-.4 2.1L8.1 10a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.4c.9.3 1.9.6 2.9.7a2 2 0 0 1 1.6 2z"/></svg>',
      globe: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/></svg>',
      pin: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="2.6"/></svg>',
    };
    let detailPlace = null, detailHome = false;
    function metaLine(c) {
      const bits = [];
      const r = ratingHtml(c);
      if (r) bits.push(r);
      let open = null;
      try { if (c.opening_hours && typeof c.opening_hours.isOpen === 'function') open = c.opening_hours.isOpen(); } catch (e) {}
      if (open === true) bits.push('<span class="ok">Open now</span>');
      else if (open === false) bits.push('<span class="dim">Closed now</span>');
      return bits.join('<span class="sep">·</span>');
    }
    function closeDetail() { $('yfDetail').classList.remove('open'); detailPlace = null; }
    $('yfdBack').addEventListener('click', closeDetail);
    $('yfdX').addEventListener('click', closeDetail);
    $('yfdSet').addEventListener('click', () => {
      if (detailHome) { closeDetail(); openFinder(); }
      else if (detailPlace) setChurch(detailPlace);
    });
    function llOf(c) {
      if (c.geometry && c.geometry.location) return { lat: c.geometry.location.lat(), lng: c.geometry.location.lng() };
      return c.loc || null;
    }
    function gmapsDir(c) {
      return 'https://www.google.com/maps/dir/?api=1&destination=' + encodeURIComponent(c.formatted_address || c.name || '')
        + (c.place_id ? '&destination_place_id=' + encodeURIComponent(c.place_id) : '');
    }
    function chipA(label, href, icon) {
      return '<a class="yfd-act" href="' + esc(href) + '" target="_blank" rel="noopener">' + icon + label + '</a>';
    }
    /* plain links — the phone hands each one to the installed app */
    function navActs(c) {
      const dest = encodeURIComponent(c.formatted_address || c.name || '');
      const ll = llOf(c);
      return chipA('Google Maps', gmapsDir(c), DICONS.pin)
        + chipA('Apple Maps', 'https://maps.apple.com/?daddr=' + dest, DICONS.pin)
        + chipA('Waze', ll ? 'https://waze.com/ul?ll=' + ll.lat + ',' + ll.lng + '&navigate=yes' : 'https://waze.com/ul?q=' + dest, DICONS.pin);
    }
    function paintActions(c, d) {
      let acts = '';
      if (d && d.formatted_phone_number) acts += '<a class="yfd-act" href="tel:' + esc(d.formatted_phone_number.replace(/[^+\d]/g, '')) + '">' + DICONS.phone + 'Call</a>';
      if (d && d.website) acts += chipA('Website', d.website, DICONS.globe);
      acts += detailHome ? navActs(c) : chipA('Directions', gmapsDir(c), DICONS.pin);
      $('yfdActions').innerHTML = acts;
    }
    function openDetail(c, home) {
      detailPlace = c; detailHome = !!home;
      // paint instantly from what we already know, then enrich from Google
      $('yfdName').innerHTML = esc(c.name || '') + (home ? ' <span class="ybadge home">Home</span>' : '');
      $('yfdAddr').textContent = c.vicinity || c.formatted_address || '';
      $('yfdAddr').href = gmapsDir(c);
      $('yfdMeta').innerHTML = metaLine(c);
      $('yfdHours').innerHTML = '';
      if (home) paintActions(c, null);
      else $('yfdActions').innerHTML = c.place_id ? '<div class="yf-note">Getting details…</div>' : '';
      $('yfdSet').textContent = home ? 'Search for another church' : 'Set as my church';
      $('yfdSet').classList.toggle('alt', !!home);
      $('yfdPhoto').hidden = true; $('yfdPhoto').style.backgroundImage = '';
      $('yfDetail').classList.add('open');
      if (!c.place_id || !places) { if (!home) $('yfdActions').innerHTML = ''; return; }
      places.getDetails({
        placeId: c.place_id,
        fields: ['name', 'formatted_address', 'formatted_phone_number', 'website', 'opening_hours', 'utc_offset_minutes', 'rating', 'user_ratings_total', 'photos', 'geometry'],
      }, (d, status) => {
        if (detailPlace !== c) return; // user moved on
        if (status !== google.maps.places.PlacesServiceStatus.OK || !d) { if (!detailHome) $('yfdActions').innerHTML = ''; return; }
        // keep the richer record so "Set as my church" saves the full address
        detailPlace = Object.assign({}, c, { name: d.name || c.name, formatted_address: d.formatted_address || c.formatted_address, geometry: d.geometry || c.geometry });
        $('yfdName').innerHTML = esc(detailPlace.name) + (detailHome ? ' <span class="ybadge home">Home</span>' : '');
        if (d.formatted_address) $('yfdAddr').textContent = d.formatted_address;
        $('yfdAddr').href = gmapsDir(detailPlace);
        $('yfdMeta').innerHTML = metaLine(d);
        if (d.photos && d.photos.length) {
          $('yfdPhoto').style.backgroundImage = 'url("' + d.photos[0].getUrl({ maxWidth: 1000, maxHeight: 560 }) + '")';
          $('yfdPhoto').hidden = false;
        }
        if (d.opening_hours && d.opening_hours.weekday_text) {
          const today = (new Date().getDay() + 6) % 7; // weekday_text starts Monday
          $('yfdHours').innerHTML = '<details class="yfd-hrs"><summary>' + esc(d.opening_hours.weekday_text[today]) + '</summary>'
            + d.opening_hours.weekday_text.map((l, i) => '<div class="' + (i === today ? 'on' : '') + '">' + esc(l) + '</div>').join('') + '</details>';
        }
        paintActions(detailPlace, d);
      });
    }
    /* "My church" -> the saved church's own card. Opens instantly from the
       device-local record, then Google fills in photo/hours/phone. */
    function openHomeChurch() {
      const hc = P.church;
      if (!hc) { openFinder(); return; }
      const c = { name: hc.name, formatted_address: hc.address, place_id: hc.placeId || '', loc: hc.loc || null };
      if (!GMAPS_KEY) { openDetail(c, true); return; }
      loadGmaps().then(() => {
        // Places works without the finder's map — a detached node is enough
        if (!places) places = new google.maps.places.PlacesService(document.createElement('div'));
        openDetail(c, true);
      }).catch(() => openDetail(c, true));
    }

    /* ---------- init ---------- */
    renderRail(); renderFacts(); renderChips(); renderChurchHub();
    // refresh stats when the account's Vault syncs in from Convex
    onChange(renderRail);
    // refresh the whole profile (name, church, interests) when it syncs in
    onAccountSync(() => { P = getProfile(); renderRail(); renderFacts(); renderChips(); renderChurchHub(); });
  </script>

