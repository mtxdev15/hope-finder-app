    .you .yf-row { display: flex; align-items: center; gap: 14px; padding: 14px 16px; background: var(--surface); border: 1px solid var(--line); border-radius: 15px;
      box-shadow: var(--card-shadow); margin-bottom: 10px; opacity: 0; animation: ymIn .5s cubic-bezier(.16, 1, .3, 1) forwards; }
    .you .yf-n { display: block; font-size: 15px; font-weight: 600; color: var(--text); }
    .you .yf-a { display: block; font-size: 12px; color: var(--muted); margin-top: 2px; }
    .you .yf-m { flex: 1; min-width: 0; background: none; border: 0; padding: 0; text-align: left; font-family: inherit; cursor: pointer; }
    .you .yf-r { display: block; font-size: 11.5px; color: var(--text2); margin-top: 4px; }
    .you .yf-r .star, .you .yfd-meta .star { color: var(--goldd); }
