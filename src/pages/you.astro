    .you .yf-h { flex: 1; text-align: center; }
    .you .yf-h .ti { font-size: 22px; font-weight: 600; color: var(--text); }
    .you .yf-h .su { font-size: 11.5px; color: var(--muted); margin-top: 2px; }
    .you .yf-body { flex: 1; min-height: 0; overflow-y: auto; padding: 8px 18px 30px; max-width: 760px; margin: 0 auto; width: 100%; scrollbar-width: none; }
