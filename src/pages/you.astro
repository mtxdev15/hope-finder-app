---
// /you — the profile. REDESIGNED on the Airbnb account-profile model (profile
// rail + confirmed-info card + icon-fact grid with modal editors + interest
// chips + clean hub cards) wearing the Declare design system, with unseen-grade
// motion. Everything editable is REAL and device-local (profile-store.js,
// 'declare-profile-v1'); stats are computed from the actual Vault/highlights.
// Accounts/sign-in remain honestly "coming soon". "Find a church" is live via
// Google Maps + Places when PUBLIC_GMAPS_KEY exists (.env, gitignored,
// referrer-restricted) and degrades gracefully without it.
import DeclareLayout from '../layouts/DeclareLayout.astro';
import RateReview from '../components/RateReview.astro';
const GMAPS_KEY = import.meta.env.PUBLIC_GMAPS_KEY || '';
---
<DeclareLayout
  title="Declare — You"
  description="Your Declare profile and settings."
  activeTab="you"
>
  <main class="you">
    <div class="topglow" aria-hidden="true"></div>
    <div class="you-col">

      <div class="ygrid">
        {/* ───── left rail: profile card + on-this-device card (Airbnb rail) ───── */}
        <aside class="yrail">
          <div class="ycard yprofile m-rise">
            <div class="yav-wrap">
              <button class="yav" id="yAvatar" type="button" aria-label="Add or change your photo"><span id="yAvText" class="serif">✝</span></button>
              <span class="yav-cam" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="3.5"/></svg></span>
            </div>
            <input type="file" id="yAvFile" accept="image/*" hidden />
            <button type="button" class="yav-remove" id="yAvRemove" hidden>Remove photo</button>
            <div class="yname serif" id="yName">Friend</div>
            <div class="yrole" id="yRole">Guest &middot; not signed in</div>
            <div class="ydivider"></div>
            <div class="ystat"><b id="yDays">1</b><span id="yDaysLbl">day with Declare</span></div>
          </div>

          <div class="ycard yconfirm m-rise">
            <div class="yc-h">Saved on this device</div>
            <ul class="yc-list" id="yStats"></ul>
            <div class="yc-note">Your words, verses and highlights live safely on this device. Signing in keeps them tied to you.</div>
          </div>
        </aside>

        {/* ───── right: About you (icon-fact grid + chips), then the hub ───── */}
        <section class="ymain">
          <div class="yhead m-rise">
            <h1 class="serif">About you</h1>
            <p>What you share here stays on this device — it simply makes Declare feel like yours.</p>
          </div>

          <div class="yfacts m-rise" id="yFacts"></div>

          <div class="ychips-wrap m-rise">
            <div class="ylbl">Ask me about</div>
            <div class="ychips" id="yChips"></div>
          </div>

          <div class="yhead yhead2 m-rise"><h2 class="serif">Your app</h2></div>
          <div class="yhub m-rise" id="yHub">
            <div class="yhubcard appearance">
              <div class="yh-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"></path></svg></div>
              <div class="yh-t">Appearance</div>
              <div class="yh-d">Dark is home. Choose what fits the hour.</div>
              <nav class="themectl" aria-label="Theme">
                <button data-mode="light">Light</button>
                <button data-mode="dark">Dark</button>
                <button data-mode="system">Auto</button>
              </nav>
            </div>
            <button class="yhubcard" id="hubChurch">
              <div class="yh-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v6M9 5h6M5 22V11l7-4 7 4v11M9 22v-5h6v5"></path></svg></div>
              <div class="yh-t">Find a church</div>
              <div class="yh-d" id="hubChurchD">Discover a fellowship near you</div>
            </button>
            <button class="yhubcard" data-soon>
              <div class="yh-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.7 21a2 2 0 0 1-3.4 0"></path></svg></div>
              <div class="yh-t">Reminders &amp; notifications</div>
              <div class="yh-d">A daily nudge back to the Word <span class="ybadge">Soon</span></div>
            </button>
            <button class="yhubcard" id="hubAuth">
              <div class="yh-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="9" rx="2"></rect><path d="M8 11V8a4 4 0 0 1 8 0v3"></path></svg></div>
              <div class="yh-t">Sign-in &amp; security</div>
              <div class="yh-d" id="hubAuthD">Sign in to keep what God gives you</div>
            </button>
            <a class="yhubcard" href="/help">
              <div class="yh-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M9.3 9.3a2.8 2.8 0 0 1 5.3 1c0 1.8-2.6 2.1-2.6 4"></path><path d="M12 17.4h.01"></path></svg></div>
              <div class="yh-t">Help &amp; support</div>
              <div class="yh-d">Answers, contact, and help when you need it</div>
            </a>
            <a class="yhubcard" href="/give">
              <div class="yh-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20.8 8.6c0 5.5-8.8 11-8.8 11s-8.8-5.5-8.8-11a4.6 4.6 0 0 1 8.8-1.9 4.6 4.6 0 0 1 8.8 1.9z"></path></svg></div>
              <div class="yh-t">Support Declare</div>
              <div class="yh-d">Help keep it free for all</div>
            </a>
            <button class="yhubcard" id="yRateCard">
              <div class="yh-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 17.3l-5.6 3 1.1-6.3L3 9.6l6.3-.9L12 3l2.7 5.7 6.3.9-4.5 4.4 1.1 6.3z"></path></svg></div>
              <div class="yh-t">Rate Declare</div>
              <div class="yh-d">Tell us how it has met you</div>
            </button>
          </div>

          <div class="yver m-fade">DECLARE &middot; VERSION 3.2</div>
        </section>
      </div>
    </div>

    {/* ───── editor modal (Airbnb pattern: title · helper · field · Save) ───── */}
    <div class="ymodal" id="yModal">
      <div class="ym-back" id="ymBack"></div>
      <div class="ym-panel">
        <button class="ym-x" id="ymX" aria-label="Close"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"></path></svg></button>
        <h3 class="serif" id="ymTitle"></h3>
        <p id="ymSub"></p>
        <div id="ymBody"></div>
        <div class="ym-actions"><button class="btn btn-primary" id="ymSave">Save</button></div>
      </div>
    </div>

    {/* ───── church finder overlay (Google Maps + Places, lazy) ───── */}
    <div class="yfinder" id="yFinder">
      <div class="yf-top">
        <button class="iconbtn" id="yfClose" aria-label="Close"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 5l-7 7 7 7"></path></svg></button>
        <div class="yf-h">
          <div class="ti serif">Find a church</div>
          <div class="su">Pick a suggestion — or press Enter to search anything</div>
        </div>
        <span class="iconbtn" style="visibility:hidden"></span>
      </div>
      <div class="yf-body">
        <div class="yf-search"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.5" y2="16.5"></line></svg><input id="yfInput" placeholder="City, state, or church name&hellip;" autocomplete="off" /></div>
        <button class="yf-loc" id="yfLoc"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M12 2v3M12 19v3M2 12h3M19 12h3"></path></svg>Use my location</button>
        <div class="yf-map" id="yfMap"></div>
        <div class="yf-list" id="yfList"></div>
        <div class="yf-missing" id="yfMissing" hidden>
          <div class="serif">Almost ready.</div>
          <p>The church finder needs its Google Maps key. Add <code>PUBLIC_GMAPS_KEY</code> to <code>.env</code> and restart the build &mdash; everything else on this page already works.</p>
        </div>
      </div>
    </div>

    <!-- church detail (house overlay: bottom sheet on mobile, centered card >=720) -->
    <div class="yfdetail" id="yfDetail">
      <div class="ym-back" id="yfdBack"></div>
      <div class="yfd-card">
        <button class="ym-x" id="yfdX" aria-label="Close"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg></button>
        <div class="yfd-photo" id="yfdPhoto" hidden></div>
        <div class="yfd-body">
          <h3 class="serif" id="yfdName"></h3>
          <a class="yfd-addr" id="yfdAddr" target="_blank" rel="noopener"></a>
          <div class="yfd-meta" id="yfdMeta"></div>
          <div class="yfd-hours" id="yfdHours"></div>
          <div class="yfd-actions" id="yfdActions"></div>
          <button class="btn btn-primary yfd-set" id="yfdSet">Set as my church</button>
        </div>
      </div>
    </div>

    <div class="ytoast" id="yToast"></div>

    {/* your-review view (read-only summary of what you rated) */}
    <div class="ymodal yrvmodal" id="yrvModal">
      <div class="ym-back" id="yrvBack"></div>
      <div class="ym-panel">
        <button class="ym-x" id="yrvX" aria-label="Close"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"></path></svg></button>
        <h3 class="serif">Your review</h3>
        <p class="yrv-status" id="yrvStatus"></p>
        <div class="yrv-dims" id="yrvDims"></div>
        <blockquote class="yrv-quote" id="yrvQuote" hidden></blockquote>
        <div class="ym-actions yrv-actions">
          <button class="btn btn-primary" id="yrvUpdate" type="button">Update my review</button>
          <a class="yrv-others" href="/welcome#testimonials">See what others are saying</a>
        </div>
      </div>
    </div>

    {/* Rate & Review surface (opened by the profile card or a ?rate= deep-link). */}
    <RateReview />
  </main>

  <script>
    import { getProfile, setProfile, daysWith } from '../app/declare/profile-store.js';
    import { listItems, listCollections, onChange } from '../app/declare/vault-store.js';
    import { onChange as onAccountSync } from '../app/declare/account-sync.js';
    import { initAuth, isConfigured, isSignedIn, currentUser, signOut, onAuthChange } from '../app/declare/auth-store.js';
    import { openAuthModal } from '../app/declare/auth-modal.js';
    import { initRateReview } from '../app/declare/rate-review.js';
    import { noteSubmitted } from '../app/declare/rate-gate.js';
    import { reviewsSubmit, reviewsMine } from '../app/declare/convex-data.js';

    const GMAPS_KEY = import.meta.env.PUBLIC_GMAPS_KEY || '';
    const $ = (id) => document.getElementById(id);
    const esc = (s) => (s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

    let P = getProfile();

    /* ---------- toast ---------- */
    let _tt;
    function toast(m) { const t = $('yToast'); t.textContent = m; t.classList.add('show'); clearTimeout(_tt); _tt = setTimeout(() => t.classList.remove('show'), 2200); }

    // A signed-out device is a guest: show a clean slate (name, church, verse, about,
    // interests, photo, saved counts) no matter what is left in local storage. The data
    // is not destroyed — it returns when they sign back in. Personal info is account-tied.
    const signedInNow = () => isConfigured() && isSignedIn();

    /* ---------- rail: identity + real device stats ---------- */
    function renderRail() {
      const sIn = signedInNow();
      const name = sIn ? (P.name || '').trim() : '';
      $('yName').textContent = name || 'Friend';
      $('yAvText').textContent = name ? name[0].toUpperCase() : '✝';
      // uploaded photo (if any) overlays the initial; remove-link shows only with one
      (function () {
        const av = $('yAvatar'); let img = av.querySelector('.yav-img'); const rm = $('yAvRemove');
        if (sIn && P.avatar) {
          if (!img) { img = document.createElement('img'); img.className = 'yav-img'; img.alt = ''; av.appendChild(img); }
          img.src = P.avatar; av.classList.add('has-photo'); if (rm) rm.hidden = false;
        } else {
          if (img) img.remove(); av.classList.remove('has-photo'); if (rm) rm.hidden = true;
        }
      })();
      const d = daysWith(P);
      $('yDays').textContent = d;
      $('yDaysLbl').textContent = d === 1 ? 'day with Declare' : 'days with Declare';
      const items = sIn ? listItems() : [];
      const words = items.filter((i) => i.type === 'word').length;
      const verses = items.filter((i) => i.type === 'verse').length;
      let hls = 0; if (sIn) { try { hls = Object.keys(JSON.parse(localStorage.getItem('declare-highlights') || '{}')).length; } catch (e) {} }
      const colls = sIn ? listCollections().length : 0;
      const rows = [
        [words, words === 1 ? 'word received & kept' : 'words received & kept'],
        [verses, verses === 1 ? 'verse saved from the Word' : 'verses saved from the Word'],
        [hls, hls === 1 ? 'verse highlighted' : 'verses highlighted'],
        [colls, colls === 1 ? 'collection' : 'collections'],
      ];
      $('yStats').innerHTML = rows.map(([n, l]) => (
        '<li' + (n ? ' class="has"' : '') + '><span class="ck"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg></span><b>' + n + '</b> ' + l + '</li>'
      )).join('');
    }

    /* ---------- profile photo: pick → crop (drag to position + zoom) → save ----------
       A circular-masked stage; the image is dragged/zoomed beneath it and the framed
       square is exported at 256px JPEG to the device profile (syncs to the account,
       clears on sign-out like the rest of the personal data). ---------- */
    let cropEl = null, cropState = null;
    function clampCrop() {
      const st = cropState; if (!st) return;
      const s = st.baseScale * st.zoom;
      st.tx = Math.min(0, Math.max(st.FRAME - st.iw * s, st.tx));
      st.ty = Math.min(0, Math.max(st.FRAME - st.ih * s, st.ty));
    }
    function applyCrop() {
      const st = cropState; if (!st || !cropEl) return;
      clampCrop();
      const s = st.baseScale * st.zoom;
      cropEl.querySelector('#cropImg').style.transform = 'translate(' + st.tx + 'px,' + st.ty + 'px) scale(' + s + ')';
    }
    function zoomAt(z, ax, ay) {           // zoom around an anchor point (px, in stage coords)
      const st = cropState; if (!st) return;
      z = Math.min(3, Math.max(1, z));
      const sOld = st.baseScale * st.zoom, sNew = st.baseScale * z;
      const ix = (ax - st.tx) / sOld, iy = (ay - st.ty) / sOld;  // image point under the anchor stays put
      st.zoom = z; st.tx = ax - ix * sNew; st.ty = ay - iy * sNew;
      applyCrop();
    }
    function setZoom(z) { const st = cropState; if (st) zoomAt(z, st.FRAME / 2, st.FRAME / 2); }
    function closeCropper() {
      if (cropEl) cropEl.hidden = true;
      if (cropState && cropState.url) { try { URL.revokeObjectURL(cropState.url); } catch (e) {} }
      cropState = null;
    }
    function buildCropper() {
      if (cropEl) return cropEl;
      const el = document.createElement('div');
      el.className = 'cropper'; el.hidden = true;
      el.innerHTML =
        '<div class="crop-card">' +
          '<div class="crop-h">Position your photo</div>' +
          '<div class="crop-tip">Drag to move, slide to zoom.</div>' +
          '<div class="crop-stage" id="cropStage"><img class="crop-img" id="cropImg" alt="" draggable="false" /><div class="crop-ring" aria-hidden="true"></div></div>' +
          '<div class="crop-zoom"><span class="crop-zi">&#8722;</span><input type="range" id="cropZoom" min="1" max="3" step="0.01" value="1" aria-label="Zoom" /><span class="crop-zi crop-zi-lg">+</span></div>' +
          '<div class="crop-actions"><button type="button" class="btn btn-ghost" id="cropCancel">Cancel</button><button type="button" class="btn btn-primary" id="cropSave">Save photo</button></div>' +
        '</div>';
      document.body.appendChild(el);
      cropEl = el;
      const stage = el.querySelector('#cropStage'), zoom = el.querySelector('#cropZoom');
      // one finger drags; two fingers pinch-zoom (around the pinch centre) and pan together
      const pointers = new Map();
      let mode = 'idle', lastX = 0, lastY = 0, pinchDist0 = 1, pinchZoom0 = 1, pinchMid = null;
      function pts() { const a = []; pointers.forEach(function (v) { a.push(v); }); return a; }
      function stageXY(cx, cy) { const r = stage.getBoundingClientRect(); return { x: cx - r.left, y: cy - r.top }; }
      stage.addEventListener('pointerdown', function (e) {
        pointers.set(e.pointerId, { x: e.clientX, y: e.clientY });
        try { stage.setPointerCapture(e.pointerId); } catch (_) {}
        if (pointers.size >= 2) {
          const p = pts(); pinchDist0 = Math.hypot(p[0].x - p[1].x, p[0].y - p[1].y) || 1;
          pinchZoom0 = cropState ? cropState.zoom : 1;
          pinchMid = stageXY((p[0].x + p[1].x) / 2, (p[0].y + p[1].y) / 2); mode = 'pinch';
        } else { mode = 'drag'; lastX = e.clientX; lastY = e.clientY; }
      });
      stage.addEventListener('pointermove', function (e) {
        if (!pointers.has(e.pointerId) || !cropState) return;
        pointers.set(e.pointerId, { x: e.clientX, y: e.clientY });
        if (mode === 'pinch' && pointers.size >= 2) {
          const p = pts(), d = Math.hypot(p[0].x - p[1].x, p[0].y - p[1].y) || 1;
          const m = stageXY((p[0].x + p[1].x) / 2, (p[0].y + p[1].y) / 2);
          cropState.tx += m.x - pinchMid.x; cropState.ty += m.y - pinchMid.y; pinchMid = m;   // pan with the fingers
          zoomAt(pinchZoom0 * (d / pinchDist0), m.x, m.y); zoom.value = String(cropState.zoom);
        } else if (mode === 'drag') {
          cropState.tx += e.clientX - lastX; cropState.ty += e.clientY - lastY; lastX = e.clientX; lastY = e.clientY; applyCrop();
        }
      });
      function liftPointer(e) {
        pointers.delete(e.pointerId);
        if (pointers.size === 1) { mode = 'drag'; const r = pts()[0]; lastX = r.x; lastY = r.y; }
        else if (pointers.size === 0) { mode = 'idle'; }
      }
      stage.addEventListener('pointerup', liftPointer);
      stage.addEventListener('pointercancel', liftPointer);
      stage.addEventListener('wheel', function (e) { if (!cropState) return; e.preventDefault(); setZoom(cropState.zoom - e.deltaY * 0.0016); zoom.value = String(cropState.zoom); }, { passive: false });
      zoom.addEventListener('input', function () { setZoom(parseFloat(zoom.value)); });
      el.querySelector('#cropCancel').addEventListener('click', closeCropper);
      el.addEventListener('click', function (e) { if (e.target === el) closeCropper(); });
      el.querySelector('#cropSave').addEventListener('click', function () {
        const st = cropState; if (!st) return;
        const s = st.baseScale * st.zoom;
        const sx = -st.tx / s, sy = -st.ty / s, sSize = st.FRAME / s, OUT = 256;
        const c = document.createElement('canvas'); c.width = c.height = OUT;
        try {
          c.getContext('2d').drawImage(el.querySelector('#cropImg'), sx, sy, sSize, sSize, 0, 0, OUT, OUT);
          P = setProfile({ avatar: c.toDataURL('image/jpeg', 0.85) }); renderRail();
          closeCropper(); toast('Looking good.');
        } catch (err) { toast("Couldn't save that image."); }
      });
      return el;
    }
    function openCropper(file) {
      const el = buildCropper(), img = el.querySelector('#cropImg'), stage = el.querySelector('#cropStage'), zoom = el.querySelector('#cropZoom');
      const url = URL.createObjectURL(file);
      img.onload = function () {
        img.style.visibility = 'hidden'; el.hidden = false;
        requestAnimationFrame(function () {
          const FRAME = stage.clientWidth || 280, iw = img.naturalWidth, ih = img.naturalHeight;
          const baseScale = FRAME / Math.min(iw, ih);
          cropState = { iw: iw, ih: ih, FRAME: FRAME, baseScale: baseScale, zoom: 1, tx: (FRAME - iw * baseScale) / 2, ty: (FRAME - ih * baseScale) / 2, url: url };
          zoom.value = '1'; applyCrop(); img.style.visibility = 'visible';
        });
      };
      img.onerror = function () { try { URL.revokeObjectURL(url); } catch (e) {} toast("Couldn't read that image."); };
      img.src = url;
    }
    /* tapping the avatar offers a native choice: take a photo (in-app camera, so it
       works on desktop too) or choose one (the OS picker, which on phones already
       shows Photo Library / Take Photo / Files). Both feed the cropper. */
    let pmEl = null, camEl = null, camStream = null;
    function closePhotoMenu() { if (pmEl) pmEl.hidden = true; }
    function buildPhotoMenu() {
      if (pmEl) return pmEl;
      const el = document.createElement('div');
      el.className = 'cammodal'; el.hidden = true;
      el.innerHTML =
        '<div class="cam-card">' +
          '<div class="cam-h">Profile photo</div>' +
          '<button type="button" class="pm-opt" id="pmCamera"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="3.5"/></svg>Take a photo</button>' +
          '<button type="button" class="pm-opt" id="pmChoose"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="9" r="1.6"/><path d="M21 15l-5-5L5 21"/></svg>Choose a photo</button>' +
          '<button type="button" class="pm-opt pm-remove" id="pmRemove" hidden><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M8 6V4h8v2M6 6l1 14h10l1-14"/></svg>Remove photo</button>' +
          '<button type="button" class="btn btn-ghost" id="pmCancel" style="width:100%;margin-top:8px;padding:13px;border-radius:12px;font-family:inherit;font-size:14px;font-weight:600;cursor:pointer;color:var(--text);background:transparent;border:1px solid var(--line2)">Cancel</button>' +
        '</div>';
      document.body.appendChild(el); pmEl = el;
      el.querySelector('#pmCamera').addEventListener('click', function () { closePhotoMenu(); openCamera(); });
      el.querySelector('#pmChoose').addEventListener('click', function () { closePhotoMenu(); $('yAvFile').click(); });
      el.querySelector('#pmRemove').addEventListener('click', function () { closePhotoMenu(); P = setProfile({ avatar: '' }); renderRail(); toast('Photo removed.'); });
      el.querySelector('#pmCancel').addEventListener('click', closePhotoMenu);
      el.addEventListener('click', function (e) { if (e.target === el) closePhotoMenu(); });
      return el;
    }
    function openPhotoMenu() {
      const el = buildPhotoMenu();
      el.querySelector('#pmRemove').hidden = !(P && P.avatar);
      el.hidden = false;
    }
    function stopCam() { if (camStream) { try { camStream.getTracks().forEach(function (t) { t.stop(); }); } catch (e) {} camStream = null; } }
    function closeCamera() { stopCam(); if (camEl) camEl.hidden = true; }
    function buildCamera() {
      if (camEl) return camEl;
      const el = document.createElement('div');
      el.className = 'cammodal'; el.hidden = true;
      el.innerHTML =
        '<div class="cam-card">' +
          '<div class="cam-h">Take a photo</div>' +
          '<div class="cam-stage"><video id="camVideo" autoplay playsinline muted></video><div class="crop-ring" aria-hidden="true"></div></div>' +
          '<div class="cam-actions"><button type="button" class="btn btn-ghost" id="camCancel">Cancel</button><button type="button" class="btn btn-primary" id="camShoot">Capture</button></div>' +
        '</div>';
      document.body.appendChild(el); camEl = el;
      el.querySelector('#camCancel').addEventListener('click', closeCamera);
      el.querySelector('#camShoot').addEventListener('click', function () {
        const v = el.querySelector('#camVideo');
        if (!v.videoWidth) { toast('The camera is still starting…'); return; }
        const cv = document.createElement('canvas'); cv.width = v.videoWidth; cv.height = v.videoHeight;
        const ctx = cv.getContext('2d');
        ctx.translate(cv.width, 0); ctx.scale(-1, 1);   // mirror to match the selfie preview
        ctx.drawImage(v, 0, 0);
        cv.toBlob(function (blob) { closeCamera(); if (blob) openCropper(blob); else toast("Couldn't capture that."); }, 'image/jpeg', 0.92);
      });
      return el;
    }
    async function openCamera() {
      if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) { $('yAvFile').click(); return; }
      let stream;
      try { stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user', width: { ideal: 1280 }, height: { ideal: 1280 } }, audio: false }); }
      catch (e) { toast('Camera unavailable. Choose a photo instead.'); $('yAvFile').click(); return; }
      camStream = stream;
      const el = buildCamera();
      const v = el.querySelector('#camVideo'); v.srcObject = stream;
      el.hidden = false;
      if (v.play) v.play().catch(function () {});
    }
    (function () {
      const av = $('yAvatar'), file = $('yAvFile'), rm = $('yAvRemove');
      if (!av || !file) return;
      av.addEventListener('click', openPhotoMenu);
      file.addEventListener('change', function (e) {
        const f = e.target.files && e.target.files[0]; e.target.value = '';
        if (!f || !/^image\//.test(f.type)) return;
        if (f.size > 12 * 1024 * 1024) { toast('That image is a bit large. Try one under 12MB.'); return; }
        openCropper(f);
      });
      if (rm) rm.addEventListener('click', function () { P = setProfile({ avatar: '' }); renderRail(); toast('Photo removed.'); });
    })();

    /* ---------- About-you fact grid (Airbnb icon rows -> modal editors) ---------- */
    const IC = {
      name: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="3.6"/><path d="M5 20a7 7 0 0 1 14 0"/></svg>',
      church: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v6M9 5h6M5 22V11l7-4 7 4v11M9 22v-5h6v5"/></svg>',
      verse: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5.4A1.4 1.4 0 0 1 5.4 4H11v15.2H5.4A1.4 1.4 0 0 0 4 20.6z"/><path d="M20 5.4A1.4 1.4 0 0 0 18.6 4H13v15.2h5.6A1.4 1.4 0 0 1 20 20.6z"/></svg>',
      about: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.4 8.4 0 0 1-8.5 8.5 8.5 8.5 0 0 1-3.8-.9L3 21l1.9-5.7a8.5 8.5 0 0 1-.9-3.8A8.4 8.4 0 0 1 12.5 3 8.4 8.4 0 0 1 21 11.5z"/></svg>',
    };
    const FACTS = [
      { key: 'name', label: 'My name', empty: 'How should we greet you?' },
      { key: 'church', label: 'My church', empty: 'Find your church' },
      { key: 'verse', label: 'My anchor verse', empty: 'The verse you stand on' },
      { key: 'about', label: 'About me', empty: 'A line about your walk' },
    ];
    function factValue(k) {
      if (!signedInNow()) return '';     // guest = clean slate, no leftover identity
      if (k === 'name') return P.name || '';
      if (k === 'church') return P.church ? P.church.name : '';
      if (k === 'verse') return P.favoriteVerse || '';
      if (k === 'about') return P.about || '';
      return '';
    }
    function renderFacts() {
      $('yFacts').innerHTML = FACTS.map((f) => {
        const v = factValue(f.key);
        return '<button class="yfact" data-fact="' + f.key + '">'
          + '<span class="fi">' + IC[f.key] + '</span>'
          + '<span class="fm"><span class="fl">' + f.label + '</span><span class="fv' + (v ? '' : ' empty') + '">' + esc(v || f.empty) + '</span></span>'
          + '<span class="fa"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg></span></button>';
      }).join('');
      $('yFacts').querySelectorAll('[data-fact]').forEach((b) => {
        b.addEventListener('click', () => {
          const k = b.dataset.fact;
          // a saved church opens its detail card (Airbnb pattern); the finder
          // only appears when there's nothing saved yet
          if (k === 'church') { (signedInNow() && P.church) ? openHomeChurch() : openFinder(); return; }
          openEditor(k);
        });
      });
    }

    /* ---------- interests ("Ask me about") ---------- */
    const INTERESTS = ['Worship', 'Prayer', 'Scripture study', 'Serving', 'Family', 'Testimony', 'Fasting', 'Missions', 'Youth', 'Music', 'Small groups', 'Bible journaling'];
    function renderChips() {
      const mine = signedInNow() ? (P.interests || []) : [];
      $('yChips').innerHTML = mine.map((i) => '<span class="ychip on">' + esc(i) + '</span>').join('')
        + '<button class="ychip add" id="chipAdd">' + (mine.length ? 'Edit' : 'Choose what you love') + ' +</button>';
      $('chipAdd').addEventListener('click', openInterests);
    }

    /* ---------- modal editors (Airbnb pattern, house motion) ---------- */
    let modalKey = null;
    function openModal() { $('yModal').classList.add('open'); }
    function closeModal() { $('yModal').classList.remove('open'); modalKey = null; $('ymSave').style.display = ''; }
    $('ymBack').addEventListener('click', closeModal);
    $('ymX').addEventListener('click', closeModal);
    function openEditor(k) {
      modalKey = k;
      const cfg = {
        name: { t: 'Your name', s: 'Just a first name is perfect — it’s how Declare will greet you.', body: '<input class="ym-field" id="ymInput" maxlength="40" placeholder="e.g. Jeff" value="' + esc((signedInNow() && P.name) || '') + '">' },
        verse: { t: 'Your anchor verse', s: 'The verse you keep coming back to.', body: '<input class="ym-field" id="ymInput" maxlength="80" placeholder="e.g. Isaiah 41:10" value="' + esc((signedInNow() && P.favoriteVerse) || '') + '">' },
        about: { t: 'About you', s: 'A sentence or two about your walk — it stays on this device.', body: '<textarea class="ym-field" id="ymInput" rows="4" maxlength="280" placeholder="Write something honest…">' + esc((signedInNow() && P.about) || '') + '</textarea><div class="ym-count"><span id="ymCount">280</span> characters available</div>' },
      }[k];
      $('ymTitle').textContent = cfg.t;
      $('ymSub').textContent = cfg.s;
      $('ymBody').innerHTML = cfg.body;
      const inp = $('ymInput');
      if (k === 'about') {
        const upd = () => { $('ymCount').textContent = 280 - inp.value.length; };
        inp.addEventListener('input', upd); upd();
      }
      openModal();
      setTimeout(() => inp.focus(), 80);
    }
    function openInterests() {
      modalKey = 'interests';
      $('ymTitle').textContent = 'What are you into?';
      $('ymSub').textContent = 'Pick what you love — people can ask you about it. Up to 6.';
      const mine = new Set(P.interests || []);
      $('ymBody').innerHTML = '<div class="ym-chips">' + INTERESTS.map((i) => (
        '<button class="ychip' + (mine.has(i) ? ' on' : '') + '" data-int="' + esc(i) + '">' + esc(i) + '</button>'
      )).join('') + '</div><div class="ym-count"><span id="ymCount">' + mine.size + '</span>/6 selected</div>';
      $('ymBody').querySelectorAll('[data-int]').forEach((c) => {
        c.addEventListener('click', () => {
          const on = c.classList.contains('on');
          const count = $('ymBody').querySelectorAll('.ychip.on').length;
          if (!on && count >= 6) return;
          c.classList.toggle('on');
          $('ymCount').textContent = $('ymBody').querySelectorAll('.ychip.on').length;
        });
      });
      openModal();
    }
    $('ymSave').addEventListener('click', () => {
      if (modalKey === 'name') P = setProfile({ name: $('ymInput').value.trim() });
      else if (modalKey === 'verse') P = setProfile({ favoriteVerse: $('ymInput').value.trim() });
      else if (modalKey === 'about') P = setProfile({ about: $('ymInput').value.trim() });
      else if (modalKey === 'interests') {
        P = setProfile({ interests: [...$('ymBody').querySelectorAll('.ychip.on')].map((c) => c.dataset.int) });
      }
      closeModal();
      toast('Saved on this device.');
      renderRail(); renderFacts(); renderChips(); renderChurchHub();
    });

    /* ---------- Soon stubs ---------- */
    document.querySelectorAll('[data-soon]').forEach((b) => b.addEventListener('click', () => toast('Coming soon — accounts arrive with V2.')));

    /* ---------- Rate & Review: explicit entries (profile card + ?rate= deep-link) ----------
       No auto toast here — only deliberate opens. Signed-out clicks (from the footer/
       menu deep-links) route through sign-in, then open once the session lands. */
    const _rateCard = $('yRateCard');
    let _myReview = null;
    const rr = initRateReview({
      onSubmit: (payload) => {
        noteSubmitted();
        const p = reviewsSubmit(payload);
        if (p && p.then) p.then(renderMyReview).catch(() => {});
      },
    });
    function openRate(source) {
      if (isConfigured() && !isSignedIn()) {
        let opened = false;
        onAuthChange(() => { if (!opened && isSignedIn()) { opened = true; rr.open(source); } });
        openAuthModal();
        return;
      }
      rr.open(source);
    }
    // After a review exists, the card shows what you rated (gold stars + status)
    // instead of just looping back to the rating flow. Tapping it re-opens to update.
    function renderMyReview() {
      if (!(isConfigured() && isSignedIn()) || !_rateCard) return;
      reviewsMine().then((r) => {
        _myReview = r || null;
        if (!r || !_rateCard) return;
        const ov = Math.round((r.score_met_you + r.score_the_word + r.score_coming_back) / 3);
        let stars = '';
        for (let i = 1; i <= 5; i++) stars += '<span style="color:' + (i <= ov ? 'var(--gold)' : 'var(--line2)') + '">★</span>';
        const status = r.status === 'approved' ? (r.isPublic ? 'Shared publicly' : 'Approved') : 'Pending review';
        const t = _rateCard.querySelector('.yh-t'); if (t) t.textContent = 'Your review';
        const d = _rateCard.querySelector('.yh-d');
        if (d) d.innerHTML = '<span style="letter-spacing:1.5px">' + stars + '</span>'
          + '<span style="color:var(--goldd);margin-left:9px;font-size:10.5px;letter-spacing:.06em;text-transform:uppercase">' + status + '</span>';
      }).catch(() => {});
    }
    // Read-only "Your review" view (what you rated), with an update option.
    function dStars(n) {
      let s = '';
      for (let i = 1; i <= 5; i++) s += '<span style="color:' + (i <= n ? 'var(--gold)' : 'var(--line2)') + '">★</span>';
      return s;
    }
    function openReviewView() {
      const r = _myReview; if (!r) return;
      $('yrvStatus').textContent = r.status === 'approved' ? (r.isPublic ? 'Shared publicly on the site' : 'Approved') : 'Pending review';
      $('yrvDims').innerHTML =
          '<div class="yrv-dim"><span class="yrv-lbl">Met you</span><span class="yrv-stars">' + dStars(r.score_met_you) + '</span></div>'
        + '<div class="yrv-dim"><span class="yrv-lbl">The Word</span><span class="yrv-stars">' + dStars(r.score_the_word) + '</span></div>'
        + '<div class="yrv-dim"><span class="yrv-lbl">Coming back</span><span class="yrv-stars">' + dStars(r.score_coming_back) + '</span></div>';
      const q = $('yrvQuote');
      if (r.testimonial) { q.textContent = '“' + r.testimonial + '”'; q.hidden = false; }
      else { q.hidden = true; }
      $('yrvModal').classList.add('open');
    }
    function closeReviewView() { $('yrvModal').classList.remove('open'); }
    $('yrvX') && $('yrvX').addEventListener('click', closeReviewView);
    $('yrvBack') && $('yrvBack').addEventListener('click', closeReviewView);
    $('yrvUpdate') && $('yrvUpdate').addEventListener('click', () => { closeReviewView(); openRate('profile'); });
    if (_rateCard) _rateCard.addEventListener('click', () => { if (_myReview) openReviewView(); else openRate('profile'); });
    initAuth().then(renderMyReview);
    onAuthChange(renderMyReview);
    try {
      const _rp = new URLSearchParams(location.search).get('rate');
      if (_rp === 'footer' || _rp === 'menu' || _rp === 'profile') initAuth().then(() => openRate(_rp));
    } catch (e) {}

    /* ---------- church hub card reflects the saved church ---------- */
    function renderChurchHub() {
      $('hubChurchD').innerHTML = (signedInNow() && P.church)
        ? esc(P.church.name) + ' <span class="ybadge home">Home</span>'
        : 'Discover a fellowship near you';
    }
    $('hubChurch').addEventListener('click', () => { (signedInNow() && P.church) ? openHomeChurch() : openFinder(); });

    /* ---------- real account session (Convex + Better Auth) ---------- */
    function renderAuth() {
      const signedIn = isConfigured() && isSignedIn();
      const u = signedIn ? currentUser() : null;
      // First sign-in mirrors the account's name onto this device so the rail
      // greets them right away. Only fills a blank name; never overwrites. On
      // sign-out the profile is cleared (see signOut), so the guest slate is blank.
      if (signedIn && u && u.firstName && !getProfile().name) P = setProfile({ name: u.firstName });
      $('yRole').textContent = signedIn ? ((u && u.email) || 'Signed in') : 'Guest · not signed in';
      $('hubAuthD').textContent = signedIn ? ('Signed in as ' + ((u && u.email) || 'you')) : 'Sign in to keep what God gives you';
      // Re-read the profile and re-render every personal surface so name, facts,
      // interests and the church hub reflect the current account/guest state.
      P = getProfile(); renderRail(); renderFacts(); renderChips(); renderChurchHub();
    }
    $('hubAuth').addEventListener('click', () => {
      if (!(isConfigured() && isSignedIn())) {
        // Julienne model: the account card opens right here
        openAuthModal({ mode: 'signin', onSuccess: () => { renderAuth(); toast('Welcome back.'); } });
        return;
      }
      const u = currentUser() || {};
      modalKey = 'auth';
      $('ymTitle').textContent = 'Your account';
      $('ymSub').textContent = 'Signed in as ' + (u.email || 'you') + '. Your words and verses stay on this device for now.';
      $('ymBody').innerHTML = '<button class="btn btn-ghost" id="ymSignout" style="width:100%;margin-top:16px">Sign out</button>';
      $('ymSave').style.display = 'none';
      document.getElementById('ymSignout').addEventListener('click', async () => {
        await signOut(); closeModal(); renderAuth(); toast('Signed out on this device.');
      });
      openModal();
    });
    initAuth().then(renderAuth);
    onAuthChange(renderAuth);

    /* ---------- church finder (Google Maps + Places, lazy) ---------- */
    let gmapsLoading = null, map = null, places = null, markers = [];
    const DARK_MAP = [
      { elementType: 'geometry', stylers: [{ color: '#10201a' }] },
      { elementType: 'labels.text.fill', stylers: [{ color: '#8fa399' }] },
      { elementType: 'labels.text.stroke', stylers: [{ color: '#0b110d' }] },
      { featureType: 'poi', stylers: [{ visibility: 'off' }] },
      { featureType: 'poi.place_of_worship', stylers: [{ visibility: 'on' }] },
      { featureType: 'road', elementType: 'geometry', stylers: [{ color: '#1c2d25' }] },
      { featureType: 'water', elementType: 'geometry', stylers: [{ color: '#0c1a22' }] },
      { featureType: 'transit', stylers: [{ visibility: 'off' }] },
    ];
    function loadGmaps() {
      if (gmapsLoading) return gmapsLoading;
      gmapsLoading = new Promise((resolve, reject) => {
        if (window.google && window.google.maps) { resolve(); return; }
        const s = document.createElement('script');
        s.src = 'https://maps.googleapis.com/maps/api/js?key=' + GMAPS_KEY + '&libraries=places&v=weekly';
        s.async = true; s.onload = resolve; s.onerror = reject;
        document.head.appendChild(s);
      });
      return gmapsLoading;
    }
    function openFinder() {
      $('yFinder').classList.add('open');
      if (!GMAPS_KEY) {
        $('yfMissing').hidden = false;
        $('yfMap').style.display = 'none';
        $('yfLoc').style.display = 'none';
        document.querySelector('.yf-search').style.display = 'none';
        return;
      }
      loadGmaps().then(initFinder).catch(() => toast('Maps couldn’t load — check the key restrictions.'));
    }
    $('yfClose').addEventListener('click', () => $('yFinder').classList.remove('open'));
    function initFinder() {
      if (map) return;
      const center = P.church && P.church.loc ? P.church.loc : { lat: 39.5, lng: -98.35 };
      map = new google.maps.Map($('yfMap'), {
        center, zoom: P.church && P.church.loc ? 12 : 4,
        styles: DARK_MAP, disableDefaultUI: true, zoomControl: true,
      });
      places = new google.maps.places.PlacesService(map);
      const ac = new google.maps.places.Autocomplete($('yfInput'), { fields: ['geometry', 'name', 'formatted_address', 'place_id', 'types'] });
      ac.addListener('place_changed', () => {
        const p = ac.getPlace();
        if (!p) return;
        // Enter pressed on raw text (no suggestion picked) -> full-text church
        // search, so "pentecostal churches" or "Fuente iglesia" just works
        if (!p.geometry) { searchText(p.name); return; }
        if ((p.types || []).indexOf('church') >= 0 || (p.types || []).indexOf('place_of_worship') >= 0) {
          renderChurches([{ name: p.name, vicinity: p.formatted_address, place_id: p.place_id, geometry: p.geometry }]);
          map.setCenter(p.geometry.location); map.setZoom(14);
        } else {
          searchNear(p.geometry.location);
        }
      });
      $('yfLoc').addEventListener('click', () => {
        if (!navigator.geolocation) return;
        navigator.geolocation.getCurrentPosition(
          (pos) => searchNear(new google.maps.LatLng(pos.coords.latitude, pos.coords.longitude)),
          () => toast('Location unavailable — search a city instead.')
        );
      });
    }
    function searchNear(loc) {
      map.setCenter(loc); map.setZoom(12);
      $('yfList').innerHTML = '<div class="yf-note">Looking for churches nearby…</div>';
      places.nearbySearch({ location: loc, radius: 9000, type: 'church' }, (res, status) => {
        if (status !== google.maps.places.PlacesServiceStatus.OK || !res || !res.length) {
          $('yfList').innerHTML = '<div class="yf-note">No churches found here — try a wider search.</div>';
          return;
        }
        renderChurches(res.slice(0, 10));
      });
    }
    /* free-text search: "pentecostal churches", "Fuente iglesia",
       "Fountain church in New Jersey" — Places textSearch understands all of
       these natively. Biased to the current map view so bare denominations
       ("baptist") land near the user, not across the country. */
    function searchText(q) {
      q = (q || '').trim();
      if (q.length < 2) return;
      $('yfList').innerHTML = '<div class="yf-note">Searching churches…</div>';
      const churchy = /church|iglesia|chapel|capilla|temple|templo|ministr|fellowship|assembl|asamblea|tabernac|cathedral|catedral|parish|parroquia|congrega/i.test(q);
      const req = { query: churchy ? q : q + ' church' };
      if (map) { req.location = map.getCenter(); req.radius = 30000; }
      places.textSearch(req, (res, status) => {
        if (status !== google.maps.places.PlacesServiceStatus.OK || !res || !res.length) {
          $('yfList').innerHTML = '<div class="yf-note">Nothing found for “' + esc(q) + '” — try adding a city or zip.</div>';
          return;
        }
        renderChurches(res.slice(0, 10));
      });
    }
    function ratingHtml(c) {
      if (!c.rating) return '';
      return '<span class="star">★</span> ' + Number(c.rating).toFixed(1)
        + (c.user_ratings_total ? ' <span class="dim">(' + c.user_ratings_total + ')</span>' : '');
    }
    function setChurch(c) {
      // Searching for churches is open to everyone; SAVING one as "My church"
      // is a kept thing — it needs an account. The card opens right here and
      // saves the moment they're in.
      if (isConfigured() && !isSignedIn()) {
        openAuthModal({ mode: 'signup', message: 'Create a free account to set your home church.', onSuccess: () => doSetChurch(c) });
        return;
      }
      doSetChurch(c);
    }
    function doSetChurch(c) {
      const loc = c.geometry ? { lat: c.geometry.location.lat(), lng: c.geometry.location.lng() } : null;
      P = setProfile({ church: { name: c.name, address: c.vicinity || c.formatted_address || '', placeId: c.place_id || '', loc } });
      toast('“' + c.name + '” is your home church.');
      renderFacts(); renderChurchHub();
      closeDetail();
      $('yFinder').classList.remove('open');
    }
    function renderChurches(list) {
      markers.forEach((m) => m.setMap(null)); markers = [];
      const bounds = new google.maps.LatLngBounds();
      list.forEach((c) => {
        if (!c.geometry) return;
        const mk = new google.maps.Marker({ map, position: c.geometry.location, title: c.name });
        mk.addListener('click', () => openDetail(c));
        markers.push(mk); bounds.extend(c.geometry.location);
      });
      if (list.length > 1) map.fitBounds(bounds, 48);
      $('yfList').innerHTML = list.map((c, i) => {
        const r = ratingHtml(c);
        return '<div class="yf-row" style="animation-delay:' + (i * 40) + 'ms">'
          + '<button class="yf-m" data-d="' + i + '"><span class="yf-n">' + esc(c.name) + '</span><span class="yf-a">' + esc(c.vicinity || c.formatted_address || '') + '</span>'
          + (r ? '<span class="yf-r">' + r + '</span>' : '') + '</button>'
          + '<button class="yf-set" data-i="' + i + '">Set as my church</button></div>';
      }).join('');
      $('yfList').querySelectorAll('.yf-m').forEach((b) => b.addEventListener('click', () => openDetail(list[+b.dataset.d])));
      $('yfList').querySelectorAll('.yf-set').forEach((b) => b.addEventListener('click', () => setChurch(list[+b.dataset.i])));
    }

    /* ---------- church detail sheet (tap a row or a map pin) ---------- */
    const DICONS = {
      phone: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 2 .7 2.9a2 2 0 0 1-.4 2.1L8.1 10a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.4c.9.3 1.9.6 2.9.7a2 2 0 0 1 1.6 2z"/></svg>',
      globe: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/></svg>',
      pin: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="2.6"/></svg>',
    };
    let detailPlace = null, detailHome = false;
    function metaLine(c) {
      const bits = [];
      const r = ratingHtml(c);
      if (r) bits.push(r);
      let open = null;
      try { if (c.opening_hours && typeof c.opening_hours.isOpen === 'function') open = c.opening_hours.isOpen(); } catch (e) {}
      if (open === true) bits.push('<span class="ok">Open now</span>');
      else if (open === false) bits.push('<span class="dim">Closed now</span>');
      return bits.join('<span class="sep">·</span>');
    }
    function closeDetail() { $('yfDetail').classList.remove('open'); detailPlace = null; }
    $('yfdBack').addEventListener('click', closeDetail);
    $('yfdX').addEventListener('click', closeDetail);
    $('yfdSet').addEventListener('click', () => {
      if (detailHome) { closeDetail(); openFinder(); }
      else if (detailPlace) setChurch(detailPlace);
    });
    function llOf(c) {
      if (c.geometry && c.geometry.location) return { lat: c.geometry.location.lat(), lng: c.geometry.location.lng() };
      return c.loc || null;
    }
    function gmapsDir(c) {
      return 'https://www.google.com/maps/dir/?api=1&destination=' + encodeURIComponent(c.formatted_address || c.name || '')
        + (c.place_id ? '&destination_place_id=' + encodeURIComponent(c.place_id) : '');
    }
    function chipA(label, href, icon) {
      return '<a class="yfd-act" href="' + esc(href) + '" target="_blank" rel="noopener">' + icon + label + '</a>';
    }
    /* plain links — the phone hands each one to the installed app */
    function navActs(c) {
      const dest = encodeURIComponent(c.formatted_address || c.name || '');
      const ll = llOf(c);
      return chipA('Google Maps', gmapsDir(c), DICONS.pin)
        + chipA('Apple Maps', 'https://maps.apple.com/?daddr=' + dest, DICONS.pin)
        + chipA('Waze', ll ? 'https://waze.com/ul?ll=' + ll.lat + ',' + ll.lng + '&navigate=yes' : 'https://waze.com/ul?q=' + dest, DICONS.pin);
    }
    function paintActions(c, d) {
      let acts = '';
      if (d && d.formatted_phone_number) acts += '<a class="yfd-act" href="tel:' + esc(d.formatted_phone_number.replace(/[^+\d]/g, '')) + '">' + DICONS.phone + 'Call</a>';
      if (d && d.website) acts += chipA('Website', d.website, DICONS.globe);
      acts += detailHome ? navActs(c) : chipA('Directions', gmapsDir(c), DICONS.pin);
      $('yfdActions').innerHTML = acts;
    }
    function openDetail(c, home) {
      detailPlace = c; detailHome = !!home;
      // paint instantly from what we already know, then enrich from Google
      $('yfdName').innerHTML = esc(c.name || '') + (home ? ' <span class="ybadge home">Home</span>' : '');
      $('yfdAddr').textContent = c.vicinity || c.formatted_address || '';
      $('yfdAddr').href = gmapsDir(c);
      $('yfdMeta').innerHTML = metaLine(c);
      $('yfdHours').innerHTML = '';
      if (home) paintActions(c, null);
      else $('yfdActions').innerHTML = c.place_id ? '<div class="yf-note">Getting details…</div>' : '';
      $('yfdSet').textContent = home ? 'Search for another church' : 'Set as my church';
      $('yfdSet').classList.toggle('alt', !!home);
      $('yfdPhoto').hidden = true; $('yfdPhoto').style.backgroundImage = '';
      $('yfDetail').classList.add('open');
      if (!c.place_id || !places) { if (!home) $('yfdActions').innerHTML = ''; return; }
      places.getDetails({
        placeId: c.place_id,
        fields: ['name', 'formatted_address', 'formatted_phone_number', 'website', 'opening_hours', 'utc_offset_minutes', 'rating', 'user_ratings_total', 'photos', 'geometry'],
      }, (d, status) => {
        if (detailPlace !== c) return; // user moved on
        if (status !== google.maps.places.PlacesServiceStatus.OK || !d) { if (!detailHome) $('yfdActions').innerHTML = ''; return; }
        // keep the richer record so "Set as my church" saves the full address
        detailPlace = Object.assign({}, c, { name: d.name || c.name, formatted_address: d.formatted_address || c.formatted_address, geometry: d.geometry || c.geometry });
        $('yfdName').innerHTML = esc(detailPlace.name) + (detailHome ? ' <span class="ybadge home">Home</span>' : '');
        if (d.formatted_address) $('yfdAddr').textContent = d.formatted_address;
        $('yfdAddr').href = gmapsDir(detailPlace);
        $('yfdMeta').innerHTML = metaLine(d);
        if (d.photos && d.photos.length) {
          $('yfdPhoto').style.backgroundImage = 'url("' + d.photos[0].getUrl({ maxWidth: 1000, maxHeight: 560 }) + '")';
          $('yfdPhoto').hidden = false;
        }
        if (d.opening_hours && d.opening_hours.weekday_text) {
          const today = (new Date().getDay() + 6) % 7; // weekday_text starts Monday
          $('yfdHours').innerHTML = '<details class="yfd-hrs"><summary>' + esc(d.opening_hours.weekday_text[today]) + '</summary>'
            + d.opening_hours.weekday_text.map((l, i) => '<div class="' + (i === today ? 'on' : '') + '">' + esc(l) + '</div>').join('') + '</details>';
        }
        paintActions(detailPlace, d);
      });
    }
    /* "My church" -> the saved church's own card. Opens instantly from the
       device-local record, then Google fills in photo/hours/phone. */
    function openHomeChurch() {
      const hc = P.church;
      if (!hc) { openFinder(); return; }
      const c = { name: hc.name, formatted_address: hc.address, place_id: hc.placeId || '', loc: hc.loc || null };
      if (!GMAPS_KEY) { openDetail(c, true); return; }
      loadGmaps().then(() => {
        // Places works without the finder's map — a detached node is enough
        if (!places) places = new google.maps.places.PlacesService(document.createElement('div'));
        openDetail(c, true);
      }).catch(() => openDetail(c, true));
    }

    /* ---------- init ---------- */
    renderRail(); renderFacts(); renderChips(); renderChurchHub();
    // refresh stats when the account's Vault syncs in from Convex
    onChange(renderRail);
    // refresh the whole profile (name, church, interests) when it syncs in
    onAccountSync(() => { P = getProfile(); renderRail(); renderFacts(); renderChips(); renderChurchHub(); });
  </script>

