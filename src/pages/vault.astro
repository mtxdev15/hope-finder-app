---
// /vault — the Vault. SURFACE rebuilt verbatim from design-source-v3.2/declare/Vault.html
// (hero + search, cinematic collection shelves, focus view, New-collection sheet, FAB);
// DRIVEN ENTIRELY by the device-local store (vault-store.js, 'declare-vault-v1') — zero
// dummy seeds. Words saved on /today explode into their verses, declarations and prayer;
// verses saved in the reader shelve under "Saved verses"; collections are real and
// persisted ('declare-vault-colls-v1'). First-time users get the honest empty state.
// "From your journeys" + the "From a journey" create mode stay hidden until Journey ships.
import DeclareLayout from '../layouts/DeclareLayout.astro';
---
<DeclareLayout
  title="Declare — Vault"
  description="Return to what God has spoken over you."
  activeTab="vault"
>
  <main class="vault">
    <div class="topglow" aria-hidden="true"></div>

    <div class="vscroll" id="vscroll">
      <div class="vhero">
        <h1>Vault</h1>
        <div class="sub">Return to what God has spoken over you.</div>
        <div class="vsearch" id="vsearchWrap"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><path d="M21 21l-4-4"></path></svg><input id="search" type="search" placeholder="Search your Vault&hellip;" autocomplete="off" /></div>
      </div>
      <div id="shelves"></div>

      {/* first-run empty state (shown only when the store is empty) */}
      <div class="vempty" id="vempty" hidden>
        <div class="ve-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3.5" y="5" width="17" height="15" rx="2.5"></rect><path d="M3.5 9.5h17"></path><path d="M8 5V3.5M16 5V3.5M12 13.2v3"></path><circle cx="12" cy="12.4" r="1.3"></circle></svg></div>
        <h2 class="serif">Your Vault awaits.</h2>
        <p>Every word you receive, every verse you save, every prayer you keep &mdash; it all lives here, saved on this device.</p>
        <div class="ve-actions">
          <a class="btn btn-primary" href="/today">Receive the Word
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;margin-left:7px;vertical-align:-3px"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></a>
          <a class="btn btn-ghost" href="/word">Read the Word</a>
        </div>
      </div>
    </div>

    <button class="fab" id="fab" hidden><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"></path></svg>New</button>

    {/* focus overlay (design) */}
    <div class="focus" id="focus"><div class="focus-glow"></div>
      <div class="focus-top">
        <button class="focus-back" id="focusBack"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6"></path></svg></button>
        <div class="focus-h"><div class="ti" id="focusTi"></div><div class="su" id="focusSu"></div></div>
      </div>
      <div class="focus-in" id="focusIn"></div>
    </div>

    {/* New collection sheet (design; "From a journey" hidden until Journey ships) */}
    <div class="vsheet" id="createSheet">
      <div class="grabber"></div>
      <div id="createStep1">
        <h3>New collection</h3>
        <p>Gather truths into a space of your own. How would you like to begin?</p>
        <div class="opts">
          <button class="opt" data-mode="type"><span class="oic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5.4A1.4 1.4 0 0 1 5.4 4H11v15.2H5.4A1.4 1.4 0 0 0 4 20.6z"></path><path d="M20 5.4A1.4 1.4 0 0 0 18.6 4H13v15.2h5.6A1.4 1.4 0 0 1 20 20.6z"></path></svg></span><span class="om"><span class="t">By kind</span><span class="s">Group your scriptures, declarations, or prayers</span></span><span class="go"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg></span></button>
          <button class="opt" data-mode="blank"><span class="oic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"></path></svg></span><span class="om"><span class="t">Start empty</span><span class="s">Name it now, add truths as you go</span></span><span class="go"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg></span></button>
        </div>
      </div>
      <div id="createStep2" class="hidden">
        <h3 id="step2Title">Name your collection</h3>
        <p id="step2Sub">Give it a name you&rsquo;ll recognize.</p>
        <div class="kindrow hidden" id="kindRow">
          <button class="kbtn on" data-kind="verse">Scriptures</button>
          <button class="kbtn" data-kind="declaration">Declarations</button>
          <button class="kbtn" data-kind="prayer">Prayers</button>
        </div>
        <div class="namewrap"><input id="collName" type="text" placeholder="e.g. Morning declarations" /></div>
        <div class="sactions"><button class="btn btn-primary" id="createGo">Create collection</button><button class="btn btn-ghost" id="createBack">Back</button></div>
      </div>
    </div>

    <div class="vtoast" id="vtoast"></div>
    <div class="vscrim" id="vscrim"></div>
  </main>

  <script>
    import { listItems, removeItem, listCollections, addCollection, removeCollection, onChange } from '../app/declare/vault-store.js';
    import { initAuth } from '../app/declare/auth-store.js';
    import { ensureSignedIn } from '../app/declare/auth-gate.js';
    initAuth(); // resolve any saved session before the user reaches a gate

    const $ = (id) => document.getElementById(id);
    const esc = (s) => (s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    const TYPES = {
      verse: { label: 'Scripture', tagt: '#E8C97A' },
      declaration: { label: 'Declaration', tagt: '#E0A45A' },
      prayer: { label: 'Prayer', tagt: '#9BD0A8' },
    };
    function relTime(ts) {
      const d = (Date.now() - ts) / 86400000;
      if (d < 1) return Math.max(1, Math.round(d * 24)) + 'h ago';
      if (d < 2) return 'Yesterday';
      if (d < 7) return Math.round(d) + ' days ago';
      return Math.round(d / 7) + 'w ago';
    }

    /* a saved struggle can grow into a 5-day journey (design's bridge) */
    const JOURNEYS = [
      { re: /shame|guilt|condemn/i, struggle: 'Shame & Guilt', to: 'Beloved of God' },
      { re: /fear|anxiet|worry|panic/i, struggle: 'Fear & Anxiety', to: 'Peace' },
      { re: /grief|loss|mourn|bereav/i, struggle: 'Grief & Loss', to: 'Comfort' },
      { re: /lonel|alone|isolat/i, struggle: 'Loneliness', to: 'Held by God' },
      { re: /doubt|unbelief|cynic/i, struggle: 'Doubt', to: 'Faith' },
      { re: /anger|rage|bitter|resent/i, struggle: 'Anger', to: 'Peace' },
      { re: /burnout|exhaust|overwhelm|weary/i, struggle: 'Burnout', to: 'Rest' },
    ];
    const journeyFor = (name) => JOURNEYS.find((j) => j.re.test(name || '')) || null;

    /* ---- explode store items into display TRUTHS (the real user data) ----
       word (from /today)  -> its verses + declarations + prayer, coll = struggle
       verse (from reader) -> one truth, coll = "Saved verses"
       prayer              -> one truth, coll = its struggle or "Prayers" */
    let truths = [], userColls = [];
    function rebuild() {
      truths = [];
      listItems().forEach((it) => {
        if (it.type === 'word') {
          (it.verses || []).forEach((v) => truths.push({ parentId: it.id, type: 'verse', body: v.text, vref: v.ref, coll: it.struggle || 'Saved', trans: it.translation, ts: it.ts, parentKind: 'word' }));
          (it.declarations || []).forEach((d) => truths.push({ parentId: it.id, type: 'declaration', body: d, coll: it.struggle || 'Saved', ts: it.ts, parentKind: 'word' }));
          if (it.prayer) truths.push({ parentId: it.id, type: 'prayer', body: it.prayer, coll: it.struggle || 'Saved', ts: it.ts, parentKind: 'word' });
        } else if (it.type === 'verse') {
          truths.push({ parentId: it.id, type: 'verse', body: it.text, vref: it.ref, coll: 'Saved verses', trans: it.translation, ts: it.ts, parentKind: 'verse' });
        } else if (it.type === 'prayer') {
          truths.push({ parentId: it.id, type: 'prayer', body: it.prayer || it.text, coll: it.struggle || 'Prayers', ts: it.ts, parentKind: 'prayer' });
        }
      });
      userColls = listCollections();
    }

    let query = '';
    const matches = (t) => !query || ((t.body || '') + ' ' + (t.vref || '') + ' ' + (t.coll || '')).toLowerCase().includes(query.toLowerCase());
    function collTruths(c) {
      if (c.kind) return truths.filter((t) => t.type === c.kind && matches(t));
      return truths.filter((t) => (t.coll || 'Saved') === c.name && matches(t));
    }
    /* groups for the shelves: auto groups (by coll) + user collections */
    function autoGroups() {
      const map = {}, order = [];
      truths.filter(matches).forEach((t) => {
        const k = t.coll || 'Saved';
        if (!map[k]) { map[k] = []; order.push(k); }
        map[k].push(t);
      });
      return order.map((k) => ({ name: k, kind: null, items: map[k], mine: false, recent: map[k].reduce((m, x) => Math.max(m, x.ts), 0) }))
        .sort((a, b) => b.recent - a.recent);
    }

    /* ---- shelf cards (design bcard) ---- */
    function bcard(c, count, top) {
      const cfg = TYPES[top ? top.type : 'verse'] || TYPES.verse;
      const body = top ? (top.body || '').replace(/[“”"]/g, '') : 'Nothing here yet — add truths as you save them.';
      let sparks = '';
      [[20, 26, 2], [78, 20, 1.5], [64, 46, 1.8]].forEach((s, k) => { sparks += '<span class="spark" style="left:' + s[0] + '%;top:' + s[1] + '%;width:' + s[2] + 'px;height:' + s[2] + 'px;animation-delay:' + (k * 0.8) + 's"></span>'; });
      return '<button class="bcard" data-coll="' + encodeURIComponent(c.name) + '" data-kind="' + (c.kind || '') + '" style="--bctag:' + cfg.tagt + '"><span class="bg-glow"></span>' + sparks
        + '<div class="bc-top"><span class="bc-tag">' + (c.mine ? 'Yours' : esc(cfg.label)) + '</span><span class="bc-count">' + count + '</span></div>'
        + '<div class="bc-quote"><span>' + (top ? '“' + esc(body.slice(0, 110)) + (body.length > 110 ? '…' : '') + '”' : esc(body)) + '</span></div>'
        + '<div class="bc-name">' + esc(c.name) + '</div><div class="bc-meta">' + count + (count === 1 ? ' truth' : ' truths') + (c.recent ? ' · ' + relTime(c.recent) : '') + '</div></button>';
    }
    const createCard = () => '<button class="createcard" id="cc-create"><span class="cc-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg></span><span class="cc-t">New collection</span></button>';
    function shelf(title, cardsHtml, delay) {
      if (!cardsHtml) return '';
      return '<section class="shelf" style="animation-delay:' + delay + 'ms"><div class="shelf-h"><span class="t">' + title + '</span></div><div class="rail">' + cardsHtml + '</div></section>';
    }

    function render() {
      rebuild();
      const empty = !truths.length && !userColls.length;
      $('vempty').hidden = !empty;
      $('fab').hidden = empty;
      $('vsearchWrap').style.display = empty ? 'none' : '';
      if (empty) { $('shelves').innerHTML = ''; return; }

      const groups = autoGroups();
      const recentHtml = groups.slice(0, 6).map((c) => bcard(c, c.items.length, c.items[0])).join('');
      const yoursHtml = userColls.map((c) => {
        const its = collTruths(c);
        return bcard({ name: c.name, kind: c.kind, mine: true, recent: its.length ? its[0].ts : c.ts }, its.length, its[0] || null);
      }).join('') + createCard();

      let html = '';
      html += shelf('Recently saved', recentHtml, 0);
      html += shelf('Your collections', yoursHtml, 90);
      if (query && !groups.length) html = '<div class="empty-note">Nothing matches your search.</div>' + shelf('Your collections', yoursHtml, 0);
      $('shelves').innerHTML = html;
      $('shelves').querySelectorAll('.bcard').forEach((b) => { b.onclick = () => openFocus(decodeURIComponent(b.dataset.coll), b.dataset.kind || null); });
      const cc = $('cc-create'); if (cc) cc.onclick = openCreate;
    }

    /* ---- focus view ---- */
    const READ_ALIASES = { 'Psalm': 'Psalms', 'Song of Songs': 'Song of Solomon', 'Revelations': 'Revelation' };
    function readLink(vref) {
      const m = (vref || '').match(/^(.*?)\s+(\d+)\s*:\s*(\d+)/);
      if (!m) return '/word';
      const book = READ_ALIASES[m[1].trim()] || m[1].trim();
      return '/word?book=' + encodeURIComponent(book) + '&chapter=' + m[2] + '&verse=' + m[3];
    }
    let focusList = [];
    function openFocus(name, kind) {
      const c = kind ? { name, kind } : (userColls.find((x) => x.name === name && !x.kind) || { name, kind: null });
      focusList = collTruths(c);
      const jrn = journeyFor(name);
      $('focusTi').textContent = name;
      $('focusSu').textContent = focusList.length + (focusList.length === 1 ? ' truth' : ' truths');
      let html = focusList.map((t, i) => {
        const cfg = TYPES[t.type] || TYPES.verse;
        let foot = '';
        if (t.vref) {
          foot = '<div class="ft-ref">' + esc(t.vref) + (t.trans ? ' · ' + esc(t.trans) : '') + '</div>'
            + '<a class="ft-read" href="' + readLink(t.vref) + '"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5.4A1.4 1.4 0 0 1 5.4 4H11v15.2H5.4A1.4 1.4 0 0 0 4 20.6z"/><path d="M20 5.4A1.4 1.4 0 0 0 18.6 4H13v15.2h5.6A1.4 1.4 0 0 1 20 20.6z"/></svg>Read in the Word</a>';
        }
        return '<div class="ftruth ' + (t.type === 'declaration' ? 'dec' : t.type === 'prayer' ? 'pray' : '') + '" style="--tagt:' + cfg.tagt + ';animation-delay:' + (i * 70) + 'ms"><span class="ft-glow"></span>'
          + '<span class="ft-acts"><button class="ft-share" data-i="' + i + '" aria-label="Share"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v13"/><path d="M8 7l4-4 4 4"/><path d="M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-7"/></svg></button>'
          + '<button class="ft-del" data-i="' + i + '" aria-label="Remove"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7h16M9 7V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2M6.5 7l1 13h9l1-13"/></svg></button></span>'
          + '<span class="ft-tag">' + cfg.label + '</span><div class="ft-body">' + (t.type === 'declaration' ? esc(t.body) : '“' + esc(t.body) + '”') + '</div>' + foot + '</div>';
      }).join('');
      if (!focusList.length) {
        html = '<div class="empty-note">Nothing here yet. Save a word on Declare or a verse in the Word and it will find its way here.</div>'
          + '<div class="ve-actions" style="justify-content:center"><a class="btn btn-primary" href="/today">Receive the Word</a><a class="btn btn-ghost" href="/word">Read the Word</a></div>'
          + (c.kind ? '' : (userColls.some((x) => x.name === name && !x.kind)
            ? '<div class="empty-note" style="padding-top:8px"><button class="vlink" id="collDelete">Delete this collection</button></div>' : ''));
      }
      if (jrn) {
        html += '<div class="vdeep"><div class="vd-glow"></div>'
          + '<div class="vd-tag">Be transplanted</div>'
          + '<div class="vd-h">Don’t just keep it here</div>'
          + '<div class="vd-shift"><b>' + esc(jrn.struggle) + '</b><span class="arr">→</span><b>' + esc(jrn.to) + '</b></div>'
          + '<div class="vd-p">These are seeds. Give them five days to take root — one declaration a day — and watch the shift become real.</div>'
          + '<a class="btn btn-primary" href="/journey">Start a 5-Day Journey'
          + '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;margin-left:7px;vertical-align:-3px"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a></div>';
      }
      $('focusIn').innerHTML = html;
      // bridge: hand /journey the struggle so it plants the matching vine and opens Day 1
      const vd = $('focusIn').querySelector('.vdeep a[href="/journey"]');
      if (vd && jrn) vd.addEventListener('click', () => {
        try {
          localStorage.setItem('declare-start-journey', '1');
          localStorage.setItem('declare-journey-struggle', jrn.struggle);
        } catch (e) {}
      });
      const del = $('collDelete');
      if (del) del.onclick = () => { removeCollection(name); toast('Collection removed'); closeFocus(); render(); };
      $('focusIn').querySelectorAll('.ft-share').forEach((b) => {
        b.onclick = (e) => {
          e.stopPropagation();
          const t = focusList[+b.dataset.i];
          const stype = t.type === 'verse' ? 'verse' : t.type === 'declaration' ? 'declaration' : 'reading';
          loadShareStack().then(() => {
            if (window.DeclareShare) window.DeclareShare.open({ type: stype, text: t.body, ref: t.vref ? t.vref + (t.trans ? ' · ' + t.trans : '') : (t.type === 'prayer' ? 'A prayer' : ''), subtitle: t.coll || 'From your Vault', url: location.href });
          });
        };
      });
      $('focusIn').querySelectorAll('.ft-del').forEach((b) => {
        b.onclick = (e) => {
          e.stopPropagation();
          const t = focusList[+b.dataset.i];
          removeItem(t.parentId);
          toast(t.parentKind === 'word' ? 'Word removed from Vault' : 'Removed from Vault');
          render();
          openFocus(name, kind);
          if (!collTruths(c).length && !kind && !userColls.some((x) => x.name === name)) closeFocus();
        };
      });
      $('focus').classList.add('show');
    }
    function closeFocus() { $('focus').classList.remove('show'); }
    $('focusBack').onclick = closeFocus;

    /* ---- share stack (lazy, shared pattern) ---- */
    let shareStack = null;
    function loadShareStack() {
      if (shareStack) return shareStack;
      shareStack = new Promise((resolve) => {
        ['/declare/share.css', '/declare/card-studio.css'].forEach((href) => {
          const l = document.createElement('link'); l.rel = 'stylesheet'; l.href = href; document.head.appendChild(l);
        });
        const s1 = document.createElement('script'); s1.src = '/declare/card-studio.js';
        s1.onload = () => { const s2 = document.createElement('script'); s2.src = '/declare/share.js'; s2.onload = resolve; document.head.appendChild(s2); };
        s1.onerror = resolve;
        document.head.appendChild(s1);
      });
      return shareStack;
    }

    /* ---- New collection sheet ---- */
    let pendingMode = null, pendingKind = 'verse';
    function openCreate() {
      // gate before they invest in naming it
      if (!ensureSignedIn('Create a free account to build your own collections.')) return;
      $('createStep1').classList.remove('hidden'); $('createStep2').classList.add('hidden');
      $('createSheet').classList.add('open'); $('vscrim').classList.add('open');
    }
    function closeSheet() { $('createSheet').classList.remove('open'); $('vscrim').classList.remove('open'); }
    $('vscrim').onclick = closeSheet;
    $('fab').onclick = openCreate;
    document.querySelectorAll('.opt').forEach((o) => {
      o.onclick = () => {
        pendingMode = o.dataset.mode;
        const titles = { type: 'By kind', blank: 'Name your collection' };
        const subs = { type: 'We’ll gather every truth of one kind, automatically.', blank: 'Give it a name you’ll recognize.' };
        $('step2Title').textContent = titles[pendingMode];
        $('step2Sub').textContent = subs[pendingMode];
        $('kindRow').classList.toggle('hidden', pendingMode !== 'type');
        $('createStep1').classList.add('hidden'); $('createStep2').classList.remove('hidden');
        $('collName').value = pendingMode === 'type' ? 'My scriptures' : '';
        setTimeout(() => $('collName').focus(), 60);
      };
    });
    $('kindRow').addEventListener('click', (e) => {
      const b = e.target.closest('.kbtn'); if (!b) return;
      $('kindRow').querySelectorAll('.kbtn').forEach((x) => x.classList.remove('on'));
      b.classList.add('on'); pendingKind = b.dataset.kind;
      const names = { verse: 'My scriptures', declaration: 'My declarations', prayer: 'My prayers' };
      if (!$('collName').value || Object.values(names).includes($('collName').value)) $('collName').value = names[pendingKind];
    });
    $('createBack').onclick = () => { $('createStep2').classList.add('hidden'); $('createStep1').classList.remove('hidden'); };
    $('createGo').onclick = () => {
      const nm = ($('collName').value || '').trim() || 'New collection';
      addCollection(nm, pendingMode === 'type' ? pendingKind : null);
      closeSheet(); $('collName').value = '';
      toast('“' + nm + '” created');
      render();
    };

    let _tt;
    function toast(m) { const t = $('vtoast'); t.textContent = m; t.classList.add('show'); clearTimeout(_tt); _tt = setTimeout(() => t.classList.remove('show'), 2200); }

    let st;
    $('search').addEventListener('input', function () { query = this.value; clearTimeout(st); st = setTimeout(render, 90); });

    render();
    // re-render when the account's Vault syncs in from Convex
    onChange(render);
  </script>

  <style is:global>
    /* ──────────────────────────────────────────────────────────────────
       /vault page styles — ported from Vault.html's page-local <style>,
       namespaced under .vault. Tokens/base from declare.css.
       ────────────────────────────────────────────────────────────────── */
    .vault { position: relative; min-height: 100dvh; }
    .vault .vscroll { position: relative; z-index: 1; padding-bottom: 130px; }
    .vault .vhero { text-align: center; padding: 26px 22px 2px; }
    .vault .vhero h1 { font-family: 'Cormorant Garamond', serif; font-size: 44px; font-weight: 600; color: var(--text); text-shadow: 0 0 50px rgba(222, 190, 100, .25); }
    .vault .vhero .sub { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 16px; color: var(--soft); margin-top: 7px; }
    .vault .vsearch { display: flex; align-items: center; gap: 11px; margin: 20px auto 0; max-width: 560px; padding: 13px 16px; background: var(--surface); border-radius: 16px; box-shadow: var(--card-shadow); }
    .vault .vsearch svg { flex: 0 0 auto; width: 17px; height: 17px; color: var(--goldd); }
    .vault .vsearch input { flex: 1; border: 0; background: transparent; outline: none; font-family: inherit; font-size: 14px; color: var(--text); }
    .vault .vsearch input::placeholder { color: var(--muted); }

    /* shelves + rails */
    .vault .shelf { margin-top: 26px; opacity: 0; transform: translateY(18px); animation: vrise .6s cubic-bezier(.22, 1, .36, 1) forwards; }
    @keyframes vrise { to { opacity: 1; transform: none; } }
    @media (prefers-reduced-motion: reduce) { .vault .shelf { animation: none; opacity: 1; transform: none; } }
    .vault .shelf-h { display: flex; align-items: baseline; justify-content: space-between; padding: 0 22px; margin-bottom: 13px; }
    .vault .shelf-h .t { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; color: var(--text); }
    .vault .rail { display: flex; gap: 14px; overflow-x: auto; overflow-y: visible; scroll-snap-type: x mandatory; padding: 14px 22px 20px; scrollbar-width: none; -webkit-overflow-scrolling: touch; margin-top: -10px; margin-bottom: -12px; }
    .vault .rail::-webkit-scrollbar { display: none; }

    /* big cinematic card */
    .vault .bcard { position: relative; flex: 0 0 auto; width: 248px; height: 300px; scroll-snap-align: start; border-radius: 22px; overflow: hidden; cursor: pointer;
      border: 1px solid color-mix(in srgb, var(--gold) 18%, transparent); background: radial-gradient(130% 100% at 30% 0%, #21362a, #0b110d 80%);
      box-shadow: 0 26px 60px -28px rgba(0, 0, 0, .75); display: flex; flex-direction: column; justify-content: flex-end; padding: 20px; text-align: left; font-family: inherit;
      transition: transform .45s cubic-bezier(.22, 1, .36, 1), box-shadow .45s ease, border-color .3s ease; }
    .vault .bcard .bg-glow { position: absolute; inset: 0; pointer-events: none; background: radial-gradient(60% 50% at 50% 22%, rgba(222, 190, 100, .22), transparent 72%); opacity: .85; transition: opacity .45s ease; }
    .vault .bcard .spark { position: absolute; border-radius: 50%; background: rgba(246, 234, 194, .85); opacity: 0; animation: vtw 5s ease-in-out infinite; }
    @keyframes vtw { 0%, 100% { opacity: 0; transform: scale(.6); } 50% { opacity: .8; transform: scale(1); } }
    @media (prefers-reduced-motion: reduce) { .vault .bcard .spark { animation: none; } }
    @media (hover: hover) {
      .vault .bcard:hover { transform: translateY(-7px) scale(1.012); border-color: color-mix(in srgb, var(--gold) 42%, transparent); box-shadow: 0 36px 70px -26px rgba(0, 0, 0, .8), 0 0 60px -16px rgba(216, 184, 95, .34); }
      .vault .bcard:hover .bg-glow { opacity: 1; }
    }
    .vault .bcard:active { transform: translateY(-3px) scale(1.0); }
    .vault .bc-top { position: relative; z-index: 2; display: flex; align-items: center; justify-content: space-between; }
    .vault .bc-tag { font-size: 9.5px; letter-spacing: .16em; text-transform: uppercase; font-weight: 700; color: var(--bctag, #E8C97A); }
    .vault .bc-count { font-size: 11px; font-weight: 700; color: rgba(243, 239, 230, .5); }
    .vault .bc-quote { position: relative; z-index: 2; flex: 1; display: flex; align-items: center; }
