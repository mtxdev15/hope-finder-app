---
// /vault — the "Vault" (saved words) page. V1 has no accounts and nothing saved
// (saving is V2/Supabase), so this is an HONEST EMPTY STATE — never the design's
// fake SEED cards. Hero + a warm "nothing saved yet" message naming the three real
// savable kinds + a "Receive a word" loop back into the Declare flow. Static page,
// no React island, no inline JS (theme is controlled from /you via the shared theme.js).
import DeclareLayout from '../layouts/DeclareLayout.astro';
---
<DeclareLayout
  title="Declare — Vault"
  description="Return to what God has spoken over you."
  activeTab="vault"
>
  <main class="vault">
    <div class="topglow" aria-hidden="true"></div>
    <div class="vault-col">

      <div class="vhero rise d1">
        <h1>Vault</h1>
        <div class="sub">Return to what God has spoken over you.</div>
      </div>

      <div class="vempty rise d2">
        <div class="vempty-glyph" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3.5" y="5" width="17" height="15" rx="2.5"/><path d="M3.5 9.5h17"/><path d="M8 5V3.5M16 5V3.5M12 13.2v3"/><circle cx="12" cy="12.4" r="1.3"/></svg>
        </div>
        <h2 class="vempty-title">Nothing saved yet</h2>
        <p class="vempty-body">When a verse, your own declaration, or a prayer meets you, keep it here &mdash; a place to return to what God has spoken over you. Saving is coming soon.</p>
        <a class="btn btn-primary vempty-cta" href="/today">
          Receive a word
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>

    </div>
  </main>

  <style>
    /* page-local Vault styles (the .btn / .topglow / .rise styling + tokens come
       from global declare.css). Honest empty state — no saved-card/shelf CSS. */
    .vault {
      position: relative;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      padding-bottom: calc(108px + env(safe-area-inset-bottom, 0));
    }
    .vault-col {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 560px;
      margin: 0 auto;
      padding: 0 22px;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    /* hero */
    .vhero { text-align: center; padding: 36px 4px 4px; }
    .vhero h1 { font-family: 'Cormorant Garamond', serif; font-size: 48px; line-height: 1; color: var(--text); font-weight: 600; }
    .vhero .sub { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 16px; color: var(--muted); margin-top: 8px; }

    /* empty state — centered in the remaining space */
    .vempty {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      gap: 6px;
      padding: 24px 6px 48px;
    }
    .vempty-glyph {
      width: 76px; height: 76px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      color: var(--goldd);
      background: color-mix(in srgb, var(--gold) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--gold) 24%, transparent);
      box-shadow: 0 0 34px -8px rgba(216, 184, 95, .4);
      margin-bottom: 14px;
    }
    .vempty-glyph svg { width: 34px; height: 34px; }
    .vempty-title { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 600; color: var(--text); }
    .vempty-body { font-size: 14px; line-height: 1.6; color: var(--muted); max-width: 40ch; margin: 4px 0 22px; text-wrap: pretty; }
    .vempty-cta { display: inline-flex; align-items: center; gap: 9px; }
    .vempty-cta svg { width: 16px; height: 16px; }
  </style>
</DeclareLayout>
