<script>
  import { initAuth, isSignedIn } from '../app/declare/auth-store.js';
  import { openAuthModal } from '../app/declare/auth-modal.js';

  // Signed-in users always skip Begin → straight to /today (covers cross-day).
  initAuth().then(() => { try { if (isSignedIn()) location.replace('/today'); } catch (e) {} });

  // Crossing the threshold records today's date — Begin won't reappear until tomorrow.
  function crossToday(){ try { localStorage.setItem('declare-begin-day', new Date().toISOString().slice(0, 10)); } catch (e) {} }
  document.querySelectorAll('#beginLink, #menuBtn, .hm-item').forEach((a) => a.addEventListener('click', crossToday));

  // "Sign in" opens the in-place auth modal (Julienne); success → /today.
  const signinBtn = document.getElementById('signinLink');
  if (signinBtn) signinBtn.addEventListener('click', () => {
    openAuthModal({ mode: 'signin', onSuccess: () => location.replace('/today') });
  });

  // Full-screen menu open/close.
  const menuBtn = document.getElementById('menuBtn');
  const menu = document.getElementById('heroMenu');
  const menuClose = document.getElementById('menuClose');
  function openMenu(){ menu.querySelectorAll('.m-menu-item').forEach((el, i) => el.style.setProperty('--i', i)); menu.classList.add('open'); menu.setAttribute('aria-hidden', 'false'); menuBtn.setAttribute('aria-expanded', 'true'); }
  function closeMenu(){ menu.classList.remove('open'); menu.setAttribute('aria-hidden', 'true'); menuBtn.setAttribute('aria-expanded', 'false'); }
  menuBtn.addEventListener('click', openMenu);
  menuClose.addEventListener('click', closeMenu);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && menu.classList.contains('open')) closeMenu(); });

  // Greet a returning, signed-in user by name + part of day.
  try {
    const fn = localStorage.getItem('declare-firstname');
    if (fn) {
      const h = new Date().getHours();
      const part = h < 12 ? 'morning' : h < 18 ? 'afternoon' : 'evening';
      const k = document.getElementById('heroKicker');
      if (k) k.textContent = 'Good ' + part + ', ' + fn;
    }
  } catch (e) {}
</script>
