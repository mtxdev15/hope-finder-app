  .hero-menu .hm-item .hm-t{ font-family:'Cormorant Garamond',serif; font-size:clamp(32px,8.4vw,44px); font-weight:600; color:var(--text); line-height:1.05; white-space:nowrap; transition:color .35s var(--ease-soft), transform .45s var(--ease-reveal); }
  .hero-menu .hm-item .uarrow{ width:38px; height:12px; color:var(--muted); opacity:0; transform:translateX(-8px); transition:opacity .4s ease, transform .45s var(--ease-reveal), color .3s ease; }
