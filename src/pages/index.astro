---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import StruggleInput from '../components/StruggleInput.astro';
import ResponseDisplay from '../components/ResponseDisplay.astro';
---

<Layout>
  <Header />
  <main>
    <StruggleInput />
    <ResponseDisplay />
  </main>
  <footer>
    Built to renew the mind — <span>Declare &amp; Believe</span> · To God be the glory. Forever.
  </footer>
</Layout>

<script>
  let selectedChips: string[] = [];
  let selectedTranslation = 'NKJV';
  let currentResult: any = null;

  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', () => {
      chip.classList.toggle('selected');
      const val = (chip as HTMLElement).dataset.val!;
      if (chip.classList.contains('selected')) {
        if (!selectedChips.includes(val)) selectedChips.push(val);
      } else {
        selectedChips = selectedChips.filter(v => v !== val);
      }
      const crisisSelected = selectedChips.some(v => v.includes('suicidal'));
      document.getElementById('crisisBanner')!.classList.toggle('visible', crisisSelected);
    });
  });

  document.querySelectorAll('.trans-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.trans-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      selectedTranslation = (btn as HTMLElement).dataset.trans!;
    });
  });

  async function handleDeclare() {
    const customText = (document.getElementById('customInput') as HTMLTextAreaElement).value.trim();
    const errorMsg = document.getElementById('errorMsg')!;

    if (selectedChips.length === 0 && !customText) {
      errorMsg.classList.add('visible');
      return;
    }
    errorMsg.classList.remove('visible');

    const struggleDesc = selectedChips.length > 0
      ? selectedChips.join(', ') + (customText ? '. Additional context: ' + customText : '')
      : customText;

    showLoading(true);
    (document.getElementById('declareBtn') as HTMLButtonElement).disabled = true;

    try {
      const aiResult = await callClaude(struggleDesc, selectedTranslation);
      currentResult = aiResult;
      renderResults(aiResult, struggleDesc, selectedTranslation);
    } catch (err) {
      console.error(err);
      showLoading(false);
      (document.getElementById('declareBtn') as HTMLButtonElement).disabled = false;
      const errorMsg = document.getElementById('errorMsg')!;
      const errorMessages = [
        'Heaven is working on this — hold tight.',
        "God's Word is on the way. Give us just a moment.",
        'Still searching the Word for you — hang on.',
        "The Word never fails. We're just a breath away.",
        'We hit a speed bump. Your breakthrough is still coming — try again.'
      ];
      errorMsg.textContent = errorMessages[Math.floor(Math.random() * errorMessages.length)];
      errorMsg.classList.add('visible');
      document.getElementById('connectionNote')!.classList.add('visible');
    }
  }

  async function callClaude(struggle: string, translation: string) {
    const systemPrompt = `You are HopeFinder Companion — the pastoral voice inside Declare and Believe, a faith-based app that delivers God's Word directly to someone's specific mindset struggle. You are not a chatbot, a therapist, or a preacher. You are a trusted friend who knows their Bible deeply and speaks with warmth, confidence, and pastoral authority. You walk with people in their darkest moments and speak truth before you speak comfort.

The person who has arrived has described something they are battling. A fear. A shame. A broken identity. A feeling of worthlessness. A sleepless night of doubt. Your job is to meet them exactly where they are and speak God's truth back to them.

This person came here carrying something real. They may have typed it out or selected it from a list, but either way they are sitting with something heavy right now. Your job is not to give them information. Your job is to speak God's Word directly into what they are carrying, give them declarations they can speak aloud with confidence, and send them back into their day knowing who they are in Christ. Make it personal. Make it real. Make it land.

RESPONSE FORMAT: Respond ONLY with valid JSON. No preamble, no markdown fences, no extra text.

VERSES: Return 3 to 5 verses that speak directly to this struggle. For each verse provide the reference AND the full accurate verse text in the ${translation} translation. The text field must NEVER be empty.

EXPLANATION: 2 to 3 paragraphs separated by \\n. Write in natural flowing sentences the way a pastor speaks to someone sitting across from them, not the way a writer crafts punchy lines for a page. Each paragraph should breathe and connect to the next. This is a conversation, not a list of insights. Address the exact struggle. Ground everything in identity in Christ. End on confidence and forward movement. DASH RULE: Use em dashes sparingly and only when a pause genuinely changes the weight of what follows. If a comma or a new sentence works just as well, use that instead. One or two dashes per paragraph is the ceiling. Zero is fine.

DECLARATIONS: 3 to 5 declarations. May begin with "I am", "I declare", or a God-statement construction (e.g. "God did not give me a spirit of fear — He gave me power, love, and a sound mind."). Present tense only. Specific to the struggle. Punchy, speakable, and memorable. Match this voice exactly:
- "I am not defined by my past. I am defined by my Creator."
- "I am not moved by what I see. I am moved by what God said."
- "God did not give me a spirit of fear — He gave me power, love, and a sound mind."
- "I am who God says I am — not what my circumstances say."
Never passive voice. Never hedging. Never future tense.

PRAYER: 3 to 5 sentences spoken directly to God in first person. Starts with "Father," or "Lord,". Ends with "In Jesus' name, Amen." Specific to the struggle. Should feel lifted from the weight they walked in carrying. Never generic.

CRISIS: If the struggle involves suicidal ideation or self-harm, lead with compassion, mention the 988 Suicide & Crisis Lifeline (call or text 988), then proceed with Scripture focused on God's presence in the darkest valley.

Tone brand voice examples:
- "I am fearless. Fear is not my portion."
- "I am the husband my wife prayed for."
- "I am covered by the blood of Jesus Christ."
- "I am filled with wisdom and I move with it."`;

    const userPrompt = `Struggle: ${struggle}
Translation: ${translation}

Return ONLY valid JSON in this exact structure:
{
  "verses": [
    { "ref": "Book Chapter:Verse", "text": "Full verse text in ${translation}" }
  ],
  "explanation": "paragraph 1\\n\\nparagraph 2\\n\\nparagraph 3",
  "declarations": ["declaration 1", "declaration 2", "declaration 3"],
  "prayer": "Full prayer text. In Jesus' name, Amen."
}`;

    const response = await fetch('https://hope-finder-worker.thinktoro.workers.dev', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-haiku-4-5-20251001',
        max_tokens: 1500,
        stream: true,
        system: [{ type: 'text', text: systemPrompt, cache_control: { type: 'ephemeral' } }],
        messages: [{ role: 'user', content: userPrompt }]
      })
    });

    if (!response.ok || !response.body) {
      throw new Error('API error: ' + response.status);
    }

    // Read the SSE stream and accumulate the text delta from Anthropic
    const reader = response.body.getReader();
    const decoder = new TextDecoder();
    let buffer = '';
    let fullText = '';

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;

      buffer += decoder.decode(value, { stream: true });
      const lines = buffer.split('\n');
      buffer = lines.pop() || '';

      for (const line of lines) {
        if (!line.startsWith('data: ')) continue;
        const dataStr = line.slice(6).trim();
        if (!dataStr || dataStr === '[DONE]') continue;

        try {
          const event = JSON.parse(dataStr);
          if (event.type === 'content_block_delta' && event.delta?.type === 'text_delta') {
            fullText += event.delta.text;
          }
        } catch {
          // ignore malformed lines
        }
      }
    }

    // Strip markdown fences, then extract the JSON object boundaries
    // (some models append safety/crisis text after the JSON closes — be defensive)
    const stripped = fullText.replace(/```json|```/g, '').trim();
    const firstBrace = stripped.indexOf('{');
    const lastBrace = stripped.lastIndexOf('}');
    const cleaned = (firstBrace !== -1 && lastBrace !== -1 && lastBrace > firstBrace)
      ? stripped.slice(firstBrace, lastBrace + 1)
      : stripped;
    try {
      return JSON.parse(cleaned);
    } catch (parseErr) {
      console.error('[callClaude] JSON.parse failed:', parseErr);
      console.error('[callClaude] cleaned string was:', cleaned);
      throw parseErr;
    }
  }

  function renderResults(data: any, struggle: string, translation: string) {
    showLoading(false);
    (document.getElementById('declareBtn') as HTMLButtonElement).disabled = false;

    const label = struggle.length > 60 ? struggle.substring(0, 57) + '…' : struggle;
    document.getElementById('resultsLabel')!.textContent = label.toUpperCase();
    document.getElementById('transLabel')!.textContent = translation;

    const versesBody = document.getElementById('versesBody')!;
    versesBody.innerHTML = data.verses.map((v: any) => `
      <div class="verse-item">
        <p class="verse-ref">${v.ref} — ${translation}</p>
        <p class="verse-text">${v.text}</p>
      </div>
    `).join('');

    const paras = data.explanation.split('\n').filter((p: string) => p.trim());
    document.getElementById('explanationBody')!.innerHTML = paras.map((p: string) =>
      `<p style="margin-bottom: 0.9rem;">${p}</p>`
    ).join('');

    const declBody = document.getElementById('declarationsBody')!;
    declBody.innerHTML = data.declarations.map((d: string, i: number) => `
      <div class="declaration-item">
        <div class="decl-bullet">${i + 1}</div>
        <p class="decl-text">${d}</p>
      </div>
    `).join('');

    document.getElementById('prayerBody')!.textContent = data.prayer;

    const resultsEl = document.getElementById('results')!;
    resultsEl.classList.add('visible');
    resultsEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function showLoading(show: boolean) {
    document.getElementById('loadingState')!.classList.toggle('visible', show);
    (document.getElementById('inputSection') as HTMLElement).style.opacity = show ? '0.5' : '1';
    document.getElementById('results')!.classList.remove('visible');
  }

  function resetForm() {
    document.querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
    selectedChips = [];
    (document.getElementById('customInput') as HTMLTextAreaElement).value = '';
    document.getElementById('results')!.classList.remove('visible');
    (document.getElementById('inputSection') as HTMLElement).style.opacity = '1';
    document.getElementById('errorMsg')!.classList.remove('visible');
    document.getElementById('connectionNote')!.classList.remove('visible');
    document.getElementById('crisisBanner')!.classList.remove('visible');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function buildCopyText() {
    if (!currentResult) return '';
    const lines = ['DECLARE & BELIEVE — God\'s Word For Your Struggle\n'];
    lines.push('— SCRIPTURE —');
    currentResult.verses.forEach((v: any) => lines.push(`${v.ref}\n"${v.text}"`));
    lines.push('\n— HOW TO OVERCOME THIS MINDSET —');
    lines.push(currentResult.explanation);
    lines.push('\n— DECLARATIONS (SPEAK THESE ALOUD) —');
    currentResult.declarations.forEach((d: string, i: number) => lines.push(`${i + 1}. ${d}`));
    lines.push('\n— YOUR PRAYER —');
    lines.push(currentResult.prayer);
    lines.push('\nTo God be the glory. Forever.');
    return lines.join('\n');
  }

  async function copyAll() {
    const text = buildCopyText();
    try {
      await navigator.clipboard.writeText(text);
      showToast('Copied to clipboard ✓');
    } catch {
      showToast('Copy failed — try saving instead');
    }
  }

  function saveAsText() {
    const text = buildCopyText();
    const blob = new Blob([text], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'declare-and-believe.txt';
    a.click();
    URL.revokeObjectURL(url);
    showToast('Saved ✓');
  }

  async function shareResult() {
    const text = buildCopyText();
    if (navigator.share) {
      try {
        await navigator.share({ title: 'Declare & Believe', text: text.substring(0, 500) + '...' });
      } catch {}
    } else {
      await copyAll();
      showToast('Link copied — paste to share');
    }
  }

  function showToast(msg: string) {
    const t = document.getElementById('toast')!;
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2800);
  }

  document.getElementById('declareBtn')!.addEventListener('click', handleDeclare);
  document.getElementById('copyBtn')!.addEventListener('click', copyAll);
  document.getElementById('shareBtn')!.addEventListener('click', shareResult);
  document.getElementById('saveBtn')!.addEventListener('click', saveAsText);
  document.getElementById('resetBtn')!.addEventListener('click', resetForm);
</script>
