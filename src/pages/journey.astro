      const t = window.TheVine.build(m, vineCfg()); t.setProgress(TOTAL, TOTAL);
      const sm = document.createElement('div'); sm.className = 'tree-mount'; $('scTree').innerHTML = ''; $('scTree').appendChild(sm);
