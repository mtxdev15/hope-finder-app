    $('dcTimes').addEventListener('click', function (e) { const b = e.target.closest('button[data-t]'); if (!b) return;
      $('dcTimes').querySelectorAll('button').forEach(function (x) { x.classList.remove('on'); }); b.classList.add('on');
      $('dcTimeInput').value = b.dataset.t; });
