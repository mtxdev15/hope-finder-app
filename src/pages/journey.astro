---
// v3.2 /journey — rebuilt from design-source-v3.2/declare/Journey.html.
// The Vine (John 15:5): one active 5-day journey out of a named struggle into
// a named identity. Surface is the design file verbatim; machinery injected:
// vault-store saves, the Worker-backed JourneyEngine (authored bank fallback),
// device-local pacing lock + active-journey persistence, DeclareShare stack.
import DeclareLayout from '../layouts/DeclareLayout.astro';
---
<DeclareLayout
  title="Declare — Journey"
  description="A free 5-day guided journey out of one struggle — daily Scripture, reflection, declarations, and prayer that walk you from fear to faith."
  activeTab="journey"
>
  <main class="journey">
    <div class="topglow" aria-hidden="true"></div>

    <div class="jin">
      <div class="jhead rise d1">
        <h1 data-i18n="journey.hTitle">Your Journey</h1>
        <div class="sub" data-i18n="journey.becoming">Who are you becoming?</div>
      </div>

      <div class="scroll" id="homeScroll">
        <!-- ===== ZERO STATE — no active journey (first-time / returning) ===== -->
        <section class="zerostate rise d2" id="zeroState" style="display:none">
          <div class="zs-rooted" id="zsRooted" style="display:none">
            <span class="zs-rooted-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9"/><path d="M3 4v5h5"/></svg></span>
            <span><span data-i18n="journey.rootedPre">You&rsquo;ve rooted </span><b id="zsRootedN">2 journeys</b><span data-i18n="journey.rootedPost">. Faithfulness is the win.</span></span>
          </div>
          <p class="zs-lead" id="zsLead"></p>
          <div class="zs-h" data-i18n="journey.chooseTransformation">Choose your transformation</div>
          <div class="zs-list" id="zsList"></div>
          <button class="seeall zs-seeall" id="zsSeeAll"><span data-i18n="journey.seeAllJourneys">See all journeys</span> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg></button>
        </section>

        <section class="jcard rise d2" id="activeCard" aria-label="Active journey">
          <div class="jc-top">
            <div>
              <div class="ey" data-i18n="journey.activeJourney">Active Journey</div>
              <div class="jc-shift"><span class="from" id="fromW">Shame</span><span class="to-row"><span class="arr" aria-hidden="true">&rarr;</span><span class="to" id="toW">Beloved Child</span></span></div>
              <div class="jc-habit" id="habitW"></div>
            </div>
            <span class="daypill" id="dayPill">Day 1 / 5</span>
          </div>

          <div class="vinewrap">
            <div class="tree-mount" id="vineMount"></div>
          </div>

          <div class="jc-foot">
            <div class="dots" id="dayDots"></div>
            <div class="remain" id="remainTxt">Just planted</div>
          </div>

          <div class="today">
            <div class="tt" id="todayTitle"></div>
            <div class="tref" id="todayRef"></div>
            <div class="focus" id="focusLine"></div>
            <div class="gen-tag"><span class="gd"></span><span data-i18n="journey.personalizing">Personalizing your path</span></div>
          </div>

          <div class="jc-actions">
            <button class="btn btn-primary btn-cont" id="continueBtn">Continue Day 1</button>
            <button class="btn btn-ghost btn-view" id="viewTreeBtn" data-i18n="journey.viewVine">View Vine</button>
          </div>

          <div class="lock-note" id="lockNote">
            <div class="ln-top">
              <span class="ln-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></span>
              <div>
                <div class="ln-t" id="lnTitle">Day 2 opens tomorrow</div>
                <div class="ln-sub" id="lnSub">Opens in 8h</div>
              </div>
            </div>
            <div class="ln-row">
              <span class="ln-rem" id="lnRem"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/></svg><span id="lnRemTxt">No reminder set</span></span>
              <button class="ln-edit" id="lnEdit">Set a reminder</button>
            </div>
            <div class="dc-time-custom" id="lnEditBox" style="display:none; margin-top:13px;">
              <input type="time" id="lnTimeInput" value="07:00" />
              <button class="btn btn-primary" id="lnTimeSave" style="flex:1; padding:9px;" data-i18n="journey.saveReminder">Save reminder</button>
            </div>
            <button class="ln-preview" id="lnPreview"><span data-i18n="journey.previewTomorrow">Preview tomorrow</span> &rarr;</button>
          </div>
        </section>

        <!-- Fruit log — a quiet record of grace -->
        <section class="fruitlog rise d3" id="fruitLog" style="display:none">
          <div class="fl-h" data-i18n="journey.fruitSoFar">Fruit so far</div>
          <div class="fl-list" id="fruitList"></div>
        </section>

        <div class="returnline rise d3">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9"/><path d="M3 4v5h5"/></svg>
          <span><span data-i18n="journey.returnedPre">You&rsquo;ve returned </span><b id="returnDays">1 day</b><span data-i18n="journey.returnedPost">. Faithfulness is the win.</span></span>
        </div>

        <button class="seeall" id="seeAll"><span class="lbl" data-i18n="journey.pastJourneys">Past journeys</span> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></button>

        <section class="allj rise d4" id="alljSection" style="display:none">
          <div class="h"><span class="t" data-i18n="journey.pastJourneys">Past journeys</span><span class="c"><span id="doneCount">0</span> rooted</span></div>
          <div class="jgrid" id="jgrid"></div>
        </section>
      </div>

      <!-- ===== DAY FLOW ===== -->
      <div class="dayflow" id="dayflow" aria-hidden="true">
        <div class="df-top">
          <button class="df-back" id="dfBack" aria-label="Back to journey"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6"/></svg></button>
          <div class="df-tt">
            <div class="ey" id="dfEy"></div>
            <div class="nm" id="dfNm"></div>
          </div>
          <div class="df-dots" id="dfDots"></div>
        </div>
        <div class="df-scroll" id="dfScroll"><!-- blocks injected --></div>
        <div class="df-foot" id="dfFoot">
          <div class="lockhint" id="dfLock"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg><span data-i18n="journey.declareAloudFinish">Declare it aloud to finish the day</span></div>
          <button class="btn btn-primary" id="dfComplete" disabled>Complete Day 1</button>
        </div>
      </div>

      <!-- ===== VINE VIEWER ===== -->
      <div class="ov viewer" id="viewer" aria-hidden="true">
        <div class="ov-glow"></div>
        <button class="close" id="viewerClose" aria-label="Close"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg></button>
        <div class="ov-in">
          <div class="vlabels"><span class="vl" data-i18n="journey.vineJohn">The Vine &middot; John 15:5</span></div>
          <div class="viewer-tree" id="viewerTree"></div>
          <p class="alt" id="viewerAlt"></p>
        </div>
      </div>

      <!-- ===== DAY COMPLETE ===== -->
      <div class="ov" id="dayComplete" aria-hidden="true">
        <div class="ov-glow"></div>
        <div class="ov-in">
          <div class="dc-tree" id="dcTree"></div>
          <h2 class="dc-aff" id="dcAff"></h2>
          <p class="dc-sub" id="dcSub"></p>
          <div class="dc-next" id="dcNext">
            <div class="dc-next-t"><span data-i18n="journey.dayWord">Day </span><span id="dcNextDay">2</span><span data-i18n="journey.opensTomorrowSuffix"> opens tomorrow</span></div>
            <div class="dc-next-s" data-i18n="journey.takeRootOvernight">Let today&rsquo;s truth take root overnight. Freedom grows one day at a time, not all at once.</div>
          </div>
          <div class="dc-remind" id="dcRemind">
            <button class="dc-remind-toggle" id="dcRemindToggle">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>
              <span class="lbl" data-i18n="journey.remindTomorrow">Remind me tomorrow</span>
              <span class="dc-remind-state" id="dcRemindState"></span>
              <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="dc-remind-body" id="dcRemindBody">
              <div class="dc-times" id="dcTimes">
                <button data-t="07:00" class="on" data-i18n="journey.time7">7:00 AM</button>
                <button data-t="12:00" data-i18n="journey.time12">12:00 PM</button>
                <button data-t="20:00" data-i18n="journey.time20">8:00 PM</button>
              </div>
              <div class="dc-time-custom">
                <label for="dcTimeInput" data-i18n="journey.orPickTime">Or pick a time</label>
                <input type="time" id="dcTimeInput" value="07:00" />
              </div>
              <button class="btn btn-primary dc-remind-set" id="dcRemindSet" data-i18n="journey.setReminderBtn">Set reminder</button>
            </div>
          </div>
          <div class="dc-save" id="dcSave" style="display:none">
            <div class="dc-save-h" data-i18n="journey.saveProgressH">Save your progress</div>
            <div class="dc-save-s" data-i18n="journey.saveProgressS">Create a free account so tomorrow is waiting for you &mdash; your fruit and your verses, all kept safe.</div>
            <button class="btn btn-primary" id="dcSaveBtn" data-i18n="journey.saveProgressBtn">Create free account</button>
            <button class="dc-save-later" id="dcSaveLater" data-i18n="journey.saveProgressLater">Maybe later</button>
          </div>
          <div class="dc-actions">
            <button class="btn btn-primary" id="dcDone">Done for today</button>
          </div>
        </div>
      </div>

      <!-- ===== JOURNEY COMPLETE ===== -->
      <div class="ov" id="journeyComplete" aria-hidden="true">
        <div class="ov-glow"></div>
        <div class="ov-in">
          <div class="jc-mark" id="jcTree"></div>
          <div class="jc-reveal">
            <span class="jc-from" id="jcFrom"></span>
            <span class="jc-arrow" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M6 13l6 6 6-6"/></svg></span>
            <span class="jc-to" id="jcTo"></span>
          </div>
          <p class="jc-bene" id="jcBene"></p>

          <div class="sharecard" id="shareCard">
            <div class="sc-wm"><span class="d"></span><span>Declare &amp; Believe</span></div>
            <div class="sc-body">
              <div class="sc-tree" id="scTree"></div>
              <div class="sc-shift" id="scShift"></div>
              <div class="sc-dec" id="scDec"></div>
            </div>
            <div class="sc-ref" id="scRef"></div>
          </div>

          <div class="jc-actions2">
            <button class="btn btn-share" id="jcShare"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v7a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-7"/><path d="M12 3v13M7 8l5-5 5 5"/></svg><span data-i18n="journey.shareDeclaration">Share this declaration</span></button>
            <button class="btn btn-primary" id="jcNew" data-i18n="journey.beginNewJourney">Begin a new journey</button>
            <button class="btn btn-ghost" id="jcSave">Save to Vault</button>
          </div>

          <div class="dr-jprompt" data-dr-prompt data-dr-source="journey-complete">
            <div class="jp-h" data-i18n="journey.testimonyQ">How has Declare met you?</div>
            <div class="jp-s" data-i18n="journey.testimonyS">Your testimony helps someone else begin.</div>
            <div data-dr-stars></div>
          </div>
        </div>
      </div>

      <div class="toast" id="toast"></div>

      <!-- sheets -->
      <div class="sheet" id="menuSheet" aria-hidden="true">
        <div class="grabber"></div>
        <div class="menu-list">
          <button id="mSaved"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4.5h12v15l-6-4-6 4z"/></svg><span data-i18n="journey.saveVersesToVault">Save this journey&rsquo;s verses to Vault</span></button>
          <button id="mSwitch" class="danger"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 1 3 6.7"/><path d="M3 19v-5h5"/></svg><span data-i18n="journey.chooseDifferentStruggle">Choose a different struggle</span></button>
        </div>
      </div>
      <div class="sheet" id="resetSheet" aria-hidden="true">
        <div class="grabber"></div>
        <h3 data-i18n="journey.beginDifferentQ">Begin a different journey?</h3>
        <p><span data-i18n="journey.partwayPre">You&rsquo;re partway through </span><b id="resetShift"></b><span data-i18n="journey.partwayPost"> Only one journey grows at a time. Starting a new one sets this vine aside &mdash; your progress is kept, and you can return to it whenever you&rsquo;re ready.</span></p>
        <div class="sactions">
          <button class="btn btn-primary" id="resetGo" data-i18n="journey.chooseNewStruggle">Choose a new struggle</button>
          <button class="btn btn-ghost" id="resetKeep" data-i18n="journey.stayWithThis">Stay with this one</button>
        </div>
      </div>
      <!-- choose-struggle sheet -->
      <div class="sheet" id="chooseSheet" aria-hidden="true">
        <div class="grabber"></div>
        <h3 data-i18n="journey.whatLayDown">What are you ready to lay down?</h3>
        <p data-i18n="journey.nameFalseIdentity">Name the false identity &mdash; the weight you&rsquo;ve been holding on to. We&rsquo;ll plant a fresh vine and walk it out with you for five days.</p>
        <div class="menu-list" id="chooseList"></div>
      </div>

      <!-- share fallback sheet -->
      <div class="sheet" id="shareSheet" aria-hidden="true">
        <div class="grabber"></div>
        <h3 data-i18n="journey.shareYourDeclaration">Share your declaration</h3>
        <p data-i18n="journey.shareSendKeep">Send it to someone who needs it, or keep it where you&rsquo;ll see it.</p>
        <textarea id="shareText" class="share-text" readonly></textarea>
        <div class="sactions">
          <button class="btn btn-primary" id="shareCopy" data-i18n="journey.copyDeclaration">Copy declaration</button>
          <button class="btn btn-ghost" id="shareClose" data-i18n="journey.done">Done</button>
        </div>
      </div>

      <!-- care gate (sensitive journeys) -->
      <div class="sheet care-sheet" id="careSheet" aria-hidden="true">
        <div class="grabber"></div>
        <div class="care-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20s-7-4.6-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 10c0 5.4-7 10-7 10z"/></svg></div>
        <h3 id="careTitle" data-i18n="journey.beforeWeBegin">Before we begin</h3>
        <p id="careBody"></p>
        <div class="sactions">
          <a class="btn btn-ghost care-talk" id="careTalk" href="/crisis" data-i18n="journey.talkToSomeone">Talk to someone now</a>
          <button class="btn btn-primary" id="careBegin" data-i18n="journey.readyBeginGently">I&rsquo;m ready &mdash; begin gently</button>
        </div>
      </div>

      <div class="scrim" id="scrim"></div>
    </div>

  {/* SEO: crawlable summary for engines and AI answer bots (page is JS-rendered). */}
  <noscript>
    <section>
      <h2>A 5-day walk out of the struggle you name</h2>
      <p>The Journey is a free 5-day guided path out of one struggle — anxiety, shame, anger, grief, or any battle you name. Each day brings Scripture, an honest reflection, declarations to speak aloud, and a prayer, one step at a time, rooted in Romans 12:2 mind renewal.</p>
      <p>Start by naming your struggle on <a href="/today/">Today</a>, or read <a href="/struggles">Scripture for every struggle</a>. The Journey requires JavaScript.</p>
    </section>
  </noscript>
  </main>

  <link rel="stylesheet" href="/declare/rate.css" media="print" onload="this.media='all'" /><noscript><link rel="stylesheet" href="/declare/rate.css" /></noscript>
  <script is:inline src="/declare/the-vine.js?v=3.16.6" defer></script>
  <script is:inline src="/declare/journey-data.js?v=3.16.6" defer></script>
  <script is:inline src="/declare/journey-engine.js?v=3.16.6" defer></script>
  <script is:inline src="/declare/i18n-journey-es.js?v=3.16.2" defer></script>
  <script is:inline src="/declare/breath-ring.js" defer></script>
  <script is:inline src="/declare/rate.js" defer></script>

  <script>
    /* /journey runtime — the design's flow with V1 machinery injected.
       Persistence is device-local: 'db_active_journey' (which vine is growing),
       'db_journey_lock' (one day per calendar day + reminder time),
       'db_journeys_done' (rooted journeys — keeps the grid honest). */
    import { saveItem } from '../app/declare/vault-store.js';
    import { initAuth, isSignedIn } from '../app/declare/auth-store.js';
    import { ensureSignedIn } from '../app/declare/auth-gate.js';
    import { openAuthModal } from '../app/declare/auth-modal.js';
    import { registerSyncKey, mirror, whenSynced } from '../app/declare/account-sync.js';
    import { mergeActiveJourney, mergeDoneList, mergeLockMap } from '../app/declare/journey-merge.js';
    // journey progress follows the account when signed in — with merge policies,
    // so signing in/up can never pull stale account state over local progress
    registerSyncKey('db_active_journey', mergeActiveJourney);
    registerSyncKey('db_journeys_done', mergeDoneList);
    registerSyncKey('db_journey_lock', mergeLockMap);
    initAuth(); // resolve any saved session before the user reaches a gate

    const $ = (id) => document.getElementById(id);
    const TOTAL = window.JourneyData.TOTAL;
    const CATALOG = window.JourneyData.CATALOG;
    const ICONS = window.JourneyData.ICONS;
    const JOURNEY_CONTENT = window.JourneyData.CONTENT;

    /* ---- mast: the design's journey-options (⋯) button, injected into the
       shared layout mast so the page surface matches Journey.html ---- */
    (function () {
      const mast = document.querySelector('body > .mast');
      if (!mast || mast.querySelector('.mright')) return;
      const right = document.createElement('div');
      right.className = 'mright';
      const btn = document.createElement('button');
      btn.className = 'iconbtn'; btn.id = 'overflowBtn'; btn.setAttribute('aria-label', 'Journey options');
      btn.innerHTML = '<svg viewBox="0 0 24 24" fill="currentColor"><circle cx="5" cy="12" r="1.8"/><circle cx="12" cy="12" r="1.8"/><circle cx="19" cy="12" r="1.8"/></svg>';
      right.appendChild(btn);
      const av = mast.querySelector('.avatar');
      if (av) right.appendChild(av);
      mast.appendChild(right);
    })();

    // ---- runtime state ----
    let active = CATALOG[0];
    // ---- Spanish display layer (declare-lang cookie). Ids/keys stay English; only
    // what the eye sees is swapped. Day content itself comes from the AI in Spanish. ----
    var JES = window.__I18N_JOURNEY_ES || {};
    function esL() { return !!(window.I18N && window.I18N.lang && window.I18N.lang() === 'es'); }
    function curLang() { try { return (window.I18N && window.I18N.lang && window.I18N.lang()) || 'en'; } catch (e) { return 'en'; } }
    function cFrom(c) { c = c || active; var e = esL() && JES[c.id]; return e ? e.from : c.from; }
    function cTo(c) { c = c || active; var e = esL() && JES[c.id]; return e ? e.to : c.to; }
    function cLine(c) { c = c || active; var e = esL() && JES[c.id]; return e ? e.line : c.line; }
    function tj(k, fb) { return (window.I18N && window.I18N.t) ? window.I18N.t(k, fb) : fb; }
    let PLAN;
    const state = { day: 1, returned: 1 };
    // Curated first-run shortlist — broad, resonant, none crisis-gated.
    const CURATED = ['anxiety', 'shame', 'loneliness', 'doubt', 'burnout'];

    function clone(o) { return JSON.parse(JSON.stringify(o)); }
    // A fresh journey instance: clone the authored bank (always-valid fallback),
    // give it a new seed + theme arc, and clear the AI-upgrade cache. The Worker
    // then rewrites each day on demand so no two journeys are ever the same.
    function startPlan() {
      active._seed = (Date.now() ^ Math.floor(Math.random() * 1e9)) >>> 0;
      active._themes = window.JourneyEngine ? window.JourneyEngine.arc(active.id, active._seed) : null;
      active._ai = {}; active._inflight = {};
      const bespoke = JOURNEY_CONTENT[active.id];
      const composed = (!bespoke && window.JourneyEngine && window.JourneyEngine.fallbackPlan)
        ? window.JourneyEngine.fallbackPlan({ struggleId: active.id, fromLabel: active.from, toLabel: active.to, seed: active._seed })
        : null;
      PLAN = clone(bespoke || composed || JOURNEY_CONTENT.shame);
    }
    // Ensure day n has freshly generated content (else keep the fallback already
    // in PLAN). One attempt per day per journey — a failed/slow Worker call keeps
    // the authored day and never retries in a loop.
    function ensureDay(n) {
      const idx = n - 1;
      if (!PLAN || !PLAN[idx]) return Promise.resolve(null);
      if (active._ai[idx]) return Promise.resolve(PLAN[idx]);
      if (active._inflight[idx]) return active._inflight[idx];
      if (!window.JourneyEngine) { return Promise.resolve(PLAN[idx]); }
      const theme = (active._themes && active._themes[idx]) || '';
      const p = window.JourneyEngine.generateDay({ struggleId: active.id, dayIndex: idx, theme: theme,
        seed: (active._seed + idx * 101) >>> 0, fromLabel: cFrom(), toLabel: cTo(),
        language: (window.I18N && window.I18N.lang && window.I18N.lang()) || 'en' })
        .then(function (obj) { if (obj) { PLAN[idx] = obj; } active._ai[idx] = true; active._inflight[idx] = null; saveInstance(); return PLAN[idx]; })
        .catch(function () { active._ai[idx] = true; active._inflight[idx] = null; return PLAN[idx]; });
      active._inflight[idx] = p; return p;
    }

    function completed() { return state.day - 1; }

    // ---- pacing lock: one day per calendar day, persisted ----
    function todayStr() { const d = new Date(); return d.getFullYear() + '-' + (d.getMonth() + 1) + '-' + d.getDate(); }
    function loadLock() { try { return JSON.parse(localStorage.getItem('db_journey_lock') || '{}'); } catch (e) { return {}; } }
    function saveLock(m) { try { localStorage.setItem('db_journey_lock', JSON.stringify(m)); } catch (e) {} mirror('db_journey_lock'); }
    function lockFor() { return loadLock()[active.id] || null; }
    function setLock(time) { const m = loadLock(); const prev = m[active.id] || {}; m[active.id] = { date: todayStr(), time: (time !== undefined ? time : prev.time) || null, day: state.day, returned: state.returned }; saveLock(m); saveActive(); saveInstance(); }
    function clearLock() { const m = loadLock(); delete m[active.id]; saveLock(m); }
    function restoreProgress() { const l = lockFor(); if (l && l.day) { state.day = l.day; state.returned = l.returned || state.returned; } }

    // ---- which journey is genuinely active, persisted across reloads ----
    const ACT_KEY = 'db_active_journey';
    function saveActive() { try { if (active && active.status === 'active') { localStorage.setItem(ACT_KEY, JSON.stringify({ id: active.id, day: state.day, returned: state.returned, ts: Date.now() })); } } catch (e) {} mirror(ACT_KEY); }
    function loadActiveSaved() { try { const r = localStorage.getItem(ACT_KEY); return r ? JSON.parse(r) : null; } catch (e) { return null; } }
    function clearActiveSaved() { try { localStorage.setItem(ACT_KEY, 'null'); } catch (e) {} mirror(ACT_KEY); }
    // Per-journey instance cache (device-local): the AI-generated content + in-day progress.
    // Without this, leaving /journey (e.g. to read a verse) and returning re-clones the template
    // and regenerates a fresh day — a NEW verse — losing the user's place. Restoring it on return
    // resumes exactly: same verse, same step progress. Kept local (not mirrored) to avoid bloat.
    function instKey() { return 'db_journey_inst:' + (active && active.id); }
    function saveInstance() {
      try {
        if (!active || active.status !== 'active' || !PLAN) return;
        localStorage.setItem(instKey(), JSON.stringify({ seed: active._seed, themes: active._themes, ai: active._ai, plan: PLAN, dayState: dayState, daySpoken: daySpoken, lang: curLang() }));
      } catch (e) {}
    }
    function restoreInstance() {
      try {
        const raw = localStorage.getItem(instKey()); if (!raw) return false;
        const o = JSON.parse(raw); if (!o || !o.plan) return false;
        PLAN = o.plan; active._seed = o.seed; active._themes = o.themes;
        active._ai = (o.lang && o.lang !== curLang()) ? {} : (o.ai || {}); active._inflight = {};
        dayState = o.dayState || {}; daySpoken = o.daySpoken || {};
        return true;
      } catch (e) { return false; }
    }
    function clearInstance() { try { localStorage.removeItem(instKey()); } catch (e) {} }
    function setReminderOnly(time) { const m = loadLock(); const prev = m[active.id] || { date: todayStr() }; prev.time = time; m[active.id] = prev; saveLock(m); }
    function previewTomorrow() { const m = loadLock(); if (m[active.id]) { m[active.id].date = '2000-01-01'; saveLock(m); } }
    function isLocked() { const l = lockFor(); return !!(l && l.date === todayStr() && state.day <= TOTAL); }
    function fmtTime(t) { if (!t) return ''; const p = t.split(':'); let h = parseInt(p[0], 10); const m = p[1] || '00'; const ap = h < 12 ? (esL() ? 'a. m.' : 'AM') : (esL() ? 'p. m.' : 'PM'); let h12 = h % 12; if (h12 === 0) h12 = 12; return h12 + ':' + m + ' ' + ap; }
    function untilTomorrow() { const now = new Date(); const mid = new Date(now.getFullYear(), now.getMonth(), now.getDate() + 1, 0, 0, 0); const ms = mid - now; const h = Math.floor(ms / 3600000); const m = Math.floor((ms % 3600000) / 60000); return h > 0 ? (h + 'h ' + m + 'm') : (m + 'm'); }

    // ---- rooted (completed) journeys, persisted — keeps the grid honest ----
    const DONE_KEY = 'db_journeys_done';
    function loadDone() { try { const a = JSON.parse(localStorage.getItem(DONE_KEY) || '[]'); return Array.isArray(a) ? a : []; } catch (e) { return []; } }
    function markDone(id) { const a = loadDone(); if (a.indexOf(id) < 0) { a.push(id); try { localStorage.setItem(DONE_KEY, JSON.stringify(a)); } catch (e) {} mirror(DONE_KEY); } }

    // ---- the Vine ----
    function fruitNames() { return PLAN.map(function (d) { return d.fruit; }); }
    function fruitTruths() { return PLAN.map(function (d) { return d.fruitTruth; }); }
    function vineCfg(extra) { const c = { total: TOTAL, falseLabel: cFrom(), trueLabel: cTo(), fruitNames: fruitNames(), fruitTruths: fruitTruths() }; if (extra) { for (const k in extra) c[k] = extra[k]; } return c; }
    let vine;
    function buildVine() {
      vine = window.TheVine.build($('vineMount'), vineCfg());
      vine.setProgress(completed(), TOTAL);
    }

    // ---- render home ----
    function renderHome() {
      $('fromW').textContent = cFrom(); $('toW').textContent = cTo();
      $('habitW').textContent = cLine();
      $('dayPill').textContent = (esL() ? 'Día ' : 'Day ') + state.day + ' / ' + TOTAL;
      const n = completed(); $('remainTxt').textContent = n > 0 ? (n + (esL() ? (n === 1 ? ' fruto hasta ahora' : ' frutos hasta ahora') : ' fruit so far')) : (esL() ? 'Recién plantado' : 'Just planted');
      let dots = ''; for (let i = 1; i <= TOTAL; i++) { const cl = (i < state.day ? 'done' : (i === state.day ? 'cur' : '')); dots += '<i class="' + cl + (i < state.day ? ' tap' : '') + '" data-day="' + i + '"' + (i < state.day ? ' role="button" tabindex="0" aria-label="Revisit day ' + i + '"' : '') + '></i>'; } $('dayDots').innerHTML = dots;
      const d = PLAN[state.day - 1];
      $('todayTitle').textContent = d.title;
      $('todayRef').innerHTML = d.ref + ' &middot; ' + d.ver;
      $('focusLine').textContent = d.fruitTruth || d.title;
      const locked = isLocked();
      const cb = $('continueBtn');
      if (locked) {
        cb.disabled = true; cb.classList.add('locked');
        cb.textContent = (esL() ? 'Día ' : 'Day ') + state.day + (esL() ? ' abre mañana' : ' opens tomorrow');
