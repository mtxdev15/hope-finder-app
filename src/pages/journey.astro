      for (let i = 1; i <= n; i++) { const d = PLAN[i - 1];
        html += '<button class="fl-item" data-day="' + i + '" aria-label="' + (esL() ? 'Revisitar día ' : 'Revisit day ') + i + ', ' + d.fruit + '"><span class="fl-bud" aria-hidden="true"></span><div class="fl-meta"><div class="nm">' + d.fruit + '</div><div class="dy">' + (esL() ? 'Día ' : 'Day ') + i + ' &middot; ' + d.fruitTruth + '</div></div><span class="fl-go" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg></span></button>';
      }
