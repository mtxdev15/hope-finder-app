      const todayEl = document.querySelector('.today');
      const generating = window.JourneyEngine && !active._ai[state.day - 1];
      if (todayEl) todayEl.classList.toggle('gen', !!generating);
      if (generating) { ensureDay(state.day).then(function () { if (document.querySelector('.jcard') && active.status === 'active') { renderHome(); } }); }
    }

    function renderFruitLog() {
