    // ---- begin a journey (shared by zero-state cards, See-all, and the switch flow) ----
    function beginJourney(id, openDay, silent) {
      const c = CATALOG.find(function (x) { return x.id === id; }); if (!c) return;
      CATALOG.forEach(function (x) { if (x.status === 'active') x.status = 'open'; }); // set the old one aside
      active = c; active.status = 'active'; startPlan();
      state.day = 1; state.returned = 0; daySpoken = {}; dayState = {}; clearLock(); clearInstance(); saveActive();
      closeSheets(); showActiveUI();
      if (!silent) toast((esL() ? 'Una vid nueva ha sido plantada — ' : 'A fresh vine is planted — ') + cFrom(c) + ' → ' + cTo(c));
      if (openDay) openAfterBegin();
    }
    function openAfterBegin() {
      if (isSensitive(active.id)) { setTimeout(function () { openCareGate(active.id, openDayFlow); }, 420); }
      else { setTimeout(openDayFlow, 380); }
    }
    // Tapping a transformation literally plants it: a seed flies from the card
    // into the new vine, the soil blooms, the sapling pulses, then Day 1 opens.
    function plantAndBegin(cardEl) {
      const id = cardEl.dataset.id;
      const reduce = window.matchMedia && matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce) { beginJourney(id, true); return; }
      const screen = document.querySelector('.journey');
      const icon = cardEl.querySelector('.zs-ic') || cardEl;
      const r0 = icon.getBoundingClientRect();
      beginJourney(id, false, true);          // render the living home (vine as a seed); hold the day flow
      window.scrollTo(0, 0);
      const sr = screen.getBoundingClientRect();
      const vm = $('vineMount') || $('activeCard');
      const rt = vm.getBoundingClientRect();
      const startX = r0.left + r0.width / 2 - sr.left, startY = r0.top + r0.height / 2 - sr.top;
      const endX = rt.left + rt.width / 2 - sr.left, endY = rt.top + rt.height * 0.66 - sr.top;
      const dx = endX - startX, dy = endY - startY;
      const seed = document.createElement('div'); seed.className = 'plant-seed';
      seed.style.left = startX + 'px'; seed.style.top = startY + 'px'; screen.appendChild(seed);
      const fly = seed.animate([
        { transform: 'translate(-50%,-50%) scale(1)', opacity: 1, offset: 0 },
        { transform: 'translate(' + (dx * 0.55) + 'px,' + (dy * 0.55 - 46) + 'px) scale(.72)', opacity: 1, offset: .55 },
        { transform: 'translate(' + dx + 'px,' + dy + 'px) scale(.32)', opacity: 1, offset: 1 }
      ], { duration: 760, easing: 'cubic-bezier(.45,0,.25,1)', fill: 'forwards' });
      fly.onfinish = function () {
        const bloom = document.createElement('div'); bloom.className = 'plant-bloom';
        bloom.style.left = endX + 'px'; bloom.style.top = endY + 'px'; screen.appendChild(bloom);
        bloom.animate([
          { transform: 'translate(-50%,-50%) scale(.2)', opacity: 0 },
          { transform: 'translate(-50%,-50%) scale(1)', opacity: .85, offset: .4 },
          { transform: 'translate(-50%,-50%) scale(2.1)', opacity: 0 }
        ], { duration: 680, easing: 'cubic-bezier(.3,0,.2,1)', fill: 'forwards' }).onfinish = function () { bloom.remove(); };
        seed.animate([{ opacity: 1 }, { opacity: 0 }], { duration: 240, fill: 'forwards' }).onfinish = function () { seed.remove(); };
        if (vm) { try { vm.animate([{ transform: 'scale(.92)' }, { transform: 'scale(1.05)' }, { transform: 'scale(1)' }], { duration: 720, easing: 'cubic-bezier(.34,1.4,.5,1)' }); } catch (e) {} }
        setTimeout(openAfterBegin, 360);
      };
    }

    // ---- home mode: the active-journey card vs. the zero state ----
