---
// /journey — placeholder until the Journey chapter ships. The tab bar and the
// results "Start a 5-Day Journey" card both lead here, so this page exists to
// keep every button honest (no 404s). Visuals use the design system; copy is the
// design's own Journey language ("Be transplanted", the Vine, five days).
// Replaced wholesale by the real Journey build (design: Journey.html).
import DeclareLayout from '../layouts/DeclareLayout.astro';
---
<DeclareLayout
  title="Declare — Journey"
  description="Five days with one truth — rooted until it grows real. Coming soon."
  activeTab="journey"
>
  <main class="journeyp">
    <div class="topglow" aria-hidden="true"></div>
    <div class="jin">
      <div class="jtag rise d1">Be transplanted</div>
      <h1 class="rise d2">The Journey is<br />being prepared.</h1>
      <p class="jlead rise d3">Five days with one truth &mdash; a verse, a declaration, and a prayer each morning &mdash; until what God spoke over you takes root and grows real.</p>
      <div class="jverse rise d4">&ldquo;Blessed is the man who trusts in the Lord&hellip; he shall be like a tree planted by the waters.&rdquo;</div>
      <div class="jref rise d4">Jeremiah 17:7&ndash;8</div>
      <a class="btn btn-primary rise d5" href="/today">Receive a word for today
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:17px;height:17px;margin-left:7px;vertical-align:-3px"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
      </a>
      <div class="jnote rise d6">This part of Declare is still being built.</div>
    </div>
  </main>

  <style is:global>
    .journeyp { position: relative; min-height: 100dvh; }
    .journeyp .jin { position: relative; z-index: 1; min-height: calc(100dvh - 96px); max-width: 640px; margin: 0 auto;
      padding: 0 28px 120px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; }
    .journeyp .jtag { font-size: 10px; letter-spacing: .24em; text-transform: uppercase; color: var(--goldd); font-weight: 700; }
    .journeyp h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(34px, 8.6vw, 46px); font-weight: 600; color: var(--text); line-height: 1.08; margin-top: 14px; text-shadow: 0 0 50px rgba(222, 190, 100, .26); }
    .journeyp .jlead { font-size: 14.5px; line-height: 1.62; color: var(--text2); margin-top: 16px; max-width: 42ch; }
    .journeyp .jverse { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 18px; line-height: 1.5; color: var(--soft); margin-top: 28px; max-width: 38ch; }
    .journeyp .jref { font-size: 10.5px; letter-spacing: .18em; text-transform: uppercase; color: var(--goldd); font-weight: 500; margin-top: 9px; }
    .journeyp .btn { margin-top: 30px; min-width: 230px; }
    .journeyp .jnote { font-size: 12px; color: var(--muted); margin-top: 22px; }
    @media (min-width: 481px) {
      .journeyp .jin { min-height: 100dvh; padding-top: 60px; }
    }
  </style>
</DeclareLayout>
