    }

    function renderLockNote() {
      const note = $('lockNote'); note.style.display = 'block';
      $('lnTitle').textContent = (esL() ? 'Día ' : 'Day ') + state.day + (esL() ? ' abre mañana' : ' opens tomorrow');
      $('lnSub').textContent = (esL() ? 'Abre en ' : 'Opens in ') + untilTomorrow();
      const l = lockFor();
      if (l && l.time) { $('lnRemTxt').textContent = (esL() ? 'Recordatorio a las ' : 'Reminder set for ') + fmtTime(l.time); $('lnEdit').textContent = esL() ? 'Cambiar' : 'Change'; $('lnTimeInput').value = l.time; }
      else { $('lnRemTxt').textContent = esL() ? 'Sin recordatorio' : 'No reminder set'; $('lnEdit').textContent = esL() ? 'Poner un recordatorio' : 'Set a reminder'; }
      $('lnEditBox').style.display = 'none';
    }
    $('lnEdit').addEventListener('click', function () { const b = $('lnEditBox'); b.style.display = b.style.display === 'none' ? 'flex' : 'none'; });
    $('lnTimeSave').addEventListener('click', function () { const t = $('lnTimeInput').value || '07:00'; setReminderOnly(t); renderLockNote(); toast((esL() ? 'Recordatorio a las ' : 'Reminder set for ') + fmtTime(t)); });
    $('lnPreview').addEventListener('click', function () { previewTomorrow(); renderHome(); toast(esL() ? ('Mañana ha llegado — el Día ' + state.day + ' está abierto') : ('Tomorrow has come — Day ' + state.day + ' is open')); });

    function renderGrid() {
      const box = $('jgrid');
      const done = CATALOG.filter(function (c) { return c.status === 'done'; });
      if (!done.length) {
        box.innerHTML = '<div class="jgrid-empty">' + (esL() ? 'Aún no hay caminos arraigados. Termina este y quedará guardado aquí.' : 'No rooted journeys yet. Finish this one and it will be kept here.') + '</div>';
        return;
      }
      box.innerHTML = done.map(function (c) {
        return '<div class="cell done" data-id="' + c.id + '">'
          + '<span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">' + ICONS[c.icon] + '</svg></span>'
          + '<span class="st done"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M8.5 12.5l2.5 2.5 4.5-5"/></svg>' + (esL() ? 'Arraigado' : 'Rooted') + '</span>'
          + '<div class="nm">' + cFrom(c) + ' <span class="a2">&rarr; ' + cTo(c) + '</span></div>'
          + '</div>';
      }).join('');
      box.querySelectorAll('.cell').forEach(function (cell) {
        cell.addEventListener('click', function () {
          const id = cell.dataset.id, c = CATALOG.find(function (x) { return x.id === id; });
          if (c) { toast(cFrom(c) + ' → ' + cTo(c) + (esL() ? ' — arraigado' : ' — rooted')); }
        });
      });
    }

    // ---- day flow ----
    let daySpoken = {};   // {day: true} once declared aloud
    let dayState = {};    // per-day: {cast:bool, repented:bool|'skipped', spoke:bool, acted:bool}
    let breathInst = null;
    let reviewDay = null; // when set, the day flow shows a completed day read-only
    function curDay() { return reviewDay || state.day; }
    function dstate() { const k = curDay(); if (!dayState[k]) dayState[k] = { cast: false, spoke: false, acted: false }; return dayState[k]; }

    // Build a Word-reader deep link from a day's scripture reference (e.g. "Philippians 4:6-7").
    const READ_ALIASES = { 'Psalm': 'Psalms', 'Song of Songs': 'Song of Solomon', 'Revelations': 'Revelation' };
    function dayVerseLink(ref) {
      const m = (ref || '').match(/^(.*?)\s+(\d+)\s*:\s*(\d+)/);
      if (!m) return '/word';
      const book = READ_ALIASES[m[1].trim()] || m[1].trim();
      return '/word?book=' + encodeURIComponent(book) + '&chapter=' + m[2] + '&verse=' + m[3];
    }
    function renderDayFlow() {
      clearInterval(renderDayLoading._t);
      const fd = curDay(), reviewing = !!reviewDay;
      const d = PLAN[fd - 1], ds = dstate();
      if (reviewing) { ds.cast = true; ds.repented = ds.repented || true; ds.spoke = true; ds.acted = true; }
      $('dayflow').classList.toggle('reviewing', reviewing);
      $('dfEy').innerHTML = (reviewing ? (esL() ? 'Repasando &middot; ' : 'Reviewing &middot; ') : '') + (esL() ? 'Día ' : 'Day ') + fd + (esL() ? ' de ' : ' of ') + TOTAL + ' &middot; ' + cFrom() + ' &rarr; ' + cTo();
      $('dfNm').textContent = d.title;
      let dots = ''; for (let i = 1; i <= TOTAL; i++) { dots += '<i class="' + (i < state.day ? 'done' : (i === state.day ? 'cur' : '')) + (i === fd && reviewing ? ' viewing' : '') + '"></i>'; } $('dfDots').innerHTML = dots;
      $('dfComplete').textContent = reviewing ? (esL() ? 'Volver a hoy' : 'Back to today') : ((esL() ? 'Completar Día ' : 'Complete Day ') + fd);

      const welcome = (fd === 1 && !reviewing) ? (
        '<div class="day1note">'
        + '<span class="d1ic"><svg viewBox="0 0 24 24" fill="none" stroke="#D8B85F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20v-7"/><path d="M12 13c-3.3 0-5.5-2-5.5-5C9.8 8 12 10 12 13z"/><path d="M12 11c0-2.6 2.1-4.5 5-4.5C17 9.2 14.7 11 12 11z"/><path d="M6 20h12"/></svg></span>'
        + '<div class="d1t">' + (esL() ? '<b>Día 1 de 5.</b> Cada día Dios da una manera nueva de ser libre. Recibirás su Palabra, echarás fuera la mentira en voz alta, exhalarás lo viejo y luego declararás la verdad sobre tu vida. Hoy: <b>' : '<b>Day 1 of 5.</b> Each day God gives a fresh way to be set free. You’ll receive His Word, cast off the lie out loud, breathe out the old, then declare the truth over your life. Today: <b>') + d.title.replace(/[.…]+$/, '') + '</b>.</div>'
        + '</div>'
      ) : '';

      const ck = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5l4.5 4.5L19 7"/></svg>';

      $('dfScroll').innerHTML =
        '<h2 class="df-h">' + d.title + '</h2>'
        + '<div class="df-sh">' + cFrom() + ' <span class="arr">&rarr;</span> ' + cTo() + '</div>'
        + welcome
        // 1 — RECEIVE
        + '<div class="block scripture"><div class="lab"><span class="step">1</span>' + (esL() ? 'Recibe' : 'Receive') + ' &middot; <a class="vref-link" href="' + dayVerseLink(d.ref) + '">' + d.ref + ' ' + d.ver + '<svg class="vref-go" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg></a></div>'
          + '<div class="verse">“' + d.verse + '”</div><div class="insight">' + d.insight + '</div></div>'
        // 2 — PRAY
        + '<div class="block pray"><div class="lab"><span class="step">2</span>' + (esL() ? 'Ora' : 'Pray') + '</div><div class="ptitle">' + d.prayerTitle + '</div><div class="pr">' + d.pray + '</div></div>'
        // 3 — CAST OFF
        + '<div class="block castoff' + (ds.cast ? ' done' : '') + '" id="castBlock"><div class="lab"><span class="step">3</span>' + (esL() ? 'Echa fuera la mentira' : 'Cast off the lie') + '</div>'
          + '<div class="intro">' + (esL() ? 'Léela una vez, en voz alta, y nómbrala por lo que es. Luego échala fuera.' : 'Read it once, out loud, and name it for what it is. Then cast it off.') + '</div>'
          + '<div class="lie-card' + (ds.cast ? ' cast' : '') + '" id="lieCard"><div class="lie-q">' + (esL() ? 'La mentira que he creído' : 'The lie I’ve believed') + '</div><div class="lie-t">“' + d.castOff + '”</div></div>'
          + '<button class="cast-btn" id="castBtn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"/></svg>' + (esL() ? 'Échala fuera' : 'Cast it off') + '</button>'
          + '<div class="cast-done">' + ck + (esL() ? 'Echada fuera. No tiene poder sobre ti.' : 'Cast off. It has no hold on you.') + '</div></div>'
        // 4 — REPENT & BREATHE
        + '<div class="block repent" id="repentBlock"><div class="lab"><span class="step">4</span>' + (esL() ? 'Arrepiéntete y respira' : 'Repent &amp; breathe') + '</div>'
          + '<div class="repent-t">“' + d.repent + '”</div>'
          + '<div class="repent-stage" id="repentStage">'
            + '<div class="repent-idle" id="repentIdle">'
              + '<button class="breath-start" id="breathStart"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a4 4 0 0 1 4 4c0 3 4 3.5 4 7a4 4 0 0 1-8 0 4 4 0 0 1-8 0c0-3.5 4-4 4-7a4 4 0 0 1 4-4z"/></svg>' + (esL() ? 'Comienza la oración de respiración' : 'Begin breath prayer') + '</button>'
              + '<button class="breath-skip-link" id="breathSkip">' + (esL() ? 'No puedo respirar hondo ahora &mdash; omitir' : 'I can’t breathe deeply right now &mdash; skip') + '</button>'
            + '</div>'
            + '<div class="breath-active" id="breathActive" style="display:none"><div class="breath-round" id="breathRound"></div><div class="breath-inline" id="repentBreath"></div></div>'
            + '<div class="repent-done" id="repentDone" style="display:none"><span class="rd-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5l4.5 4.5L19 7"/></svg></span><div class="rd-t" id="repentDoneT">' + (esL() ? 'Amén. Exhalaste lo viejo.' : 'Amen. You breathed out the old.') + '</div><button class="rd-again" id="breathAgain">' + (esL() ? 'Respira otra vez' : 'Breathe again') + '</button></div>'
          + '</div></div>'
        // 5 — DECLARE THE TRUTH ALOUD (no mic, no recording — just say it, then mark it)
        + '<div class="block declare' + (ds.spoke ? ' spoken' : '') + '" id="declareBlock"><div class="lab"><span class="step">5</span>' + (esL() ? 'Declara la verdad en voz alta' : 'Declare the truth aloud') + '</div>'
          + '<div class="dc">“' + d.declare + '”</div>'
          + '<div class="mic-hint" id="micHint">' + (ds.spoke ? (esL() ? 'Amén. Lo declaraste. &#10003;' : 'Amen. You declared it. &#10003;') : (esL() ? 'Dilo en voz alta, luego márcalo aquí.' : 'Say it out loud — then mark it here.')) + '</div>'
          + '<button class="act-check' + (ds.spoke ? ' on' : '') + '" id="declCheck"><span class="bx">' + ck + '</span><span id="declLbl">' + (ds.spoke ? (esL() ? 'Declarado en voz alta' : 'Declared aloud') : (esL() ? 'Marcar como declarado' : 'Mark as declared')) + '</span></button></div>'
        // 6 — REFLECT
        + '<div class="block reflect"><div class="lab"><span class="step">6</span>' + (esL() ? 'Reflexiona' : 'Reflect') + '</div><p>' + d.reflect + '</p><textarea placeholder="' + (esL() ? 'Escribe con libertad. Esto es entre tú y Dios.' : 'Write freely. This is between you and God.') + '"></textarea></div>'
        // 7 — ACT
        + '<div class="block action' + (ds.acted ? ' done' : '') + '" id="actBlock"><div class="lab"><span class="step">7</span>' + (esL() ? 'Llévalo a tu día' : 'Take it into your day') + '</div>'
          + '<div class="act-t">' + d.actionTitle + '</div><div class="act-d">' + d.action + '</div>'
          + '<button class="act-check' + (ds.acted ? ' on' : '') + '" id="actCheck"><span class="bx">' + ck + '</span><span id="actLbl">' + (ds.acted ? (esL() ? 'Lo hice' : 'I did this') : (esL() ? 'Lo llevaré hoy' : 'I’ll carry this today')) + '</span></button></div>';

      $('dfScroll').scrollTop = 0;
      bindCast(); bindRepent(); bindSpeak(); bindAction();
      refreshGate();
      // reverent unfolding — each step veils in as it scrolls into view (premium scroll-reveal,
      // not all-at-once on load), with a gentle cascade for the steps already on screen.
      if (window.DeclareMotion && !window.DeclareMotion.reduced && ('IntersectionObserver' in window)) {
        const root = $('dfScroll');
        root.style.setProperty('--m-stagger', '0ms'); // we control timing; no per-index CSS delay
        const seq = Array.prototype.slice.call(root.querySelectorAll(':scope > .df-h, :scope > .df-sh, :scope > .block, :scope > .day1note'));
        seq.forEach(function (el) { el.classList.add('m-veil'); el.style.setProperty('--i', 0); });
        const rb = root.getBoundingClientRect();
        let k = 0;
        const io = new IntersectionObserver(function (ents) {
          ents.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('m-in'); io.unobserve(e.target); } });
        }, { root: root, rootMargin: '0px 0px -8% 0px', threshold: 0 });
        seq.forEach(function (el) {
          const r = el.getBoundingClientRect();
          if (r.top < rb.bottom * 0.95 && r.bottom > rb.top) { const i = k++; setTimeout(function () { el.classList.add('m-in'); }, 90 + i * 110); }
          else io.observe(el);
        });
      }
    }

    // ---- step 3: cast off ----
    function bindCast() {
      const btn = $('castBtn'), card = $('lieCard'), blk = $('castBlock');
      if (!btn) return;
      btn.addEventListener('click', function () {
        card.classList.add('cast'); blk.classList.add('done'); dstate().cast = true;
        if (navigator.vibrate) { try { navigator.vibrate(14); } catch (_) {} } refreshGate();
      });
    }
    // ---- step 4: repent breath (guided, finite, with start + skip + complete) ----
    const BREATH_ROUNDS = 3;
    function repentMarkDone(skipped) {
      if (breathInst) { try { breathInst.destroy(); } catch (_) {} breathInst = null; }
      dstate().repented = skipped ? 'skipped' : true;
      const idle = $('repentIdle'), act = $('breathActive'), done = $('repentDone');
      if (idle) idle.style.display = 'none'; if (act) act.style.display = 'none'; if (done) done.style.display = 'flex';
      const t = $('repentDoneT'); if (t) t.textContent = skipped ? (esL() ? 'Guardado por hoy. El Espíritu te encuentra aquí.' : 'Held for today. The Spirit meets you here.') : (esL() ? 'Amén. Exhalaste lo viejo.' : 'Amen. You breathed out the old.');
      refreshGate();
    }
    function bindRepent() {
      const ds = dstate();
      const startBtn = $('breathStart'), skip = $('breathSkip'), again = $('breathAgain');
      if (ds.repented) { repentMarkDone(ds.repented === 'skipped'); }
      if (startBtn) startBtn.addEventListener('click', startBreath);
      if (skip) skip.addEventListener('click', function () { repentMarkDone(true); });
      if (again) again.addEventListener('click', function () { dstate().repented = false; $('repentDone').style.display = 'none'; $('repentIdle').style.display = 'flex'; refreshGate(); });
    }
    function startBreath() {
      if (!window.BreathRing) { repentMarkDone(false); return; }
      $('repentIdle').style.display = 'none'; $('repentDone').style.display = 'none';
      $('breathActive').style.display = 'block';
      const round = [{ label: esL() ? 'Respira misericordia' : 'Breathe in mercy', secs: 4, scale: 1, glow: .95 }, { label: esL() ? 'Sostén' : 'Hold', secs: 2, scale: 1, glow: .95 }, { label: esL() ? 'Suelta lo viejo' : 'Release the old', secs: 6, scale: .55, glow: .34 }];
      let seq = []; for (let r = 0; r < BREATH_ROUNDS; r++) { seq = seq.concat(round); }
      const perRound = round.length;
      if (breathInst) { try { breathInst.destroy(); } catch (_) {} }
      breathInst = window.BreathRing.mount($('repentBreath'), {
        seq: seq, loop: false, skipLabel: esL() ? 'Omitir el resto' : 'Skip the rest',
        caption: esL() ? 'Exhala lo viejo. Inhala su misericordia.' : 'Breathe out the old. Breathe in His mercy.',
        onPhase: function (idx) { const rd = Math.floor(idx / perRound) + 1; const el = $('breathRound'); if (el) el.textContent = (esL() ? 'Respiración ' : 'Breath ') + rd + (esL() ? ' de ' : ' of ') + BREATH_ROUNDS; },
        onDone: function () { if (navigator.vibrate) { try { navigator.vibrate(16); } catch (_) {} } repentMarkDone(false); },
        onSkip: function () { repentMarkDone(true); }
      });
