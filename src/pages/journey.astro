        return '<button class="zs-card" data-id="' + c.id + '"><span class="zs-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">' + ICONS[c.icon] + '</svg></span><span class="zs-txt"><span class="zs-shift"><span class="zs-from">' + cFrom(c) + '</span><span class="zs-toline"><span class="zs-arr" aria-hidden="true">→</span><span class="zs-to">' + cTo(c) + '</span></span></span><span class="zs-line">' + cLine(c) + '</span></span><span class="zs-go" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg></span></button>';
      }).join('');
      $('zsList').querySelectorAll('.zs-card').forEach(function (b) { b.addEventListener('click', function () { plantAndBegin(b); }); });
    }
    $('zsSeeAll').addEventListener('click', function () { openChooseList(true); });

    // ---- journey complete actions ----
    function jcShareText() { const d7 = PLAN[TOTAL - 1];
      return '“' + d7.declare + '”\n— ' + d7.ref + '  (' + cFrom() + ' → ' + cTo() + ')\n\n' + (esL() ? 'Mi camino de 5 días con Declare & Believe.' : 'My 5-day journey with Declare & Believe.'); }

    /* design share system — share.js + card-studio.js lazy-loaded on first tap */
    let shareStack = null;
    function loadShareStack() {
      if (shareStack) return shareStack;
      shareStack = new Promise((resolve) => {
        ['/declare/share.css?v=3.16.0', '/declare/card-studio.css?v=3.16.0'].forEach((href) => {
          const l = document.createElement('link'); l.rel = 'stylesheet'; l.href = href; document.head.appendChild(l);
        });
        const s1 = document.createElement('script'); s1.src = '/declare/card-studio.js?v=3.16.0';
        s1.onload = () => {
          const s2 = document.createElement('script'); s2.src = '/declare/share.js?v=3.16.0';
          s2.onload = resolve; document.head.appendChild(s2);
        };
        document.head.appendChild(s1);
      });
      return shareStack;
    }
    $('jcShare').addEventListener('click', function () {
      const d7 = PLAN[TOTAL - 1];
      loadShareStack().then(function () {
        if (window.DeclareShare) {
          window.DeclareShare.open({ type: 'journey', text: d7.declare, ref: (d7.ref || '') + (d7.ver ? ' · ' + d7.ver : ''), subtitle: cFrom() + ' → ' + cTo(), url: location.href, save: saveItem });
        } else { openShareSheet(jcShareText()); }
      });
    });
    function openShareSheet(txt) { $('shareText').value = txt; openSheet('shareSheet'); }
    $('shareClose').addEventListener('click', closeSheets);
    $('shareCopy').addEventListener('click', function () {
      const ta = $('shareText'); ta.focus(); ta.select(); ta.setSelectionRange(0, ta.value.length);
      let ok = false; try { ok = document.execCommand('copy'); } catch (e) { ok = false; }
      if (ok) { toast(esL() ? 'Copiado — pégalo donde quieras' : 'Copied — paste anywhere'); }
      else if (navigator.clipboard && navigator.clipboard.writeText) { navigator.clipboard.writeText(ta.value).then(function () { toast(esL() ? 'Copiado — pégalo donde quieras' : 'Copied — paste anywhere'); }).catch(function () { toast(esL() ? 'Selecciona el texto y cópialo' : 'Select the text and copy'); }); }
      else { toast(esL() ? 'Selecciona el texto y cópialo' : 'Select the text and copy'); }
    });
    $('jcSave').addEventListener('click', function () { const b = this; if (b.disabled) return;
      if (!ensureSignedIn(esL() ? 'Crea una cuenta gratis para guardar este camino en tu Bóveda.' : 'Create a free account to keep this journey in your Vault.')) return;
      b.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;margin-right:7px;vertical-align:-3px"><path d="M5 12.5l4.5 4.5L19 7"/></svg>' + (esL() ? 'Guardado en la Bóveda' : 'Saved to Vault');
      vaultSaveAll(); b.disabled = true; b.style.opacity = '.72'; toast(esL() ? 'Guardado en tu Bóveda' : 'Saved to your Vault'); });
    $('jcNew').addEventListener('click', function () { $('journeyComplete').classList.remove('show'); $('journeyComplete').setAttribute('aria-hidden', 'true'); showZeroUI(); renderZero(true); openChooseList(); });

    let _tt;
    function toast(msg) { const t = $('toast'); t.textContent = msg; t.classList.add('show'); clearTimeout(_tt); _tt = setTimeout(function () { t.classList.remove('show'); }, 2400); }

    // ---- pastoral care gate for sensitive journeys ----
    const CARE = {
      abuse: 'What was done to you was real, and it was not your fault. You don’t have to carry it alone. If you are in danger right now, please reach out for help first — that is the strong, God-honoring thing to do. When you’re ready, we’ll walk these five days gently, and let God speak your true name over the wounding words.',
      sexual: 'There’s no shame here, and no condemnation — only grace. You can be fully honest in this space; it stays between you and God. We’ll take this one gentle day at a time. If you ever need to talk to a real person, that door is always open.',
      addiction: 'You’re not too far gone, and you don’t have to do this alone. This journey walks with you one day at a time. If you’re in crisis or need real support, please reach out — asking for help is courage, not failure.',
      depression: 'Thank you for being here. That took something today. If the darkness ever feels like too much, or you’re having thoughts of harming yourself, please reach out to someone right now — you matter, and help is here. When you’re ready, we’ll take this gently, one day at a time.',
      grief: 'There’s no right way to grieve and no clock on it. Come as you are, tears and all. We’ll move slowly and gently through these days. If you need someone to talk to along the way, that help is always here.',
      divorce: 'What you’re walking through is a real loss, and grief is the honest response to it. There’s no blame here and no pressure — only space to bring the breaking to God. We’ll go gently, one day at a time. If you ever need to talk to someone, that door is always open.',
    };
    // Spanish care-gate copy (declare-lang = es). Same pastoral, non-triggering intent.
    const CARE_ES = {
      abuse: 'Lo que te hicieron fue real, y no fue tu culpa. No tienes que cargarlo solo. Si estás en peligro ahora mismo, por favor busca ayuda primero — eso es lo fuerte y lo que honra a Dios. Cuando estés listo, caminaremos estos cinco días con calma, y dejaremos que Dios hable tu verdadero nombre sobre las palabras que hirieron.',
      sexual: 'Aquí no hay vergüenza, ni condenación — solo gracia. Puedes ser totalmente honesto en este espacio; queda entre tú y Dios. Lo tomaremos un día suave a la vez. Si alguna vez necesitas hablar con una persona real, esa puerta siempre está abierta.',
      addiction: 'No estás demasiado lejos, y no tienes que hacer esto solo. Este camino te acompaña un día a la vez. Si estás en crisis o necesitas apoyo real, por favor busca ayuda — pedir ayuda es valentía, no fracaso.',
      depression: 'Gracias por estar aquí. Eso costó algo hoy. Si la oscuridad alguna vez se siente demasiado, o tienes pensamientos de hacerte daño, por favor busca a alguien ahora mismo — tú importas, y hay ayuda aquí. Cuando estés listo, lo tomaremos con calma, un día a la vez.',
      grief: 'No hay una forma correcta de hacer duelo ni un reloj para él. Ven tal como estás, con lágrimas y todo. Iremos despacio y con suavidad por estos días. Si necesitas alguien con quien hablar en el camino, esa ayuda siempre está aquí.',
      divorce: 'Lo que estás atravesando es una pérdida real, y el duelo es la respuesta honesta a ella. Aquí no hay culpa ni presión — solo espacio para traerle a Dios lo que se rompe. Iremos con suavidad, un día a la vez. Si alguna vez necesitas hablar con alguien, esa puerta siempre está abierta.',
    };
    function isSensitive(id) { return !!CARE[id]; }
    function openCareGate(id, onBegin) {
      $('careBody').textContent = (esL() && CARE_ES[id]) ? CARE_ES[id] : (CARE[id] || '');
      $('careBegin').onclick = function () { closeSheets(); setTimeout(onBegin, 220); };
      openSheet('careSheet');
    }

    // ---- entry from Declare: map the chosen struggle → a journey, open Day 1 ----
    function mapStruggle(s) {
      s = (s || '').toLowerCase();
      const rules = [
        // dedicated journeys — most specific first
        [/(divorce|separation|splitting up|ex-wife|ex-husband)/, 'divorce'],
        [/(faith crisis|deconstruct|losing my faith|god feels far|god feels absent|is god real)/, 'faithcrisis'],
        [/(spiritual.{0,3}attack|oppress|demonic|warfare|tormented)/, 'spiritualattack'],
        [/(sexual temptation|pornograph|lust|sexual sin|porn)/, 'sexual'],
        [/(verbal abuse|emotional abuse|abusive|\babuse\b|narcissist|belittl|demean)/, 'abuse'],
        [/(addict|substance|drinking|drug|alcohol)/, 'addiction'],
        [/(marriage|spouse|husband|wife)/, 'marriage'],
        [/(grief|loss|mourn|bereav|died|death)/, 'grief'],
        [/(depress|hopeless|despair|numb)/, 'depression'],
        [/(lonel|alone|isolat|left out|unseen|forgotten)/, 'loneliness'],
        [/(betray|cheated on|backstab|stabbed in the back|deceiv)/, 'betrayal'],
        [/(unforg|bitter|resentment|grudge)/, 'unforgiveness'],
        [/(anger|angry|rage|temper|wrath)/, 'anger'],
        [/(family conflict|family|parents|sibling|in-law|household)/, 'family'],
        [/(feeling like a failure|like a failure|failure|i failed|always fail|messed up)/, 'failure'],
        [/(comparison|compare|comparing|jealous|envy)/, 'comparison'],
        [/(unworthy|unworth|don.{0,1}t deserve|not worthy|undeserving|not enough)/, 'unworthy'],
        [/(broken identity|who am i|lost myself|don.{0,1}t know who i am)/, 'identity'],
        [/(feeling lost|directionless|no direction|no purpose|wandering|lost my way)/, 'lost'],
        [/(people pleas|people-pleas|fear of man|need(ing)? approval|can.{0,1}t say no)/, 'peoplepleasing'],
        [/(self.?sabotage|sabotage|my own worst enemy|undermine)/, 'selfsabotage'],
        [/(overthink|racing thoughts|can.{0,1}t stop thinking|ruminat|spiral)/, 'overthinking'],
        [/(\bcontrol\b|controlling|let go|need to control)/, 'control'],
        [/(perfection|never good enough|never enough|flawless)/, 'perfectionism'],
        [/(financial|finances|money|debt|provision|bills|broke)/, 'financial'],
        [/(stress|burnout|burn out|burned out|exhaust|overwhelm|running on empty)/, 'burnout'],
        [/(spiritual dry|dryness|dry season|dry spell|distant from god)/, 'dryness'],
        [/(waiting on god|waiting|wait on|long wait|delay)/, 'waiting'],
        [/(drift|drifting|far from god|fallen away|cooled|first love|backslid)/, 'drifting'],
        // broad sibling fallbacks
        [/(doubt|unbelief|cynic)/, 'doubt'],
        [/(fear|afraid|panic|scared|intimidat)/, 'fear'],
        [/(shame|guilt|condemn|regret|hiding)/, 'shame'],
        [/(reject|abandon|belong|approval)/, 'rejection'],
        [/(anx|worry|identity)/, 'anxiety'],
      ];
      for (let i = 0; i < rules.length; i++) { if (rules[i][0].test(s)) return rules[i][1]; }
      return 'anxiety';
    }

    function init() {
      // honest statuses: everything opens 'open'; the device decides what's
      // done and what's growing (the design file's authored demo statuses are
      // exactly that — demo)
      CATALOG.forEach(function (c) { c.status = 'open'; });
      loadDone().forEach(function (id) { const c = CATALOG.find(function (x) { return x.id === id; }); if (c) c.status = 'done'; });

      let start = null, struggle = null;
      try { start = localStorage.getItem('declare-start-journey');
        struggle = localStorage.getItem('declare-journey-struggle') || localStorage.getItem('declare-struggle'); } catch (e) {}
      if (start) {
        try { localStorage.removeItem('declare-start-journey'); } catch (e) {}
        const targetId = mapStruggle(struggle);
        const already = loadActiveSaved();
        if (already && already.id) {
          // A journey is already growing — never silently replant. Users re-enter
          // through /today's "Start a 5-Day Journey" card the day after Day 1 and
          // were losing everything (lock, instance, reflections) to a fresh Day 1.
          const sc = CATALOG.find(function (x) { return x.id === already.id; });
          if (sc) { active = sc; active.status = 'active'; startPlan(); restoreInstance(); }
          state.day = already.day || state.day; state.returned = already.returned || state.returned;
          restoreProgress();
          showActiveUI();
          if (already.id === targetId) {
            // Same struggle: this is a continue, not a restart — open where they left off.
            setTimeout(openDayFlow, 380);
          } else {
            // Different struggle: let them choose, with the existing progress-kept sheet.
            setTimeout(function () { openSheet('resetSheet'); }, 420);
          }
          return;
        }
        const c = CATALOG.find(function (x) { return x.id === targetId; });
        if (c) { active = c; active.status = 'active'; }
        startPlan();
        state.day = 1; state.returned = 0; daySpoken = {}; dayState = {}; clearLock(); clearInstance(); saveActive();
        showActiveUI();
        if (isSensitive(active.id)) { setTimeout(function () { openCareGate(active.id, openDayFlow); }, 420); }
        else { setTimeout(openDayFlow, 380); }
        return;
      }
      // No bridge entry: honor real persistence.
      const saved = loadActiveSaved();
      if (saved) {
        const sc = CATALOG.find(function (x) { return x.id === saved.id; });
        if (sc) { active = sc; active.status = 'active'; startPlan(); restoreInstance(); }
        state.day = saved.day || state.day; state.returned = saved.returned || state.returned;
        restoreProgress();
        showActiveUI();
        return;
      }
      // Brand-new visitor — no journey ever planted. Open the honest zero state.
      showZeroUI(); renderZero(loadDone().length > 0);
    }
    // Build from synced state once the account's data has come down (instant for guests).
    whenSynced().then(init);
  </script>

  <style is:global>
    /* ──────────────────────────────────────────────────────────────────
       /journey — Tree of Knowledge → Tree of Life (design-source surface).
       Adaptation: document scroll for the home; the day flow, overlays,
       sheets, scrim and toast are viewport-fixed (house pattern).
       ────────────────────────────────────────────────────────────────── */
    .journey { position: relative; min-height: 100dvh; }
    /* NOTE: .jin must NOT create a stacking context (no z-index) — the day flow,
       overlays and sheets inside it are viewport-fixed and have to stack above
       the layout's fixed tabbar/mast. Source order already covers the topglow. */
    .journey .jin { position: relative; }
    .journey .scroll { padding: 6px 22px calc(120px + env(safe-area-inset-bottom)); }
