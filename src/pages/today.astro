---
// /today — Declare. SURFACE rebuilt verbatim from the design source
// (design-source-v3.2/declare/Today.html input + Results.html results); the
// proven MACHINERY (declare-api.js: prompt, streaming, crisis logic) is injected
// unchanged. Declare flow default translation: NLT (per the Bible Integration
// Spec). Saves are device-local (vault-store.js, 'declare-vault-v1').
// The design's "Start a 5-Day Journey" card is included (review ruling) and leads
// to /journey, a branded coming-soon page until the Journey chapter ships.
// Single page: entry ⇄ results swap in place.
import DeclareLayout from '../layouts/DeclareLayout.astro';
import RateReview from '../components/RateReview.astro';
---
<DeclareLayout
  title="Declare: Today"
  description="Name your struggle, anxiety, fear, shame, grief, and receive Bible verses, declarations, and a prayer for this exact moment. Free, English and Spanish."
  activeTab="declare"
>
  <main class="today">
    <div class="topglow" aria-hidden="true"></div>

    {/* ============ ENTRY (design: Today.html) ============ */}
    <div class="in" id="entryView">
      <div class="entryhero rise d1">
        <div class="heading" data-i18n="today.heading">What&rsquo;s weighing on your heart?</div>
        <div class="sub" data-i18n="today.sub">Name it, and receive His Word for this moment.</div>
      </div>

      <form class="input entry-input rise d2" id="writeForm" autocomplete="off">
        <textarea id="writeInput" rows="1" placeholder="Or write what&rsquo;s on your heart&hellip;" data-i18n-ph="today.placeholder" aria-label="Write what's on your heart" data-i18n-aria="today.writeAria"></textarea>
        <button class="send" type="submit" aria-label="Receive the Word" data-i18n-aria="today.receiveAria">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M6 11l6-6 6 6"></path></svg>
        </button>
      </form>

      <div class="divider entry-div rise d3"><span></span><em data-i18n="today.orChoose">or choose what fits</em><span></span></div>

      <div class="chips entry-chips rise d4" id="chips">
        <button class="chip on" data-struggle="Fear &amp; Anxiety" data-i18n="chip.fearAnxiety">Fear &amp; Anxiety</button>
        <button class="chip" data-struggle="Shame &amp; Guilt" data-i18n="chip.shameGuilt">Shame &amp; Guilt</button>
        <button class="chip" data-struggle="Loneliness" data-i18n="chip.loneliness">Loneliness</button>
        <button class="chip" data-struggle="Anger &amp; Bitterness" data-i18n="chip.angerBitterness">Anger &amp; Bitterness</button>
        <button class="chip" data-struggle="Doubt" data-i18n="chip.doubt">Doubt</button>
        <button class="chip" data-struggle="Grief &amp; Loss" data-i18n="chip.griefLoss">Grief &amp; Loss</button>
        <button class="chip more" id="moreBtn" data-i18n="today.more">More +</button>
      </div>

      <div class="spacer"></div>

      <button class="btn btn-primary btn-full rise d5" id="receiveBtn" data-i18n="today.receiveBtn">Receive the Word</button>

      <a class="crisis entry-crisis rise d6" href="/crisis">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"></circle><circle cx="12" cy="12" r="3.4"></circle><line x1="5.6" y1="5.6" x2="9.6" y2="9.6"></line><line x1="14.4" y1="14.4" x2="18.4" y2="18.4"></line><line x1="18.4" y1="5.6" x2="14.4" y2="9.6"></line><line x1="9.6" y1="14.4" x2="5.6" y2="18.4"></line></svg>
        <span data-i18n="today.crisisLink">In crisis? Find help now</span>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
      </a>
    </div>

    {/* ============ RESULTS (design: Results.html) ============ */}
    <div class="results" id="resultsView" hidden>
      <div class="botglow" aria-hidden="true"></div>

      {/* >=1024px only (results-grid CSS below) — a quiet wayfinding rail:
          the same actions already reachable in .nextsteps/.results-crisis
          below, just always visible instead of requiring a scroll. Hidden
          at every narrower width; .nextsteps/.results-crisis stay as the
          only copy at those widths. */}
      <aside class="results-rail results-rail-left" aria-hidden="true">
        <a class="rail-action" id="railReadPassage" href="/word">
          <span class="nsi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5.4A1.4 1.4 0 0 1 5.4 4H11v15.2H5.4A1.4 1.4 0 0 0 4 20.6z"></path><path d="M20 5.4A1.4 1.4 0 0 0 18.6 4H13v15.2h5.6A1.4 1.4 0 0 1 20 20.6z"></path></svg></span>
          <span data-i18n="today.nsReadT">Read the full passage</span>
        </a>
        <a class="rail-action" href="/vault">
          <span class="nsi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3.5" y="5" width="17" height="15" rx="2.5"></rect><path d="M3.5 9.5h17"></path><path d="M8 5V3.5M16 5V3.5M12 13.2v3"></path><circle cx="12" cy="12.4" r="1.3"></circle></svg></span>
          <span data-i18n="today.nsReturnT">Return to it later</span>
        </a>
        <button class="rail-action" id="railAnotherWord" type="button">
          <span class="nsi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="13" r="5"></circle><path d="M12 2v3M4.5 6.5l1.5 1.5M19.5 6.5l-1.5 1.5M2 13h3M19 13h3"></path></svg></span>
          <span data-i18n="today.nsAnotherT">Receive another word</span>
        </button>
        <a class="rail-crisis" href="/crisis">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"></circle><circle cx="12" cy="12" r="3.4"></circle><line x1="5.6" y1="5.6" x2="9.6" y2="9.6"></line><line x1="14.4" y1="14.4" x2="18.4" y2="18.4"></line><line x1="18.4" y1="5.6" x2="14.4" y2="9.6"></line><line x1="9.6" y1="14.4" x2="5.6" y2="18.4"></line></svg>
          <span data-i18n="today.crisisLink">In crisis? Find help now</span>
        </a>
      </aside>

      {/* >=1024px only — optional depth, never required reading: a verse
          index with an expandable "Breakdown" (deep context tied back to
          the struggle, from the AI's `breakdowns` field) and, once there's
          real data for it, a quiet "Your Recent Words" list. */}
      <aside class="results-rail results-rail-right" aria-hidden="true">
        <div class="rail-title" data-i18n="today.inThisWord">In this Word</div>
        <div id="railIndex"></div>
        <div class="idx-divider" id="railRecentDivider" hidden></div>
        <div class="rail-title" id="railRecentTitle" hidden data-i18n="today.recentWords">Your Recent Words</div>
        <div id="railRecent"></div>
      </aside>

      {/* everything between the two rails is ONE grid cell (results-main),
          so the grid only ever has a single row across all three columns —
          no row-spanning between the rails and this content, which is what
          was causing the huge vertical gap between .head and #resultsBody
          (a spanning item's minimum-size resolution was inflating row 1). */}
      <div class="results-main">
      <div class="head">
        <button class="iconbtn" id="resultsBack" aria-label="Back" data-i18n-aria="today.back">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 5l-7 7 7 7"></path></svg>
        </button>
        <span class="mid" id="forLabel">For fear &amp; anxiety</span>
        <button class="iconbtn bm" id="saveWord" aria-label="Save this word" aria-pressed="false" data-i18n-aria="today.saveWord">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4.5h12v15l-6-4-6 4z"></path></svg>
        </button>
      </div>

      <div id="resultsBody">
        <div class="intro m-rise"><div class="serif" data-i18n="today.intro">Walk through this slowly.</div></div>

        <div class="journey" data-m-stagger style="--m-stagger:240ms; --m-premium:820ms">
          {/* Scripture */}
          <div class="stn m-veil">
            <span class="node" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5.4A1.4 1.4 0 0 1 5.4 4H11v15.2H5.4A1.4 1.4 0 0 0 4 20.6z"></path><path d="M20 5.4A1.4 1.4 0 0 0 18.6 4H13v15.2h5.6A1.4 1.4 0 0 1 20 20.6z"></path></svg></span>
            <div class="stnhead"><span class="lbl" data-i18n="today.lblScripture">Scripture</span></div>
            <div class="serif verse" id="verse1"></div>
            <a class="ref ref-link" id="ref1"></a>
            <div id="receives"></div>
          </div>

          {/* Mindset */}
          <div class="stn m-veil">
            <span class="node" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M9.2 17.5h5.6"></path><path d="M10 20.5h4"></path><path d="M12 3.2A5.8 5.8 0 0 0 8.4 13c.5.5.8 1.1.8 1.8v.2h5.6v-.2c0-.7.3-1.3.8-1.8A5.8 5.8 0 0 0 12 3.2z"></path></svg></span>
            <div class="stnhead"><span class="lbl" data-i18n="today.lblMindset">Mindset</span></div>
            <div class="mind" id="mind">
              <div class="body" id="mindBody"></div>
              <div class="more-body"><div class="more-in">
                <div class="body" style="margin-top:0" id="mindMore"></div>
              </div></div>
              <button class="more" id="more" aria-expanded="false">
                <span class="more-lbl" data-i18n="today.readMore">Read more</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"></path></svg>
              </button>
            </div>
          </div>

          {/* Speak it aloud */}
          <div class="stn m-veil">
            <span class="node" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="3" width="6" height="11" rx="3"></rect><path d="M5.5 11a6.5 6.5 0 0 0 13 0"></path><path d="M12 17.5V21"></path></svg></span>
            <div class="stnhead"><span class="lbl" data-i18n="today.lblSpeak">Speak it aloud</span></div>
            <div class="speak" id="speak"></div>
          </div>

          {/* Prayer */}
          <div class="stn m-veil">
            <span class="node" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M10.7 5.3C9.5 7.3 8.5 10 8.1 12.8c-.4 2.4-.1 4.8 1.1 6.4l2.5.1V6.6z"></path><path d="M13.3 5.3c1.2 2 2.2 4.7 2.6 7.5.4 2.4.1 4.8-1.1 6.4l-2.5.1V6.6z"></path></svg></span>
            <div class="stnhead"><span class="lbl" data-i18n="today.lblPrayer">Prayer</span></div>
            <div class="praywrap">
              <div class="prayglow" aria-hidden="true"></div>
              <div class="pray">
                <div class="ptext" id="ptext"></div>
                <div class="amen" id="amen" data-i18n="today.amen">Amen.</div>
              </div>
            </div>
          </div>
        </div>

        <div class="foot">
          <button class="save" id="saveWord2">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4.5h12v15l-6-4-6 4z"></path></svg>
            <span class="sw-lbl" data-i18n="today.saveWord">Save this word</span>
          </button>
          <button class="share" id="shareWord">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v13"></path><path d="M8 7l4-4 4 4"></path><path d="M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-7"></path></svg>
            <span data-i18n="today.share">Share</span>
          </button>
        </div>

        <div class="startjourney m-rise">
          <div class="sj-glow" aria-hidden="true"></div>
          <div class="sj-tag" data-i18n="today.sjTag">Five days to free</div>
          <div class="sj-h" data-i18n="today.sjH">Don&rsquo;t just feel better. Be made free.</div>
          <div class="sj-p"><span data-i18n="today.sjP1">One Word can steady you for </span><span class="tod-word" id="sjTod">tonight</span><span data-i18n="today.sjP2">. But real change rarely comes from understanding a truth once. It comes from meeting God in it again and again, until you believe what you are declaring instead of just saying it. This 5-Day Journey walks you deeper into </span><b id="sjStruggle">fear &amp; anxiety</b><span data-i18n="today.sjP3">, not to manage it, but to replace what is underneath it: what you believe about yourself, and what you believe about God.</span></div>
          <button class="btn btn-primary btn-full" id="startJourney"><span data-i18n="today.startJourney">Start a 5-Day Journey</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:17px;height:17px;margin-left:7px;vertical-align:-3px"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
          </button>
        </div>

        <div class="nextsteps m-rise">
          <div class="ns-lbl" data-i18n="today.carry">Carry it with you</div>
          <div class="nslist">
            <a class="nscard" id="readPassage" href="/word"><span class="nsi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5.4A1.4 1.4 0 0 1 5.4 4H11v15.2H5.4A1.4 1.4 0 0 0 4 20.6z"></path><path d="M20 5.4A1.4 1.4 0 0 0 18.6 4H13v15.2h5.6A1.4 1.4 0 0 1 20 20.6z"></path></svg></span><span class="nsm"><span class="nst" data-i18n="today.nsReadT">Read the full passage</span><span class="nsd" data-i18n="today.nsReadD">Open it in The Word and keep reading</span></span><span class="nsa"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg></span></a>
            <a class="nscard" href="/vault"><span class="nsi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3.5" y="5" width="17" height="15" rx="2.5"></rect><path d="M3.5 9.5h17"></path><path d="M8 5V3.5M16 5V3.5M12 13.2v3"></path><circle cx="12" cy="12.4" r="1.3"></circle></svg></span><span class="nsm"><span class="nst" data-i18n="today.nsReturnT">Return to it later</span><span class="nsd" data-i18n="today.nsReturnD">Everything you saved lives in your Vault</span></span><span class="nsa"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg></span></a>
            <button class="nscard" id="anotherWord"><span class="nsi"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="13" r="5"></circle><path d="M12 2v3M4.5 6.5l1.5 1.5M19.5 6.5l-1.5 1.5M2 13h3M19 13h3"></path></svg></span><span class="nsm"><span class="nst" data-i18n="today.nsAnotherT">Receive another word</span><span class="nsd" data-i18n="today.nsAnotherD">For whatever else is heavy</span></span><span class="nsa"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg></span></button>
          </div>
        </div>

        {/* Crisis help must be reachable here too, not only pre-submission — a
            gap found during the desktop redesign audit (also always-visible in
            the >=1024px sidebar, see TabBar.astro/sidebar.css, but this keeps
            it one tap away at every breakpoint including mobile/tablet). */}
        <a class="crisis results-crisis" href="/crisis">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"></circle><circle cx="12" cy="12" r="3.4"></circle><line x1="5.6" y1="5.6" x2="9.6" y2="9.6"></line><line x1="14.4" y1="14.4" x2="18.4" y2="18.4"></line><line x1="18.4" y1="5.6" x2="14.4" y2="9.6"></line><line x1="9.6" y1="14.4" x2="5.6" y2="18.4"></line></svg>
          <span data-i18n="today.crisisLink">In crisis? Find help now</span>
        </a>

        {/* Rate & Review: bottom sentinel — IntersectionObserver shows the toast here. */}
        <div id="rrSentinel" aria-hidden="true" style="height:1px;pointer-events:none;"></div>
      </div>

      <div id="resultsError" hidden>
        <div class="rsoon">
          <div class="ri"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5.4A1.4 1.4 0 0 1 5.4 4H11v15.2H5.4A1.4 1.4 0 0 0 4 20.6z"></path><path d="M20 5.4A1.4 1.4 0 0 0 18.6 4H13v15.2h5.6A1.4 1.4 0 0 1 20 20.6z"></path></svg></div>
          <div class="rt2" data-i18n="today.errTitle">Something interrupted this</div>
          <div class="rd" data-i18n="today.errDesc">The Word is still here. Let&rsquo;s try again.</div>
          <div class="err-actions">
            <button class="btn btn-primary" id="tryAgain" data-i18n="today.tryAgain">Try again</button>
            <button class="btn btn-ghost" id="errBack" data-i18n="today.goBack">Go back</button>
          </div>
        </div>
      </div>
      </div><!-- /results-main -->
    </div>

    {/* ============ More sheet (design: Today.html, verbatim) ============ */}
    <div class="sheet-scrim" id="scrim"></div>
    <section class="sheet" id="sheet" aria-label="Choose what fits" aria-hidden="true">
      <div class="sheetglow" aria-hidden="true"></div>
      <div class="grabber" aria-hidden="true"></div>
      <div class="shead">
        <span class="t serif" data-i18n="today.sheetTitle">What&rsquo;s on your heart?</span>
        <button class="x" id="sheetClose" aria-label="Close">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"></path></svg>
        </button>
      </div>
      <div class="ssscroll" data-lenis-prevent>
        <form class="input" id="sheetForm" autocomplete="off" style="margin-top:16px">
          <input type="text" placeholder="Or write it in your own words&hellip;" data-i18n-ph="today.ownWordsPh" aria-label="Write it in your own words" data-i18n-aria="today.writeAria" />
          <button class="send" type="submit" aria-label="Receive the Word" data-i18n-aria="today.receiveAria">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M6 11l6-6 6 6"></path></svg>
          </button>
        </form>

        <div class="scat">
          <div class="catlbl" data-i18n="today.catIdentity">Identity &amp; worth</div>
          <div class="chips" data-cat>
            <button class="chip" data-struggle="Shame &amp; Guilt" data-i18n="chip.shameGuilt">Shame &amp; Guilt</button><button class="chip" data-struggle="Feeling Like a Failure">Feeling Like a Failure</button><button class="chip" data-struggle="Comparison">Comparison</button><button class="chip" data-struggle="Feeling Unworthy">Feeling Unworthy</button><button class="chip" data-struggle="Broken Identity">Broken Identity</button><button class="chip" data-struggle="Feeling Lost">Feeling Lost</button><button class="chip" data-struggle="People Pleasing">People Pleasing</button>
          </div>
        </div>
        <div class="scat">
          <div class="catlbl" data-i18n="today.catWounds">Wounds &amp; relationships</div>
          <div class="chips" data-cat>
            <button class="chip" data-struggle="Emotional &amp; Verbal Abuse">Emotional &amp; Verbal Abuse</button><button class="chip" data-struggle="Rejection &amp; Abandonment">Rejection &amp; Abandonment</button><button class="chip" data-struggle="Betrayal">Betrayal</button><button class="chip" data-struggle="Self-Sabotage">Self-Sabotage</button><button class="chip" data-struggle="Unforgiveness">Unforgiveness</button><button class="chip" data-struggle="Family Conflict">Family Conflict</button><button class="chip" data-struggle="Marriage Struggles">Marriage Struggles</button><button class="chip" data-struggle="Divorce / Separation">Divorce / Separation</button><button class="chip" data-struggle="Grief &amp; Loss" data-i18n="chip.griefLoss">Grief &amp; Loss</button><button class="chip" data-struggle="Loneliness" data-i18n="chip.loneliness">Loneliness</button>
          </div>
        </div>
        <div class="scat">
          <div class="catlbl" data-i18n="today.catMind">Mind &amp; emotion</div>
          <div class="chips" data-cat>
            <button class="chip on" data-struggle="Fear &amp; Anxiety" data-i18n="chip.fearAnxiety">Fear &amp; Anxiety</button><button class="chip" data-struggle="Overthinking">Overthinking</button><button class="chip" data-struggle="Depression">Depression</button><button class="chip" data-struggle="Anger &amp; Bitterness" data-i18n="chip.angerBitterness">Anger &amp; Bitterness</button><button class="chip" data-struggle="Doubt" data-i18n="chip.doubt">Doubt</button><button class="chip" data-struggle="Control">Control</button><button class="chip" data-struggle="Perfectionism">Perfectionism</button><button class="chip" data-struggle="Stress &amp; Burnout">Stress &amp; Burnout</button>
          </div>
        </div>
        <div class="scat">
          <div class="catlbl" data-i18n="today.catTrials">Trials &amp; Seasons</div>
          <div class="chips" data-cat>
            <button class="chip" data-struggle="Spiritual Dryness">Spiritual Dryness</button><button class="chip" data-struggle="Waiting on God">Waiting on God</button><button class="chip" data-struggle="Financial Stress">Financial Stress</button><button class="chip" data-struggle="Sexual Temptation">Sexual Temptation</button><button class="chip" data-struggle="Addiction">Addiction</button><button class="chip" data-struggle="Faith Crisis">Faith Crisis</button><button class="chip" data-struggle="Feeling Spiritually Attacked">Feeling Spiritually Attacked</button><button class="chip" data-struggle="Drifting from God">Drifting from God</button>
          </div>
        </div>

        <a class="crisis sheet-crisis" href="/crisis">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"></circle><circle cx="12" cy="12" r="3.4"></circle><line x1="5.6" y1="5.6" x2="9.6" y2="9.6"></line><line x1="14.4" y1="14.4" x2="18.4" y2="18.4"></line><line x1="18.4" y1="5.6" x2="14.4" y2="9.6"></line><line x1="9.6" y1="14.4" x2="5.6" y2="18.4"></line></svg>
          <span data-i18n="today.crisisLink">In crisis? Find help now</span>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
        </a>
      </div>
      <div class="ctawrap">
        <button class="btn btn-primary btn-full" id="sheetCta"><span data-i18n="today.receiveBtn">Receive the Word</span> <span class="cta-n" data-i18n="today.ctaDefault">&middot; Fear &amp; Anxiety</span></button>
      </div>
    </section>

    {/* share chooser (design: Results.html .sps) */}
    <div class="sps-scrim" id="spsScrim"></div>
    <section class="sps" id="sps" aria-hidden="true" aria-label="Choose what to share" data-lenis-prevent>
      <div class="grab" aria-hidden="true"></div>
      <h3>Share this word</h3>
      <div class="sps-sub">Choose what to send</div>
      <div id="spsRows"></div>
    </section>

    {/* toast (design: Results.html) */}
    <div class="toast" id="toast"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"></path></svg><span id="toastMsg">Saved to Vault.</span></div>

    {/* Rate & Review surface (toast + multi-step sheet). Behavior wired in <script> below. */}
    <RateReview />

  {/* SEO: crawlable summary for engines and AI answer bots (page is JS-rendered). */}
  <noscript>
    <section>
      <h2>Receive God's Word for what you're carrying</h2>
      <p>Declare and Believe gives Christians Scripture for the exact struggle they name: anxiety, fear, shame, grief, loneliness, doubt, burnout, and more. You describe what's weighing on you and receive Bible verses, a short faith-rooted reflection, "I am" declarations to speak aloud, and a personal prayer. Free, ad-free, in English and Spanish.</p>
      <p>Explore <a href="/struggles">Scripture for every struggle</a>, read the Bible in <a href="/word/">seven translations</a>, or walk a <a href="/journey/">free 5-day journey</a> out of one battle. This experience requires JavaScript.</p>
    </section>
  </noscript>
  </main>

  <script>
    import { generateContent, isCompleteResult } from '../app/declare/declare-api.js';
    import { saveItem, removeItem, isSaved, wordId, listItems } from '../app/declare/vault-store.js';
    import { initAuth } from '../app/declare/auth-store.js';
    import { ensureSignedIn } from '../app/declare/auth-gate.js';
    import { track } from '../app/declare/analytics.js';
    import { initRateReview } from '../app/declare/rate-review.js';
    import { isToastEligible, noteDismissed, noteSubmitted, recordWordReceived } from '../app/declare/rate-gate.js';
    import { reviewsSubmit } from '../app/declare/convex-data.js';
    import Lenis from 'lenis';

    // Rate & Review: the gated results toast. RateReview.astro is mounted in this
    // page; the bottom #rrSentinel triggers the toast once the gate passes. Set up
    // after the session resolves so isSignedIn() is accurate. (initAuth is cached.)
    initAuth().then(() => {
      initRateReview({
        isEligible: isToastEligible,
        onDismiss: noteDismissed,
        onSubmit: (payload) => { noteSubmitted(); reviewsSubmit(payload); },
      });
    });

    // Cinematic smooth scroll on the results page (unseen.co feel). Desktop wheel
    // only (Lenis default smoothTouch:false keeps native mobile momentum); skipped
    // under reduced-motion.
    if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
      try {
        const lenis = new Lenis({ smoothWheel: true });
        const raf = (t) => { lenis.raf(t); requestAnimationFrame(raf); };
        requestAnimationFrame(raf);
      } catch (e) {}
    }

    // The Declare flow default per the Bible Integration Spec. The brain call,
    // prompts, streaming, and crisis logic in declare-api.js are unchanged.
    const TRANSLATION = 'NLT';
    function activeTrans(){ return (window.I18N && I18N.lang() === 'es') ? 'RVR1909' : TRANSLATION; }
    function activeLang(){ try { return (window.I18N && I18N.lang()) || 'en'; } catch(e){ return 'en'; } }

    const $ = (id) => document.getElementById(id);
    const esc = (s) => (s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

    const entryView = $('entryView'), resultsView = $('resultsView');
    const resultsBody = $('resultsBody'), resultsError = $('resultsError');
    const chips = $('chips'), writeInput = $('writeInput');
    const sheet = $('sheet'), scrim = $('scrim'), sheetCta = $('sheetCta');
    const toast = $('toast'), toastMsg = $('toastMsg');
    function tI(k, fb){ try { return (window.I18N ? window.I18N.t(k, fb) : fb); } catch(e){ return fb; } }
    function struggleLabel(s){ try { if (window.I18N && I18N.lang()==='es'){ var m=window.__I18N_STRUGGLES_ES||{}, c=window.__I18N_CHIP_ES||{}; return m[s]||c[s]||s; } } catch(e){} return s; }
    /* inline (mid-sentence) form: Spanish lowercases only the first letter so proper
       nouns survive ('esperar en Dios'); English keeps the full lowercase as before */
    function struggleLower(s){ var l = struggleLabel(s); try { if (window.I18N && I18N.lang()==='es') return l.charAt(0).toLowerCase() + l.slice(1); } catch(e){} return l.toLowerCase(); }

    let selected = 'Fear & Anxiety';
    let activeStruggle = '';
    let content = null, currentId = null;
    let usedRefs = [];
    let reqId = 0;
    let speakingIdx = -1;
    let toastTimer = null;

    /* ---------- helpers ---------- */
    function showToast(msg) {
      toastMsg.textContent = msg;
      toast.classList.add('show');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toast.classList.remove('show'), 2200);
    }
    function showView(view) {
      [entryView, resultsView].forEach((v) => { v.hidden = v !== view; });
      window.scrollTo({ top: 0, behavior: 'instant' });
    }
    function stopSpeak() {
      if ('speechSynthesis' in window) window.speechSynthesis.cancel();
      speakingIdx = -1;
      document.querySelectorAll('.srow.speaking').forEach((el) => el.classList.remove('speaking'));
    }
    function splitPrayer(prayer) {
      const m = (prayer || '').match(/^([\s\S]*?)([\w'’ ]*\bamen\b\.?)\s*$/i);
      if (m && m[2]) return { body: m[1].trim().replace(/[,;]\s*$/, '.'), amen: m[2].trim().replace(/\.?$/, '.') };
      return { body: (prayer || '').trim(), amen: '' };
    }
    function splitExplanation(text) {
      const sentences = (text || '').match(/[^.!?]+[.!?]+(\s+|$)/g) || [text || ''];
      if (sentences.length <= 2) return { body: text, more: '' };
      return { body: sentences.slice(0, 2).join('').trim(), more: sentences.slice(2).join('').trim() };
    }
    // "Psalm 34:18" -> /word?book=Psalms&chapter=34&verse=18 — the reader opens the
    // chapter, scrolls to the verse, and highlights it so reading begins there.
    const BOOK_ALIASES = { 'Psalm': 'Psalms', 'Song of Songs': 'Song of Solomon', 'Songs of Solomon': 'Song of Solomon', 'Revelations': 'Revelation' };
    function passageLink(ref) {
      const m = (ref || '').match(/^(.*?)\s+(\d+)\s*:\s*(\d+)/);
      if (!m) return '/word';
      const book = BOOK_ALIASES[m[1].trim()] || m[1].trim();
      return '/word?book=' + encodeURIComponent(book) + '&chapter=' + m[2] + '&verse=' + m[3];
    }

    /* ---------- entry: chips (design behavior) ---------- */
    chips.addEventListener('click', (e) => {
      const c = e.target.closest('.chip'); if (!c) return;
      if (c.id === 'moreBtn') { openSheet(); return; }
      chips.querySelectorAll('.chip:not(.more)').forEach((x) => x.classList.remove('on'));
      c.classList.add('on');
      selected = c.dataset.struggle.replace(/&amp;/g, '&');
      syncSheet(selected);
    });

    /* composer: grow with the text, submit on Enter (Shift+Enter = newline) */
    function autogrow() { writeInput.style.height = 'auto'; writeInput.style.height = Math.min(writeInput.scrollHeight, 168) + 'px'; }
    writeInput.addEventListener('input', autogrow);
    writeInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        const f = $('writeForm');
        if (f.requestSubmit) f.requestSubmit(); else f.dispatchEvent(new Event('submit', { cancelable: true }));
      }
    });
    $('writeForm').addEventListener('submit', (e) => { e.preventDefault(); go(writeInput.value.trim()); });
    $('receiveBtn').addEventListener('click', () => go(writeInput.value.trim()));

    /* deep-link: ?struggle=… pre-selects (design behavior, for SEO pages later) */
    function preselect(s) {
      s = (s || '').trim(); if (!s) return;
      const main = [...chips.querySelectorAll('.chip:not(.more)')];
      let match = null;
      main.forEach((x) => { if (x.dataset.struggle.replace(/&amp;/g, '&') === s) match = x; });
      main.forEach((x) => x.classList.remove('on'));
      if (match) { match.classList.add('on'); }
      else {
        const b = document.createElement('button');
        b.className = 'chip on'; b.setAttribute('data-struggle', s); b.textContent = (typeof struggleLabel === 'function' ? struggleLabel(s) : s);
        chips.insertBefore(b, chips.firstChild);
      }
      selected = s;
      syncSheet(s);
    }
    try { const inc = new URLSearchParams(location.search).get('struggle'); if (inc) preselect(inc); } catch (e) {}

    /* ---------- More sheet (design behavior) ---------- */
    function openSheet() { sheet.classList.add('open'); scrim.classList.add('open'); sheet.setAttribute('aria-hidden', 'false'); }
    function closeSheet() { sheet.classList.remove('open'); scrim.classList.remove('open'); sheet.setAttribute('aria-hidden', 'true'); }
    $('sheetClose').addEventListener('click', closeSheet);
    scrim.addEventListener('click', closeSheet);
    function syncMain(s) {
      let matched = false;
      chips.querySelectorAll('.chip:not(.more)').forEach((x) => {
        const on = x.dataset.struggle.replace(/&amp;/g, '&') === s;
        x.classList.toggle('on', on); if (on) matched = true;
      });
      if (!matched) chips.querySelectorAll('.chip:not(.more)').forEach((x) => x.classList.remove('on'));
    }
    function syncSheet(s) {
      sheet.querySelectorAll('[data-cat] .chip').forEach((x) => {
        const on = x.dataset.struggle.replace(/&amp;/g, '&') === s;
        x.classList.toggle('on', on);
        if (on) sheetCta.querySelector('.cta-n').innerHTML = '&middot; ' + x.innerHTML;
      });
    }
    sheet.querySelectorAll('[data-cat]').forEach((group) => {
      group.addEventListener('click', (e) => {
        const c = e.target.closest('.chip'); if (!c) return;
        sheet.querySelectorAll('.chip').forEach((x) => x.classList.remove('on'));
        c.classList.add('on');
        const s = c.dataset.struggle.replace(/&amp;/g, '&');
        selected = s;
        sheetCta.querySelector('.cta-n').innerHTML = '&middot; ' + c.innerHTML;
        syncMain(s);
      });
    });
    $('sheetForm').addEventListener('submit', function (e) {
      e.preventDefault();
      const v = this.querySelector('input').value.trim();
      go(v);
    });
    sheetCta.addEventListener('click', () => go(''));

    /* ---------- analytics: privacy-safe category + translation (see .agents/tracking-plan.md).
       Preset chip labels are a closed UI set (never user free text); typed input is never
       inspected and always reports as 'other', so the raw struggle text never reaches
       track(). Both fields are bounded by allowlists — no free text is ever sent. ---------- */
    function slugifyStruggle(label) {
      return (label || '').toLowerCase().replace(/&/g, 'and')
        .replace(/[^a-z0-9]+/g, '_').replace(/^_+|_+$/g, '') || 'other';
    }
    const KNOWN_STRUGGLES = new Set([
      'fear_and_anxiety','shame_and_guilt','loneliness','anger_and_bitterness','doubt','grief_and_loss',
      'feeling_like_a_failure','comparison','feeling_unworthy','broken_identity','feeling_lost','people_pleasing',
      'emotional_and_verbal_abuse','rejection_and_abandonment','betrayal','self_sabotage','unforgiveness',
      'family_conflict','marriage_struggles','divorce_separation','overthinking','depression','control',
      'perfectionism','stress_and_burnout','spiritual_dryness','waiting_on_god','financial_stress',
      'sexual_temptation','addiction','faith_crisis','feeling_spiritually_attacked','drifting_from_god',
    ]);
    function categoryOf(label) {
      const s = slugifyStruggle(label);
      return KNOWN_STRUGGLES.has(s) ? s : 'other';
    }
    const KNOWN_TRANSLATIONS = new Set(['nkjv', 'nlt', 'niv']);
    function translationSlug(t) {
      const s = (t || '').toLowerCase();
      return KNOWN_TRANSLATIONS.has(s) ? s : 'other';
    }

    /* ---------- generate (the unchanged brain) ---------- */
    function go(written) {
      const struggle = written || selected;
      if (!struggle) return;
      activeStruggle = struggle;
      const typed = !!written; // typed free text is never sent; only a bounded category
      track('struggle_submitted', {
        struggle_category: typed ? 'other' : categoryOf(selected),
        input_method: typed ? 'typed' : 'preset',
        translation: translationSlug(activeTrans()),
      });
      closeSheet();
      showView(resultsView);
      runGen(struggle);
    }
    async function runGen(struggle) {
      const myReq = ++reqId;
      resultsBody.hidden = true; resultsError.hidden = true;
      // the header is visible while the word streams — name the right struggle in the
      // right language from the start (the SSR placeholder is English "fear & anxiety")
      $('forLabel').textContent = tI('today.forPrefix', 'For ') + struggleLabel(struggle);
      if (window.RouteLoader) window.RouteLoader.show();
      try {
        const ai = await generateContent(struggle, activeTrans(), usedRefs, { language: activeLang() });
        if (myReq !== reqId) return;
        if (!isCompleteResult(ai)) throw new Error('incomplete result');
        usedRefs = usedRefs.concat(ai.verses.map((v) => v.ref));
        render(ai);
      } catch (err) {
        if (myReq !== reqId) return;
        console.error('[today] generation failed:', err);
        resultsError.hidden = false;
      } finally {
        if (window.RouteLoader) window.RouteLoader.hide();
      }
    }
    $('tryAgain').addEventListener('click', () => runGen(activeStruggle));
    $('errBack').addEventListener('click', () => showView(entryView));

    /* ---------- render results (design markup) ---------- */
    function render(ai) {
      content = ai;
      currentId = wordId(activeStruggle, ai.verses);
      recordWordReceived(); // count toward the rate-prompt gate (>= 3 Words received)
      $('forLabel').textContent = tI('today.forPrefix','For ') + struggleLabel(activeStruggle);

      const v1 = ai.verses[0];
      $('verse1').innerHTML = '&ldquo;' + esc(v1.t || v1.text) + '&rdquo;';
      $('ref1').textContent = v1.ref + ' · ' + activeTrans();
      $('ref1').href = passageLink(v1.ref);

      // further verses: "tap to receive this verse" reveals (design .receive)
      $('receives').innerHTML = ai.verses.slice(1).map((v, i) => (
        '<div class="receive" data-i="' + i + '">'
        + '<button class="rtoggle" aria-expanded="false">'
        +   '<span class="pl"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"></path></svg></span>'
        +   '<span class="rmid">'
        +     '<span class="rprompt"><b>' + esc(v.ref) + '</b> &middot; <span class="serif rp-i">' + tI('today.tapReceive','tap to receive this verse') + '</span></span>'
        +   '</span>'
        + '</button>'
        + '<span class="reveal"><span class="reveal-in">'
        +   '<span class="serif rverse">&ldquo;' + esc(v.text) + '&rdquo;</span>'
        +   '<span class="rrow"><a class="rref ref-link" href="' + passageLink(v.ref) + '">' + esc(v.ref) + ' &middot; ' + activeTrans() + '</a></span>'
        + '</span></span>'
        + '</div>'
      )).join('');

      const ex = splitExplanation(ai.explanation);
      $('mindBody').textContent = ex.body;
      $('mindMore').textContent = ex.more;
      $('mind').classList.remove('open');
      $('more').style.display = ex.more ? '' : 'none';
      $('more').setAttribute('aria-expanded', 'false');
      $('more').querySelector('.more-lbl').textContent = tI('today.readMore','Read more');

      $('speak').innerHTML = ai.declarations.map((d, i) => (
        '<div class="card srow" data-i="' + i + '">'
        + '<button class="play" aria-label="Read aloud"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg></button>'
        + '<span class="dec">' + esc(d) + '</span></div>'
      )).join('');

      const pr = splitPrayer(ai.prayer);
      $('ptext').textContent = pr.body;
      $('amen').textContent = pr.amen || tI('today.amen','Amen.');

      $('readPassage').href = passageLink(v1.ref);
      $('railReadPassage').href = passageLink(v1.ref);
      $('sjStruggle').textContent = struggleLower(activeStruggle);
      // time-of-day copy: same 6pm/6am boundary the theme auto-resolver uses
      // in DeclareLayout.astro, so the Journey card's tone and the app's
      // visual theme flip at the same moment. "Tonight" only shows up when
      // it is actually night for this reader.
      const hr = new Date().getHours();
      $('sjTod').textContent = (hr < 6 || hr >= 18) ? tI('today.tonight', 'tonight') : tI('today.today', 'today');

      // >=1024px right rail: verse index + expandable Breakdown. `ai.breakdowns`
      // is optional (older cached/fallback content may not have it) so every
      // row falls back gracefully instead of breaking.
      const breakdowns = Array.isArray(ai.breakdowns) ? ai.breakdowns : [];
      $('railIndex').innerHTML = ai.verses.map((v, i) => (
        '<div class="idx-row" data-i="' + i + '">'
        + '<button class="idx-top" type="button">'
        +   '<span class="idx-n">' + (i + 1) + '</span>'
        +   '<span><span class="idx-ref">' + esc(v.ref) + '</span><span class="idx-go">' + tI('today.breakdown', 'Breakdown') + '</span></span>'
        + '</button>'
        + '<div class="idx-breakdown"><div class="in"><p>' + esc(breakdowns[i] || tI('today.noBreakdown', 'A deeper look at this verse is not available for this word.')) + '</p></div></div>'
        + '</div>'
      )).join('');

      // >=1024px right rail: "Your Recent Words" — other struggles already
      // saved to the Vault, most recent first, excluding this one. (Device-
      // local Vault data today; once struggleHistory ships this can widen to
      // every struggle asked, not just the ones someone chose to save.)
      try {
        const seen = new Set(); const recent = [];
        for (const it of listItems()) {
          if (!it.struggle || it.struggle === activeStruggle || seen.has(it.struggle)) continue;
          seen.add(it.struggle); recent.push(it);
          if (recent.length >= 3) break;
        }
        $('railRecentDivider').hidden = recent.length === 0;
        $('railRecentTitle').hidden = recent.length === 0;
        $('railRecent').innerHTML = recent.map((it) => (
          '<a class="recent-row" href="/today/?struggle=' + encodeURIComponent(it.struggle) + '"><span class="rdot"></span><span class="rt">' + esc(struggleLabel(it.struggle)) + '</span></a>'
        )).join('');
      } catch (e) { /* Vault unavailable — rail just shows the verse index */ }

      updateSaveUI();
      resultsBody.hidden = false;
      // replay the design's cascade (motion.js): clear past reveals, then stagger in
      resultsBody.querySelectorAll('.m-in').forEach((el) => el.classList.remove('m-in'));
      if (window.DeclareMotion) window.DeclareMotion.reveal(resultsBody, { stagger: 140 });
      window.scrollTo({ top: 0, behavior: 'instant' });
    }

    /* reveals + read-more + play (delegation) — only the .rtoggle button
       opens/closes the card; clicking the revealed verse-reference link
       inside it must navigate, not toggle it shut again. */
    $('receives').addEventListener('click', (e) => {
      const btn = e.target.closest('.rtoggle'); if (!btn) return;
      const card = btn.closest('.receive');
      const open = card.classList.toggle('open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    $('more').addEventListener('click', () => {
      const open = $('mind').classList.toggle('open');
      $('more').setAttribute('aria-expanded', open ? 'true' : 'false');
      $('more').querySelector('.more-lbl').textContent = open ? tI('today.readLess','Read less') : tI('today.readMore','Read more');
    });
    $('speak').addEventListener('click', (e) => {
      const btn = e.target.closest('.play'); if (!btn) return;
      const row = btn.closest('.srow'); const i = +row.dataset.i;
      if (speakingIdx === i) { stopSpeak(); return; }
      stopSpeak();
      if (!('speechSynthesis' in window)) return;
      const u = new SpeechSynthesisUtterance(content.declarations[i]);
      u.rate = 0.86; u.pitch = 1.02;
      u.onend = () => { if (speakingIdx === i) stopSpeak(); };
      u.onerror = () => { if (speakingIdx === i) stopSpeak(); };
      speakingIdx = i; row.classList.add('speaking');
      window.speechSynthesis.speak(u);
    });

    /* ---------- save (device-local) + share ---------- */
    function updateSaveUI() {
      const saved = currentId && isSaved(currentId);
      $('saveWord').classList.toggle('on', !!saved);
      $('saveWord').setAttribute('aria-pressed', saved ? 'true' : 'false');
      document.querySelector('#saveWord2 .sw-lbl').textContent = saved ? tI('today.saved','Saved') : tI('today.saveWord','Save this word');
      $('saveWord2').classList.toggle('on', !!saved);
    }
    function toggleSave() {
      if (!content || !currentId) return;
      if (!ensureSignedIn(tI('today.saveSignin','Create a free account to keep this word in your Vault.'))) return;
      if (isSaved(currentId)) {
        removeItem(currentId);
        showToast(tI('today.removedVault','Removed from Vault.'));
      } else {
        saveItem({
          id: currentId, type: 'word', struggle: activeStruggle, translation: activeTrans(),
          verses: content.verses, explanation: content.explanation,
          declarations: content.declarations, prayer: content.prayer,
        });
        showToast(tI('today.savedVault','Saved to Vault.'));
      }
      updateSaveUI();
    }
    $('saveWord').addEventListener('click', toggleSave);
    $('saveWord2').addEventListener('click', toggleSave);

    /* ---------- share: design system — chooser sheet → Card Studio → share-card
       sheet (Instagram/Story/TikTok/X/Facebook/Threads/Download + native More).
       share.js + card-studio.js are the design-source modules, lazy-loaded on the
       first share tap so the reading path stays light. ---------- */
    let shareStack = null;
    function loadShareStack() {
      if (shareStack) return shareStack;
      shareStack = new Promise((resolve) => {
        ['/declare/share.css?v=3.16.0', '/declare/card-studio.css?v=3.16.0'].forEach((href) => {
          const l = document.createElement('link'); l.rel = 'stylesheet'; l.href = href; document.head.appendChild(l);
        });
        const s1 = document.createElement('script'); s1.src = '/declare/card-studio.js?v=3.16.0';
        s1.onload = () => {
          const s2 = document.createElement('script'); s2.src = '/declare/share.js?v=3.16.0';
          s2.onload = resolve; document.head.appendChild(s2);
        };
        document.head.appendChild(s1);
      });
      return shareStack;
    }

    const SP_IC = {
      verse: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5.4A1.4 1.4 0 0 1 5.4 4H11v15.2H5.4A1.4 1.4 0 0 0 4 20.6z"></path><path d="M20 5.4A1.4 1.4 0 0 0 18.6 4H13v15.2h5.6A1.4 1.4 0 0 1 20 20.6z"></path></svg>',
      mind: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9.2 17.5h5.6"></path><path d="M10 20.5h4"></path><path d="M12 3.2A5.8 5.8 0 0 0 8.4 13c.5.5.8 1.1.8 1.8v.2h5.6v-.2c0-.7.3-1.3.8-1.8A5.8 5.8 0 0 0 12 3.2z"></path></svg>',
      dec: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="3" width="6" height="11" rx="3"></rect><path d="M5.5 11a6.5 6.5 0 0 0 13 0"></path><path d="M12 17.5V21"></path></svg>',
      pray: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M10.7 5.3C9.5 7.3 8.5 10 8.1 12.8c-.4 2.4-.1 4.8 1.1 6.4l2.5.1V6.6z"></path><path d="M13.3 5.3c1.2 2 2.2 4.7 2.6 7.5.4 2.4.1 4.8-1.1 6.4l-2.5.1V6.6z"></path></svg>',
      go: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg>',
    };
    const sps = $('sps'), spsScrim = $('spsScrim'), spsRows = $('spsRows');
    let shareables = [];
    function buildShareables() {
      const v1 = content.verses[0];
      shareables = [
        { type: 'verse', label: tI('today.lblScripture','Scripture'), text: v1.text, ref: v1.ref + ' · ' + activeTrans(), ic: 'verse' },
        { type: 'reading', label: tI('today.lblMindset','Mindset'), text: content.explanation, ref: tI('today.lblMindset','Mindset'), ic: 'mind' },
        ...content.declarations.map((d) => ({ type: 'declaration', label: tI('today.lblDeclaration','Declaration'), text: d, ref: '', ic: 'dec' })),
        { type: 'reading', label: tI('today.lblPrayer','Prayer'), text: content.prayer, ref: tI('today.aPrayer','A prayer'), ic: 'pray' },
      ];
      spsRows.innerHTML = shareables.map((s, i) => (
        '<button class="sps-row" data-i="' + i + '"><span class="ic">' + SP_IC[s.ic] + '</span>'
        + '<span class="tx"><span class="k">' + s.label + '</span><span class="v">' + esc(s.text) + '</span></span>'
        + '<span class="go">' + SP_IC.go + '</span></button>'
      )).join('');
    }
    function openSps() { sps.classList.add('show'); spsScrim.classList.add('show'); sps.setAttribute('aria-hidden', 'false'); }
    function closeSps() { sps.classList.remove('show'); spsScrim.classList.remove('show'); sps.setAttribute('aria-hidden', 'true'); }
    spsScrim.addEventListener('click', closeSps);
    spsRows.addEventListener('click', (e) => {
      const row = e.target.closest('.sps-row'); if (!row) return;
      const s = shareables[+row.dataset.i];
      closeSps();
      loadShareStack().then(() => {
        setTimeout(() => {
          window.DeclareShare.open({ type: s.type, text: s.text, ref: s.ref, subtitle: tI('today.forPrefix','For ') + struggleLower(activeStruggle), url: location.href, save: saveItem });
        }, 180);
      });
    });
    $('shareWord').addEventListener('click', () => {
      if (!content) return;
      buildShareables();
      openSps();
      loadShareStack(); // warm the studio while the user chooses
    });

    /* back / reset — also the >=1024px left rail's "Receive another word",
       same action, different entry point */
    function resetToEntry() { stopSpeak(); writeInput.value = ''; autogrow(); showView(entryView); }
    $('resultsBack').addEventListener('click', () => { stopSpeak(); showView(entryView); });
    $('anotherWord').addEventListener('click', resetToEntry);
    $('railAnotherWord').addEventListener('click', resetToEntry);

    /* >=1024px right rail: expand/collapse a verse's Breakdown, one open at a time */
    $('railIndex').addEventListener('click', (e) => {
      const btn = e.target.closest('.idx-top'); if (!btn) return;
      const row = btn.closest('.idx-row');
      const wasOpen = row.classList.contains('open');
      $('railIndex').querySelectorAll('.idx-row.open').forEach((r) => r.classList.remove('open'));
      if (!wasOpen) row.classList.add('open');
    });
    $('startJourney').addEventListener('click', () => {
      // bridge: /journey reads these, maps the struggle to a journey, and opens Day 1
      try {
        localStorage.setItem('declare-start-journey', '1');
        localStorage.setItem('declare-journey-struggle', activeStruggle || '');
      } catch (e) {}
      location.href = '/journey';
    });
  </script>

  <script is:inline>
    /* Localize every struggle chip by its canonical English data-struggle key.
       data-struggle stays English (SEO autofill + AI depend on it); only the visible
       label swaps. Stashes the original so switching back to English restores it. */
    (function () {
      function localizeChips() {
        var es = !!(window.I18N && window.I18N.lang && window.I18N.lang() === 'es');
        var map = window.__I18N_CHIP_ES || {};
        var chips = document.querySelectorAll('.chip[data-struggle]');
        for (var i = 0; i < chips.length; i++) {
          var c = chips[i];
          if (c.__enLabel == null) c.__enLabel = c.textContent;
          var key = c.dataset.struggle;               // dataset decodes &amp; -> &
          c.textContent = (es && map[key]) ? map[key] : c.__enLabel;
        }
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', localizeChips);
      else localizeChips();
      document.addEventListener('declare-lang', localizeChips);
    })();
  </script>

