    .today .sps-scrim { position: fixed; inset: 0; z-index: 64; background: rgba(6, 11, 8, .55); backdrop-filter: blur(3px); -webkit-backdrop-filter: blur(3px); opacity: 0; pointer-events: none; transition: opacity .4s ease; }
