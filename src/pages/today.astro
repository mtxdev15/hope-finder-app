    .today .sps { position: fixed; left: 50%; bottom: 0; transform: translate(-50%, 100%); width: min(440px, 100%); z-index: 65; background: var(--screen); border-radius: 26px 26px 0 0; box-shadow: 0 -24px 70px -24px rgba(0, 0, 0, .7); padding: 10px 20px calc(22px + env(safe-area-inset-bottom)); transition: transform .42s cubic-bezier(.2, .7, .2, 1); max-height: 84vh; overflow-y: auto; scrollbar-width: none; }
    .today .sps::-webkit-scrollbar { display: none; }
    .today .sps.show { transform: translate(-50%, 0); }
    .today .sps .grab { width: 42px; height: 5px; border-radius: 999px; background: var(--line2); margin: 2px auto 14px; }
    .today .sps h3 { font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 600; color: var(--text); text-align: center; }
    .today .sps-sub { font-size: 13px; color: var(--muted); text-align: center; margin-top: 4px; margin-bottom: 6px; }
    .today .sps-row { display: flex; align-items: center; gap: 14px; padding: 15px 6px; width: 100%; border: 0; background: none; cursor: pointer; font-family: inherit; text-align: left; border-top: 1px solid var(--line); transition: padding-left .2s ease; }
    .today .sps-row:hover { padding-left: 10px; }
    .today .sps-row .ic { flex: 0 0 auto; width: 40px; height: 40px; border-radius: 12px; background: var(--field); display: flex; align-items: center; justify-content: center; color: var(--goldd); }
    .today .sps-row .ic svg { width: 19px; height: 19px; }
    .today .sps-row .tx { flex: 1; min-width: 0; }
    .today .sps-row .k { font-size: 10.5px; letter-spacing: .16em; text-transform: uppercase; color: var(--goldd); font-weight: 600; }
    .today .sps-row .v { font-size: 14.5px; color: var(--text); margin-top: 3px; line-height: 1.42; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .today .sps-row .go { flex: 0 0 auto; color: var(--muted); display: flex; }
    .today .sps-row .go svg { width: 16px; height: 16px; }

    /* toast (Results.html) */
    .today .toast { position: fixed; left: 50%; bottom: 110px; transform: translate(-50%, 14px); background: var(--surface); color: var(--text);
      padding: 12px 18px; border-radius: 14px; box-shadow: var(--card-shadow); font-size: 13.5px; display: flex; align-items: center; gap: 9px;
      opacity: 0; pointer-events: none; transition: opacity .3s ease, transform .3s ease; z-index: 60; }
    .today .toast.show { opacity: 1; transform: translate(-50%, 0); }
    .today .toast svg { width: 16px; height: 16px; color: var(--goldd); }

    /* error panel */
    .today .rsoon { text-align: center; padding: 60px 18px; }
    .today .rsoon .ri { width: 46px; height: 46px; margin: 0 auto 14px; border-radius: 50%; background: var(--field); display: flex; align-items: center; justify-content: center; color: var(--goldd); }
    .today .rsoon .ri svg { width: 21px; height: 21px; }
    .today .rsoon .rt2 { font-family: 'Cormorant Garamond', serif; font-size: 20px; color: var(--text); }
    .today .rsoon .rd { font-size: 13px; color: var(--muted); margin-top: 7px; line-height: 1.5; }
    .today .err-actions { display: flex; gap: 10px; justify-content: center; margin-top: 20px; }

    /* ===== DESKTOP (design Today.html + Results.html desktop blocks; the
       top-bar itself comes from declare.css .app-shell) ===== */
    @media (min-width: 481px) {
      .today .in { justify-content: center; align-items: center; max-width: 640px; width: 100%; margin: 0 auto; padding: 84px 24px 48px; min-height: 100dvh; }
      .today .spacer { display: none; }
      .today .entryhero { width: 100%; padding: 0; }
      .today .entryhero .heading { font-size: clamp(32px, 3.2vw, 42px); line-height: 1.14; }
      .today .entryhero .sub { font-size: 15.5px; margin-top: 13px; }
      .today .entry-input { width: 100%; max-width: 580px; margin: 30px auto 0; padding: 8px 8px 8px 20px; border-radius: 16px; }
      .today .entry-input textarea { font-size: 16px; }
      .today .entry-input .send { width: 38px; height: 38px; }
      .today .entry-div { width: 100%; max-width: 560px; margin: 26px auto 16px; }
      .today .entry-chips { max-width: 560px; gap: 8px; }
      .today .entry-chips .chip { font-size: 13px; padding: 8px 14px; box-shadow: none;
        background: color-mix(in srgb, var(--text) 5%, transparent); border: 1px solid var(--line); color: var(--text2); }
      .today .entry-chips .chip:hover { color: var(--text); border-color: var(--line2); }
      .today .entry-chips .chip.on { background: var(--gold); color: #22382E; border-color: transparent; box-shadow: 0 6px 16px -6px rgba(201, 168, 76, .45); }
      .today .entry-chips .chip.more { background: transparent; border: 1px dashed var(--line2); color: var(--goldd); }
      .today #receiveBtn { width: auto; min-width: 230px; align-self: center; margin-top: 30px; padding: 13px 34px; font-size: 14.5px; border-radius: 13px; }
      .today .entry-crisis { margin-top: 22px; font-size: 13px; }

      .today .head { max-width: 720px; margin: 0 auto; width: 100%; padding: 80px 22px 4px; }
      .today .intro { max-width: 720px; margin: 0 auto; width: 100%; }
      .today .journey { max-width: 720px; margin: 0 auto; width: 100%; }
      .today .foot { max-width: 720px; margin: 0 auto; width: 100%; padding-bottom: 24px; }
      .today .nextsteps { max-width: 720px; margin: 0 auto; width: 100%; padding-bottom: 96px; }
      .today .results-crisis { max-width: 720px; }
      .today .botglow { bottom: 120px; }
      .today .toast { bottom: 60px; }
    }
    @media (min-width: 1100px) {
      .today .in { max-width: 660px; padding-top: 104px; }
      .today .entryhero .heading { font-size: 44px; }
      .today .head, .today .intro, .today .journey, .today .foot, .today .nextsteps, .today .results-crisis { max-width: 760px; }
    }
    @media (min-width: 481px) {
      .today .startjourney { max-width: 720px; margin-left: auto; margin-right: auto; }
    }
    @media (min-width: 1100px) {
      .today .startjourney { max-width: 760px; }
    }

    /* ===== >=1024px: the sidebar shell (sidebar.css) replaces the fixed top
       bar, so the top-clearance padding tuned for a 60px top bar (84-104px
       above) is no longer needed — just calm, generous breathing room instead.
       Kept last among the padding-top rules so it wins at every width the
       sidebar is present, including >=1100px. ===== */
    @media (min-width: 1024px) {
      .today .in { padding-top: 64px; }
      .today .head { padding-top: 56px; }
    }

    /* ===== >=1024px: two flanking rails around the results reading column.
       Left rail is wayfinding only (the same actions already reachable at
       the bottom of the page, just always visible instead of requiring a
       scroll) — .nextsteps/.results-crisis are hidden at this width since
       the rail supersedes them. Right rail is optional depth (per-verse
       Breakdown + Recent Words), never required reading. The center column
       is untouched content; it just gets recentered by the grid instead of
       the page's own margin:auto. Kept last so it wins the .head/.results-*
       max-width contests declared earlier in this stylesheet. ===== */
    @media (min-width: 1024px) {
      /* Flexbox, not Grid — a single flex row with three items, each sized
         only by its OWN content (align-items:flex-start). Grid's row-track
         sizing has real edge cases when a spanning item shares rows with
         separately-placed siblings (that was the cause of the huge gap
         between .head and #resultsBody); flexbox has no row concept at all
         in a single, non-wrapping row, so that whole class of bug can't
         happen here. */
      .today .results { display: flex; align-items: flex-start; gap: 40px; max-width: 1400px; margin: 0 auto; padding: 0 32px; }
      .today .results-rail { display: block; flex: 0 0 260px; position: sticky; top: 32px; padding-top: 56px; }
      /* DOM order is rail-left, rail-right, results-main (the aside markup
         comes before the wrapped center content) — explicit `order` puts
         them in the correct LEFT / CENTER / RIGHT visual order regardless. */
      .today .results-rail-left { order: 1; }
      .today .results-rail-right { order: 3; flex-basis: 280px; }
      .today .results-main { order: 2; flex: 1 1 auto; min-width: 0; }
      .today .nextsteps, .today .results-crisis { display: none; }

      .today .rail-title { font-size: 10.5px; letter-spacing: .16em; text-transform: uppercase; color: var(--muted); font-weight: 600; margin: 0 0 12px; }
      .today .rail-action { display: flex; align-items: center; gap: 12px; padding: 11px 6px; border-radius: 10px; color: var(--text2); font-size: 14px; cursor: pointer; border: 0; background: none; width: 100%; text-align: left; font-family: inherit; margin-bottom: 2px; }
      .today .rail-action:hover { background: color-mix(in srgb, var(--text) 5%, transparent); color: var(--text); }
      .today .rail-action .nsi { width: 28px; height: 28px; border-radius: 8px; background: var(--field); display: flex; align-items: center; justify-content: center; color: var(--goldd); flex: 0 0 auto; }
      .today .rail-action .nsi svg { width: 13px; height: 13px; }
      .today .rail-crisis { margin-top: 26px; display: flex; align-items: center; gap: 9px; font-size: 13px; color: var(--text); opacity: .85; }
      .today .rail-crisis svg { width: 15px; height: 15px; color: var(--gold); flex: 0 0 auto; }

      .today .idx-row { background: var(--field); border: 1px solid var(--line); border-radius: 13px; padding: 3px; margin-bottom: 9px; transition: border-color .2s ease; }
      .today .idx-row.open { border-color: var(--line2); }
      .today .idx-top { display: flex; align-items: flex-start; gap: 10px; cursor: pointer; border: 0; background: none; width: 100%; text-align: left; font-family: inherit; padding: 11px 10px; border-radius: 10px; }
      .today .idx-top:hover { background: color-mix(in srgb, var(--text) 5%, transparent); }
      .today .idx-n { font-family: 'Cormorant Garamond', serif; color: var(--goldd); font-size: 16px; flex: 0 0 auto; width: 16px; }
      .today .idx-ref { font-size: 12.5px; font-weight: 500; color: var(--text); display: block; }
      .today .idx-go { font-size: 10.5px; color: var(--goldd); margin-top: 2px; display: block; }
      /* max-height transition, not grid-template-rows:0fr — a fixed cap is
         less "exact" than the fr-collapse trick but works reliably in every
         browser; the fr version was rendering these cards permanently
         expanded/empty instead of collapsed. */
      .today .idx-breakdown { max-height: 0; overflow: hidden; opacity: 0; transition: max-height .35s ease, opacity .3s ease; margin: 0 10px; }
      /* generous cap: verified real breakdown text needs up to ~450-500px in
         this rail's narrow column (breakdowns run 3-5 sentences), 400px was
         clipping real content */
      .today .idx-row.open .idx-breakdown { max-height: 800px; opacity: 1; }
      .today .idx-breakdown p { font-size: 12.5px; line-height: 1.6; color: var(--text2); padding: 0 2px 12px 32px; }
      .today .idx-divider { height: 1px; background: var(--line); margin: 16px 0; }
      .today .recent-row { display: flex; align-items: center; gap: 10px; padding: 10px; border-radius: 11px; background: var(--field); margin-bottom: 8px; }
      .today .recent-row:hover { background: color-mix(in srgb, var(--text) 6%, var(--field)); }
      .today .recent-row .rdot { width: 6px; height: 6px; border-radius: 50%; background: var(--gold); flex: 0 0 auto; }
      .today .recent-row .rt { font-size: 12.5px; font-weight: 500; color: var(--text); }
    }
    @media (min-width: 1024px) and (prefers-reduced-motion: reduce) {
      .today .idx-breakdown { transition: none; }
    }

    /* ===== DESKTOP (≥720px): sheets → centered modals (bottom sheets are a mobile
       idiom). Blur-dimmed backdrop, scale-fade on the house expo-out curve.
       Kept LAST in this stylesheet so it wins same-specificity contests. ===== */
    @media (min-width: 720px) {
      .today .sheet-scrim, .today .sps-scrim { background: rgba(6, 11, 8, .5); backdrop-filter: blur(10px) saturate(1.05); -webkit-backdrop-filter: blur(10px) saturate(1.05); }
      .today .sheet {
        left: 50%; top: 50%; bottom: auto;
        width: min(560px, 92%); max-height: min(720px, 86vh);
        border-radius: 26px; border: 1px solid var(--line2);
        box-shadow: 0 50px 130px -40px rgba(0, 0, 0, .8), 0 0 0 1px rgba(255, 255, 255, .03);
        transform: translate(-50%, -46%) scale(.965); opacity: 0; pointer-events: none; visibility: hidden;
        transition: transform .42s var(--ease-reveal, cubic-bezier(.16, 1, .3, 1)), opacity .32s ease, visibility 0s linear .42s;
      }
      .today .sheet.open { transform: translate(-50%, -50%) scale(1); opacity: 1; pointer-events: auto; visibility: visible;
        transition: transform .42s var(--ease-reveal, cubic-bezier(.16, 1, .3, 1)), opacity .32s ease; }
      .today .sheet .grabber { display: none; }
      .today .ctawrap { padding-bottom: 22px; }
      .today .sps {
        left: 50%; top: 50%; bottom: auto;
        width: min(460px, 92%); max-height: min(640px, 86vh);
        border-radius: 26px; border: 1px solid var(--line2);
        box-shadow: 0 50px 130px -40px rgba(0, 0, 0, .8), 0 0 0 1px rgba(255, 255, 255, .03);
        transform: translate(-50%, -46%) scale(.965); opacity: 0; pointer-events: none; visibility: hidden;
        transition: transform .42s var(--ease-reveal, cubic-bezier(.16, 1, .3, 1)), opacity .32s ease, visibility 0s linear .42s;
      }
      .today .sps.show { transform: translate(-50%, -50%) scale(1); opacity: 1; pointer-events: auto; visibility: visible;
        transition: transform .42s var(--ease-reveal, cubic-bezier(.16, 1, .3, 1)), opacity .32s ease; }
      .today .sps .grab { display: none; }
      @media (prefers-reduced-motion: reduce) { .today .sheet, .today .sps { transition: opacity .2s ease; } }
    }
  </style>
</DeclareLayout>
