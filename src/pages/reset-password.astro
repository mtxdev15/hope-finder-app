---
// v3.2 /reset-password — the landing for the "forgot password" email link.
// Supabase puts a recovery token in the URL; supabase-js exchanges it on load,
// giving a short-lived recovery session. With that session we open the account
// modal in 'reset' mode (new-password field) and call updateUser. No token →
// the link is invalid/expired, and we say so with a path back to request another.
import DeclareLayout from '../layouts/DeclareLayout.astro';
---
<DeclareLayout title="Declare — Reset password" description="Set a new password for your Declare account.">
  <main class="authpage">
    <div class="topglow" aria-hidden="true"></div>

    <!-- accounts not configured (missing keys) -->
    <div class="ap-missing" id="apMissing" hidden>
      <div class="serif">Almost ready.</div>
      <p>Accounts need their Supabase keys before password reset works.</p>
      <a class="btn btn-ghost" href="/today">Back to Declare</a>
    </div>

    <!-- no/expired recovery token -->
    <div class="ap-missing" id="apExpired" hidden>
      <div class="serif">This link has expired.</div>
      <p>Reset links work once and don’t last long. Request a fresh one and we’ll send it right over.</p>
      <button class="btn btn-primary" id="apRequest">Request a new link</button>
      <a class="btn btn-ghost" href="/today" style="margin-top:10px">Back to Declare</a>
    </div>
  </main>

  <script>
    import { initAuth, isConfigured, isSignedIn } from '../app/declare/auth-store.js';
    import { openAuthModal } from '../app/declare/auth-modal.js';

    const $ = (id) => document.getElementById(id);

    initAuth().then(() => {
      if (!isConfigured()) { $('apMissing').hidden = false; return; }
      if (isSignedIn()) {
        // a recovery session is active (or they're already signed in) → let them set a new password
        openAuthModal({ mode: 'reset', returnTo: '/you', onSuccess: () => { location.href = '/you'; } });
        // if they close it without finishing, send them home rather than a blank page
        const watch = setInterval(() => {
          const w = document.querySelector('.am-wrap');
          if (w && !w.classList.contains('open')) { clearInterval(watch); location.href = '/you'; }
        }, 300);
      } else {
        $('apExpired').hidden = false;
        $('apRequest').addEventListener('click', () => openAuthModal({ mode: 'forgot' }));
      }
    });
  </script>

  <style is:global>
    body:has(.authpage) > .tabbar, body:has(.authpage) > .mast { display: none; }
    .authpage { position: relative; min-height: 100dvh; }
    .authpage .ap-missing { position: relative; z-index: 1; min-height: 100dvh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 40px 30px; }
    .authpage .ap-missing[hidden] { display: none; }
    .authpage .ap-missing .serif { font-size: 26px; color: var(--text); }
    .authpage .ap-missing p { font-size: 13.5px; color: var(--muted); line-height: 1.6; margin-top: 10px; max-width: 38ch; }
    .authpage .ap-missing .btn { margin-top: 22px; min-width: 220px; }
  </style>
</DeclareLayout>
