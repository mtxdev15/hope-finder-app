      const els = rbody.querySelectorAll('[data-n]');
      for (let i = 0; i < els.length; i++) {
        if (els[i].getBoundingClientRect().bottom >= cr.top + 96) return els[i].getAttribute('data-n');
      }
      return null;
    }
    // Rest a verse just below the controls. Shared by verse-jump and the re-render restore.
    function scrollToVerseN(n, opts) {
