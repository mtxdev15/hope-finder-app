    // applyDisplay is the single source of truth — it reads the shared localStorage keys and
    // syncs the reading body + the unified Reading-preferences sheet, so brightness/theme/font/
    // size stay identical whether opened from the library gear or the reader's Aa button.
    function applyDisplay() {
      let size = 'Medium', font = 'lora', bright = 100;
      try { size = localStorage.getItem('declare-textsize') || 'Medium'; } catch (e) {}
      try { font = localStorage.getItem('declare-fontstyle') || 'lora'; } catch (e) {}
      try { const b = parseInt(localStorage.getItem('declare-brightness'), 10); if (!isNaN(b)) bright = b; } catch (e) {}
      const fs = { Small: 'fs-s', Medium: 'fs-m', Large: 'fs-l' }[size] || 'fs-m';
      rbody.className = 'rbody ' + fs + ' ff-' + font;
      dim.style.opacity = ((100 - bright) / 100 * 0.62).toFixed(3);
      const lb = $('libBright'); if (lb) lb.value = bright;
      const ss = $('libSizeSeg'); if (ss) ss.querySelectorAll('button').forEach((x) => x.classList.toggle('on', x.dataset.s === size));
      const fsg = $('libFontSeg'); if (fsg) fsg.querySelectorAll('button').forEach((x) => x.classList.toggle('on', x.dataset.f === font));
      let mode = 'dark'; try { mode = localStorage.getItem('declare-theme') || 'dark'; } catch (e) {}
      const themeSeg = $('libThemeSeg'); if (themeSeg) themeSeg.querySelectorAll('button').forEach((x) => x.classList.toggle('on', x.dataset.mode === mode));
      const fam = { cormorant: "'Cormorant Garamond',serif", lora: "'Lora',serif", sans: "'DM Sans',sans-serif" };
      const sz = { Small: '18px', Medium: '22px', Large: '27px' };
      const dp = $('lsPreview'); if (dp) { dp.style.fontFamily = fam[font] || fam.cormorant; dp.style.fontSize = sz[size] || sz.Medium; }
    }

    /* The unified Reading-preferences sheet — opened from the library gear AND the reader's
       Aa button. Theme, brightness, font and text size all share storage with the reader, so
       every surface stays in sync via applyDisplay(). Gentle open/close to match the iOS feel. */
    const lsheet = $('lsheet'), libPrefs = $('libPrefs');
    let lsTimer;
    function openLsheet() { clearTimeout(lsTimer); applyDisplay(); lsheet.hidden = false; void lsheet.offsetWidth; lsheet.classList.add('open'); }
    function closeLsheet() { lsheet.classList.remove('open'); lsTimer = setTimeout(() => { lsheet.hidden = true; }, 540); }
    if (libPrefs) libPrefs.addEventListener('click', openLsheet);
    if (lsheet) {
      lsheet.querySelectorAll('[data-lsclose]').forEach((b) => b.addEventListener('click', closeLsheet));
      $('libThemeSeg').addEventListener('click', (e) => { const b = e.target.closest('button'); if (!b) return; if (window.DeclareTheme) window.DeclareTheme.set(b.dataset.mode); applyDisplay(); });
      $('libBright').addEventListener('input', function () { try { localStorage.setItem('declare-brightness', this.value); } catch (err) {} dim.style.opacity = ((100 - this.value) / 100 * 0.62).toFixed(3); });
      $('libSizeSeg').addEventListener('click', (e) => { const b = e.target.closest('button'); if (!b) return; try { localStorage.setItem('declare-textsize', b.dataset.s); } catch (err) {} applyDisplay(); });
      $('libFontSeg').addEventListener('click', (e) => { const b = e.target.closest('button'); if (!b) return; try { localStorage.setItem('declare-fontstyle', b.dataset.f); } catch (err) {} applyDisplay(); });
      enableSwipeDown(lsheet.querySelector('.lspanel'), closeLsheet);
    }
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && lsheet && !lsheet.hidden && lsheet.classList.contains('open')) closeLsheet(); });

    function enableSwipeDown(el, onClose) {
      if (!el) return; let sy = null, dy = 0;
      el.addEventListener('touchstart', (e) => { sy = e.touches[0].clientY; dy = 0; el.style.transition = 'none'; }, { passive: true });
      el.addEventListener('touchmove', (e) => { if (sy === null) return; dy = e.touches[0].clientY - sy; if (dy > 0) el.style.transform = 'translateY(' + dy + 'px)'; }, { passive: true });
      el.addEventListener('touchend', () => { el.style.transition = ''; const doClose = dy > 80; el.style.transform = ''; sy = null; dy = 0; if (doClose) onClose(); });
    }

    /* ---------- highlights (device-local, design scheme) ---------- */
    // Highlight colors. Stored value is a color id; legacy `1` (boolean) maps to gold.
    const HL_COLORS = ['gold', 'rose', 'sky', 'mint', 'lilac'];
    function normColor(v) { return HL_COLORS.indexOf(v) >= 0 ? v : 'gold'; }
    function getHL() { try { return JSON.parse(localStorage.getItem('declare-highlights') || '{}'); } catch (e) { return {}; } }
    function hlKey(n) { return curBook + ' ' + curChap + ':' + n; }
    function isHL(n) { return !!getHL()[hlKey(n)]; }
    function applyHighlights() {
      const o = getHL();
      rbody.querySelectorAll('[data-n]').forEach((el) => {
        const v = o[hlKey(el.dataset.n)];
        if (v) { el.classList.add('hl'); el.setAttribute('data-hlc', normColor(v)); }
        else { el.classList.remove('hl'); el.removeAttribute('data-hlc'); }
      });
    }

    /* ---------- verse selection (one OR many) + actions ---------- */
    const vbar = $('vbar'), vbref = $('vbref'), vbHl = $('vbHl'), vbSave = $('vbSave'), hlPalette = $('hlPalette');
    const sel = new Set();                 // selected verse numbers (as strings); tap to add/remove
    function selNums() { return [...sel].map((x) => parseInt(x, 10)).filter((x) => !isNaN(x)).sort((a, b) => a - b); }
    // compress sorted verse numbers into a readable range: "10" / "8-11" / "8,10-11"
    function compressRange(nums) {
      const parts = []; let i = 0;
      while (i < nums.length) { let j = i; while (j + 1 < nums.length && nums[j + 1] === nums[j] + 1) j++; parts.push(i === j ? '' + nums[i] : nums[i] + '-' + nums[j]); i = j + 1; }
      return parts.join(',');
    }
    function closeVbar() { vbar.classList.remove('open'); hlPalette.hidden = true; sel.clear(); rbody.querySelectorAll('.sel').forEach((x) => x.classList.remove('sel')); }
    // common highlight color of the whole selection (null if mixed or unhighlighted)
    function selColor() {
      const o = getHL(), nums = selNums(); if (!nums.length || !o[hlKey(nums[0])]) return null;
      const first = normColor(o[hlKey(nums[0])]);
      return nums.every((m) => o[hlKey(m)] && normColor(o[hlKey(m)]) === first) ? first : null;
    }
    function verseText(el) {
      const v = el.querySelector('.vt'); if (v) return v.textContent.trim();
      const c = el.querySelector('.pcell .pcx'); return c ? c.textContent.trim() : '';
    }
    function curRef() { return curBook + ' ' + curChap + ':' + compressRange(selNums()); }
    function saveId() { return 'verse:' + curRef(); }
    // selected verses in scripture order, with text — for copy / share / save
    function selVerses() { return selNums().map((n) => { const el = rbody.querySelector('[data-n="' + n + '"]'); return { n: n, t: el ? verseText(el) : '' }; }); }
    function passageBody() { const vs = selVerses(); return vs.length <= 1 ? (vs[0] ? vs[0].t : '') : vs.map((v) => v.n + ' ' + v.t).join(' '); }
    function passageQuote() { return '“' + passageBody() + '” — ' + curRef() + ' (' + byId(readT).label + ')'; }
    function allSelHL() { const o = getHL(); return selNums().every((n) => !!o[hlKey(n)]); }
    function paintVbar() {
      const n = sel.size;
      vbHl.classList.toggle('on', n > 0 && allSelHL());
      const sc = selColor();
      hlPalette.querySelectorAll('.hlsw').forEach((b) => b.classList.toggle('on', b.dataset.c === sc));
      const saved = isSaved(saveId());
      vbSave.classList.toggle('on', saved);
      vbSave.querySelector('span').textContent = saved ? (esLock() ? 'Guardado' : 'Saved') : (esLock() ? 'Guardar' : 'Save');
      vbref.textContent = curRef() + (n > 1 ? '  ·  ' + n + (esW() ? ' versículos' : ' verses') : '') + '  ·  ' + byId(readT).label;
    }
    rbody.addEventListener('click', (e) => {
      if (e.target.closest('a,button')) return;
      const el = e.target.closest('.vrse,.pverse'); if (!el || el.dataset.n === undefined) return;
      const n = el.dataset.n;
      hlPalette.hidden = true;                                            // changing the selection collapses the palette
      if (sel.has(n)) { sel.delete(n); el.classList.remove('sel'); }     // tap again to deselect
      else { sel.add(n); el.classList.add('sel'); }                       // tap to add to the passage
      if (!sel.size) { closeVbar(); return; }
      paintVbar();
      vbar.classList.add('open');
    });
    $('vbClose').addEventListener('click', closeVbar);
    // Highlight opens a pastel palette; picking a swatch colors the whole selection.
    vbHl.addEventListener('click', () => { if (!sel.size) return; hlPalette.hidden = !hlPalette.hidden; paintVbar(); });
    hlPalette.addEventListener('click', (e) => { const b = e.target.closest('.hlsw'); if (b) applyColor(b.dataset.c); });
    function applyColor(c) {
      if (!sel.size) return;
      if (!ensureSignedIn(esLock() ? 'Crea una cuenta gratis para guardar tus resaltados.' : 'Create a free account to keep your highlights.')) return;
      const o = getHL(), nums = selNums();
      nums.forEach((n) => { const k = hlKey(n); if (c === 'none') delete o[k]; else o[k] = c; });
      try { localStorage.setItem('declare-highlights', JSON.stringify(o)); } catch (e) {}
      toast(c === 'none' ? (esLock() ? 'Resaltado quitado' : 'Highlight removed') : (nums.length > 1 ? (esLock() ? 'Versículos resaltados' : 'Verses highlighted') : (esLock() ? 'Versículo resaltado' : 'Verse highlighted')));
      hlPalette.hidden = true; paintVbar(); applyHighlights();
    }
    vbSave.addEventListener('click', () => {
      if (!sel.size) return;
      if (!ensureSignedIn(esLock() ? 'Crea una cuenta gratis para guardar esto en tu Bóveda.' : 'Create a free account to save this to your Vault.')) return;
      const id = saveId();
      if (isSaved(id)) { removeItem(id); toast(esLock() ? 'Quitado de tu Bóveda.' : 'Removed from Vault.'); }
      else { saveItem({ id, type: 'verse', ref: curRef(), text: passageBody(), translation: byId(readT).label }); toast(sel.size > 1 ? (esLock() ? 'Pasaje guardado en la Bóveda.' : 'Passage saved to Vault.') : (esLock() ? 'Guardado en tu Bóveda.' : 'Saved to Vault.')); }
      paintVbar();
    });
    $('vbCopy').addEventListener('click', () => {
      if (!sel.size) return;
      const s = passageQuote();
      if (navigator.clipboard && navigator.clipboard.writeText) navigator.clipboard.writeText(s).then(() => toast(esLock() ? 'Copiado' : 'Copied'), () => toast(esLock() ? 'Copiado' : 'Copied'));
      else toast(esLock() ? 'Copiado' : 'Copied');
    });

    /* share: design system — Card Studio when the stack loads, design fallback sheet otherwise */
    let shareStack = null;
    function loadShareStack() {
      if (shareStack) return shareStack;
      shareStack = new Promise((resolve) => {
        ['/declare/share.css?v=3.16.0', '/declare/card-studio.css?v=3.16.0'].forEach((href) => {
          const l = document.createElement('link'); l.rel = 'stylesheet'; l.href = href; document.head.appendChild(l);
        });
        const s1 = document.createElement('script'); s1.src = '/declare/card-studio.js?v=3.16.0';
        s1.onload = () => { const s2 = document.createElement('script'); s2.src = '/declare/share.js?v=3.16.0'; s2.onload = resolve; document.head.appendChild(s2); };
        s1.onerror = resolve;
        document.head.appendChild(s1);
      });
      return shareStack;
    }
    const sharesheet = $('sharesheet'), sharePrev = $('sharePrev');
    let shareTxt = '', shareRef = '', shareTrans = '';
    const shareFull = () => '“' + shareTxt + '” — ' + shareRef + ' (' + shareTrans + ')';
    $('vbShare').addEventListener('click', () => {
      if (!sel.size) return;
      shareTxt = passageBody(); shareRef = curRef(); shareTrans = byId(readT).label;
      closeVbar();
      loadShareStack().then(() => {
        if (window.DeclareShare) {
          window.DeclareShare.open({ type: 'verse', text: shareTxt, ref: shareRef + ' · ' + shareTrans, url: location.href, save: saveItem });
        } else {
          sharePrev.innerHTML = '<div class="sp-v">“' + esc(shareTxt) + '”</div><div class="sp-r">' + esc(shareRef) + ' · ' + shareTrans + '</div>';
          $('shSystem').style.display = navigator.share ? '' : 'none';
          sharesheet.classList.add('open');
        }
      });
    });
    $('shSystem').addEventListener('click', () => { if (navigator.share) navigator.share({ title: 'Declare', text: shareFull() }).then(() => {}, () => {}); sharesheet.classList.remove('open'); });
    $('shCopy').addEventListener('click', () => { if (navigator.clipboard && navigator.clipboard.writeText) navigator.clipboard.writeText(shareFull()); toast(esLock() ? 'Versículo copiado' : 'Verse copied'); sharesheet.classList.remove('open'); });

    /* ---------- init ---------- */
    applyDisplay();
    paintPills();
    enableSwipeDown(vbar, closeVbar);
    enableSwipeDown(tmenu.querySelector('.rspanel'), () => tmenu.classList.remove('open'));
    enableSwipeDown(sharesheet.querySelector('.rspanel'), () => sharesheet.classList.remove('open'));
    enableSwipeDown(rsearch.querySelector('.rspanel'), () => rsearch.classList.remove('open'));
    enableSwipeDown(document.querySelector('#vjump .vjsheet'), () => vjump.classList.remove('open'));

    // Present the Word in the reader translation's language on load (RVR1909 in an
    // English app still reads Spanish). Deferred past i18n's DOMContentLoaded apply
    // so both stash the same English originals.
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', function(){ setTimeout(updateWordLangUI, 0); });
    else setTimeout(updateWordLangUI, 0);

    /* deep-link: /word?book=Psalms&chapter=34&verse=18 (from /today + search) */
    (function deepLink() {
      try {
        const q = new URLSearchParams(location.search);
        const wantBook = (q.get('book') || '').trim();
        const wantChap = parseInt(q.get('chapter') || '', 10);
        const wantVerse = parseInt(q.get('verse') || '', 10);
        const wantT = (q.get('t') || '').trim().toLowerCase();  // e.g. Spanish pages pass &t=rvr1909
        if (wantT && byId(wantT)) setReadT(wantT);
        if (!wantBook) return;
        const btn = bookByName(wantBook); if (!btn) return;
        const chaps = parseInt(btn.dataset.chaps, 10);
        openReader(btn.dataset.name, btn.dataset.usfm, chaps);
        if (Number.isInteger(wantChap) && wantChap >= 1 && wantChap <= chaps) {
          readChapter(wantChap, Number.isInteger(wantVerse) && wantVerse >= 1 ? wantVerse : null);
        }
      } catch (e) {}
    })();
  </script>

  <style is:global>
    /* ──────────────────────────────────────────────────────────────────
       /word page styles — ported from TheWord.html's page-local <style>,
       namespaced (.word library / .w-reader overlay). Tokens + base
       components come from the vendored declare.css.
       ────────────────────────────────────────────────────────────────── */
    .word { position: relative; min-height: 100dvh; }
    .appdim { position: fixed; inset: 0; background: #000; opacity: 0; pointer-events: none; z-index: 55; transition: opacity .2s ease; }
    .word .w-col { position: relative; z-index: 1; max-width: 680px; margin: 0 auto; padding-bottom: 110px; }

    .word .whead { display: flex; justify-content: space-between; align-items: center; padding: 14px 22px 2px; color: var(--text); }
    .word .wlbl { font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--goldd); font-weight: 500; }
    .word .whead .gear { color: var(--muted); display: flex; align-items: center; justify-content: center; width: 38px; height: 38px; margin: -8px -8px -8px 0; border: 0; border-radius: 50%; background: transparent; cursor: pointer; -webkit-tap-highlight-color: transparent; transition: color .2s ease, background .25s ease, transform .18s cubic-bezier(.34,1.56,.64,1); }
    .word .whead .gear:hover { color: var(--text); background: color-mix(in srgb, var(--gold) 10%, transparent); }
    .word .whead .gear:active { transform: scale(.86); }
    .word .whead .gear svg { width: 19px; height: 19px; transition: transform .4s cubic-bezier(.34,1.56,.64,1); }
    .word .whead .gear:active svg { transform: rotate(90deg); }

    /* Reading preferences sheet — gentle, iOS-style motion (soft spring slide, blur fade, staggered rows) */
    .lsheet { position: fixed; inset: 0; z-index: 60; }
    .lsheet[hidden] { display: none; }
    .lsheet .lsback { position: absolute; inset: 0; background: rgba(6,11,8,.55); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); opacity: 0; transition: opacity .42s ease; }
    .lsheet.open .lsback { opacity: 1; }
    .lsheet .lspanel { position: absolute; left: 0; right: 0; bottom: 0; max-width: 520px; margin-inline: auto;
      background: var(--surface); border-radius: 28px 28px 0 0; padding: 10px 22px calc(26px + env(safe-area-inset-bottom));
      box-shadow: 0 -24px 64px -22px rgba(0,0,0,.7), 0 0 0 1px var(--line);
      transform: translateY(102%); transition: transform .52s cubic-bezier(.32,.72,0,1); }
    .lsheet.open .lspanel { transform: none; }
    .lsgrab { width: 42px; height: 5px; border-radius: 999px; background: var(--line2); margin: 2px auto 16px; }
    .lstitle { text-align: center; font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 600; color: var(--text); }
    .lssub { text-align: center; font-size: 12.5px; color: var(--muted); margin: 3px 0 16px; }
    .lspreview { text-align: center; padding: 2px 6px 18px; color: var(--text); line-height: 1.4; min-height: 32px; font-family: 'Lora', serif; font-size: 20px; }
    .lssec { margin-bottom: 18px; opacity: 0; transform: translateY(12px); }
    .lsheet.open .lssec { animation: lsRise .5s cubic-bezier(.22,1,.36,1) forwards; }
    .lsheet.open .lssec:nth-child(5) { animation-delay: .04s; }
    .lsheet.open .lssec:nth-child(6) { animation-delay: .09s; }
    .lsheet.open .lssec:nth-child(7) { animation-delay: .14s; }
    .lsheet.open .lssec:nth-child(8) { animation-delay: .19s; }
    @keyframes lsRise { to { opacity: 1; transform: none; } }
    .lsbright { display: flex; align-items: center; gap: 13px; }
    .lsbright svg { width: 18px; height: 18px; color: var(--muted); flex: 0 0 auto; }
    .lsbright input[type=range] { flex: 1; -webkit-appearance: none; appearance: none; height: 5px; border-radius: 999px; background: var(--line2); outline: none; }
    .lsbright input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; width: 20px; height: 20px; border-radius: 50%; background: var(--gold); cursor: pointer; box-shadow: 0 2px 6px rgba(0,0,0,.3); }
    .lsbright input[type=range]::-moz-range-thumb { width: 20px; height: 20px; border: 0; border-radius: 50%; background: var(--gold); cursor: pointer; }
    .lslbl { font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--goldd); font-weight: 500; margin-bottom: 9px; }
    .lsseg { display: flex; gap: 6px; }
    .lsseg button { flex: 1; border: 1px solid var(--line2); background: transparent; color: var(--text); border-radius: 13px; padding: 12px 4px; cursor: pointer; font-family: inherit; font-size: 14px;
      -webkit-tap-highlight-color: transparent; transition: background .25s ease, border-color .25s ease, transform .16s cubic-bezier(.34,1.56,.64,1); }
    .lsseg button:active { transform: scale(.94); }
    .lsseg button.on { background: rgba(216,184,95,.16); border-color: rgba(216,184,95,.5); color: var(--text); }
    .lsseg .ff-cormorant { font-family: 'Cormorant Garamond', serif; } .lsseg .ff-lora { font-family: 'Lora', serif; } .lsseg .ff-sans { font-family: 'DM Sans', sans-serif; }
    .lsseg .sz1 { font-size: 13px; } .lsseg .sz2 { font-size: 16px; } .lsseg .sz3 { font-size: 19px; }
    .lsdone { width: 100%; margin-top: 8px; padding: 14px; border: 0; border-radius: 999px; background: var(--gold); color: #15241B; font-family: inherit; font-size: 14px; font-weight: 700; cursor: pointer; transition: transform .16s cubic-bezier(.34,1.56,.64,1); }
    .lsdone:active { transform: scale(.97); }
    @media (prefers-reduced-motion: reduce) {
      .lsheet .lsback, .lsheet .lspanel, .lssec, .lsseg button, .word .whead .gear, .word .whead .gear svg { transition: none; animation: none; }
      .lssec { opacity: 1; transform: none; }
    }
    /* Desktop: present as a centered modal (gentle scale-in) rather than a full-width bottom sheet. */
    @media (min-width: 600px) {
      .lsheet { display: flex; align-items: center; justify-content: center; }
      .lsheet[hidden] { display: none; }
      .lsheet .lspanel { position: relative; left: auto; right: auto; bottom: auto; width: 420px; max-width: calc(100vw - 40px);
        border-radius: 26px; padding: 18px 26px 26px; box-shadow: 0 40px 120px -30px rgba(0,0,0,.7), 0 0 0 1px var(--line);
        transform: translateY(14px) scale(.97); opacity: 0; transition: transform .42s cubic-bezier(.22,1,.36,1), opacity .32s ease; }
      .lsheet.open .lspanel { transform: none; opacity: 1; }
      .lsgrab { display: none; }
    }
    .word .wtitle { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 600; padding: 4px 22px 2px; color: var(--text); }

    .word .search { display: flex; align-items: center; gap: 11px; margin: 12px 22px 0; padding: 14px 16px; background: var(--surface); border-radius: 16px; box-shadow: var(--card-shadow); }
    .word .search svg { flex: 0 0 auto; width: 17px; height: 17px; color: var(--goldd); }
    .word .search input { flex: 1; border: 0; background: transparent; outline: none; font-family: inherit; font-size: 14px; color: var(--text); }
    .word .search input::placeholder { color: var(--muted); }

    .word .tlanslbl { display: block; padding: 16px 22px 0; }
    .word .trow { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; padding: 12px 22px 4px; }
    .word .pill { font-size: 12px; font-weight: 500; padding: 8px 14px; border-radius: 999px; border: 1px solid var(--line2); color: var(--text); background: transparent; cursor: pointer; transition: background .2s, color .2s, border-color .2s, transform .16s; font-family: inherit; }
    .word .pill.on { background: var(--gold); border-color: var(--gold); color: #22382E; }
    @media (hover: hover) { .word .pill:hover { transform: translateY(-1px); border-color: var(--line); } }

    .word .seg { display: flex; gap: 4px; margin: 14px 22px 0; padding: 4px; background: var(--field); border-radius: 999px; }
    .word .seg button { flex: 1; border: 0; background: transparent; font-family: inherit; font-size: 13px; font-weight: 500; color: var(--muted); padding: 9px; border-radius: 999px; cursor: pointer; transition: .2s; }
    .word .seg button.on { background: var(--surface); color: var(--text); box-shadow: var(--card-shadow); }

    .word .grp { padding: 22px 22px 0; }
    .word .grphead { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 12px; }
    .word .grptitle { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; color: var(--text); }
    .word .grpsub { font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: var(--goldd); font-weight: 500; }
    .word .books { display: flex; flex-direction: column; gap: 10px; }
    .word .book { display: flex; align-items: center; gap: 14px; padding: 15px 16px; background: var(--surface); border-radius: 16px; box-shadow: var(--card-shadow); cursor: pointer; border: 0; width: 100%; text-align: left; font-family: inherit; transition: transform .25s; }
    @media (hover: hover) { .word .book:hover { transform: translateY(-3px); } }
    .word .book .bmain { flex: 1; min-width: 0; }
    .word .book .bname { display: block; font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 600; color: var(--text); line-height: 1.1; }
    .word .book .bdesc { display: block; font-size: 12.5px; color: var(--muted); margin-top: 3px; }
    .word .book .bchap { display: block; font-size: 11px; color: var(--text2); margin-top: 5px; opacity: .8; }
    .word .book .chev { flex: 0 0 auto; color: var(--goldd); display: flex; }
    .word .book .chev svg { width: 18px; height: 18px; }
    .word .foot-sp { height: 26px; }

    .word .searchhint { padding: 14px 22px 0; }
    .word .shitem, .w-reader .shitem { display: flex; align-items: center; gap: 12px; padding: 13px 16px; background: var(--surface); border-radius: 14px; box-shadow: var(--card-shadow); cursor: pointer; border: 0; width: 100%; text-align: left; font-family: inherit; margin-bottom: 9px; transition: transform .2s; }
    @media (hover: hover) { .word .shitem:hover, .w-reader .shitem:hover { transform: translateY(-2px); } }
    .word .shitem .shref, .w-reader .shitem .shref { display: block; font-size: 11px; color: var(--goldd); font-weight: 600; letter-spacing: .04em; flex: 0 0 auto; }
    .word .shitem .shlabel, .w-reader .shitem .shlabel { display: block; font-family: 'Cormorant Garamond', serif; font-size: 16px; color: var(--text); }
    .word .searchnote { padding: 8px 26px 0; font-size: 10.5px; line-height: 1.55; color: var(--muted); }
    .word .vp-loading, .w-reader .rs-results .vp-loading { padding: 18px 22px; color: var(--muted); font-size: 14px; }

    /* in-reader search: animated magnifier + sheet/modal field */
    /* Equal-weight side clusters so the book title centers on the viewport, not on the gap. */
    .w-reader .rh-lead { flex: 1; display: flex; align-items: center; justify-content: flex-start; }
    .w-reader .rh-actions { flex: 1; display: flex; align-items: center; justify-content: flex-end; gap: 2px; }
    .w-reader .rsglass svg { transition: transform .34s var(--ease-reveal, cubic-bezier(.16, 1, .3, 1)); }
    @media (hover: hover) { .w-reader .rsglass:hover svg { transform: scale(1.14) rotate(-8deg); color: var(--goldd); } }
    .w-reader .rsglass:active svg { transform: scale(.92); }
    .w-reader .rs-search { display: flex; flex-direction: column; max-height: 76vh; }
    .w-reader .rs-field { display: flex; align-items: center; gap: 11px; margin: 2px 0 12px; padding: 13px 16px; background: var(--field); border: 1px solid var(--line2); border-radius: 14px; }
    .w-reader .rs-field svg { flex: 0 0 auto; width: 17px; height: 17px; color: var(--goldd); }
    .w-reader .rs-field input { flex: 1; border: 0; background: transparent; outline: none; font-family: inherit; font-size: 14.5px; color: var(--text); }
    .w-reader .rs-field input::placeholder { color: var(--muted); }
    .w-reader .rs-results { flex: 1; min-height: 120px; overflow-y: auto; scrollbar-width: none; margin: 0 -4px; padding: 0 4px; }
    .w-reader .rs-results::-webkit-scrollbar { display: none; }

    /* ===== reader overlay ===== */
    .w-reader { position: fixed; inset: 0; z-index: 40; background: var(--bgfield); display: none; flex-direction: column; }
    .w-reader.open { display: flex; }
    .w-reader .topglow { position: absolute; top: 0; left: 0; right: 0; height: 280px; z-index: 0; pointer-events: none;
      background: radial-gradient(120% 90% at 50% -10%, var(--topglow), transparent 60%); }
    .w-reader .rtop { position: relative; z-index: 2; }
    .w-reader .rhead { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 14px 18px 2px; }
    .w-reader .iconbtn { width: 38px; height: 38px; border-radius: 50%; border: 0; background: transparent; color: var(--text); cursor: pointer; display: flex; align-items: center; justify-content: center; }
    .w-reader .iconbtn svg { width: 20px; height: 20px; }
    .w-reader .rbook { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; color: var(--text); text-align: center; flex: 0 1 auto; min-width: 0; background: none; border: 0; cursor: pointer; padding: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .w-reader .rsub { text-align: center; font-size: 11px; letter-spacing: .06em; color: var(--goldd); padding-bottom: 6px; }
    .w-reader .rscroll { position: relative; z-index: 1; flex: 1; min-height: 0; overflow-y: auto; scrollbar-width: none; }
    .w-reader .rscroll::-webkit-scrollbar { display: none; }

    .w-reader .chappick { padding: 10px 22px 30px; }
    .w-reader .picklbl { font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--goldd); font-weight: 500; margin: 8px 2px 14px; }
    .w-reader .versepick { padding: 10px 22px 30px; }
    .w-reader .vp-all { display: flex; align-items: center; justify-content: center; gap: 9px; width: 100%; padding: 14px; margin: 2px 0 18px; border: 0; cursor: pointer;
      background: var(--cta); color: var(--ctatext); border-radius: 14px; font-family: inherit; font-size: 14.5px; font-weight: 600; box-shadow: 0 10px 24px -10px rgba(201, 168, 76, .5); transition: filter .2s ease, transform .16s ease; }
    .w-reader .vp-all:hover { filter: brightness(1.04); }
    .w-reader .vp-all:active { transform: translateY(1px); }
    .w-reader .vp-all svg { width: 16px; height: 16px; }
    .w-reader .vp-loading { padding: 18px 2px; color: var(--muted); font-size: 14px; }
    .w-reader .chapgrid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; }
    .w-reader .chaptile { position: relative; aspect-ratio: 1/1; border-radius: 14px; border: 1px solid var(--line2); background: var(--surface); box-shadow: var(--card-shadow); color: var(--text); font-family: 'Cormorant Garamond', serif; font-size: 19px; font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: transform .2s, background .2s, color .2s; }
    @media (hover: hover) { .w-reader .chaptile:hover { transform: translateY(-2px); } }
    .w-reader .chaptile.has::after { content: ''; position: absolute; bottom: 7px; left: 50%; transform: translateX(-50%); width: 4px; height: 4px; border-radius: 50%; background: var(--gold); box-shadow: 0 0 7px rgba(216, 184, 95, .7); }

    .w-reader .readctl { display: flex; align-items: center; justify-content: center; gap: 12px; padding: 6px 18px 10px; }
    .w-reader .navchap { width: 38px; height: 38px; border-radius: 11px; border: 1px solid var(--line2); background: transparent; color: var(--text); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: .2s; }
    .w-reader .navchap svg { width: 18px; height: 18px; }
    .w-reader .navchap:disabled { opacity: .32; cursor: default; }
    .w-reader .chaplabel { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; color: var(--text); background: var(--field); border: 1px solid var(--line2); border-radius: 12px; padding: 9px 18px; cursor: pointer; display: inline-flex; align-items: center; gap: 9px; }
    .w-reader .chaplabel svg { width: 13px; height: 13px; color: var(--goldd); }

    .w-reader .rtrans { display: flex; align-items: center; gap: 8px; padding: 0 18px 12px; flex-wrap: wrap; }
    .w-reader .rtrans .rt { font-size: 11px; font-weight: 600; letter-spacing: .06em; padding: 6px 12px; border-radius: 999px; border: 1px solid var(--line2); color: var(--muted); background: transparent; cursor: pointer; font-family: inherit; }
    .w-reader .rtrans .rt.on { background: rgba(216, 184, 95, .16); color: var(--text); border-color: rgba(216, 184, 95, .4); }
    .w-reader .rtrans .compare { margin-left: auto; font-size: 11px; font-weight: 600; letter-spacing: .04em; color: var(--goldd); background: none; border: 0; cursor: pointer; display: flex; align-items: center; gap: 6px; font-family: inherit; }
    .w-reader .rtrans .compare svg { width: 14px; height: 14px; }
    .w-reader .rtrans .compare.on { color: var(--text); }
    .w-reader .aabtn { margin-left: auto; border: 1px solid var(--line2); background: transparent; color: var(--text); border-radius: 10px; min-width: 38px; height: 34px; cursor: pointer; font-family: 'Cormorant Garamond', serif; font-size: 16px; font-weight: 600; padding: 0 9px; }
    .w-reader .transsel { display: inline-flex; align-items: center; gap: 7px; font-size: 12px; font-weight: 600; letter-spacing: .04em; color: var(--text); background: var(--field); border: 1px solid var(--line2); border-radius: 999px; padding: 8px 14px; cursor: pointer; font-family: inherit; }
    .w-reader .transsel svg { width: 13px; height: 13px; color: var(--goldd); }

    .w-reader .rbody { padding: 6px 22px 24px; }
    /* reading typography — Cormorant at a generous size, calm leading, roomy verses */
    .w-reader .vrse { display: flex; gap: 12px; margin-bottom: 17px; }
    .w-reader .vrse .vn { flex: 0 0 auto; font-size: 10.5px; color: var(--goldd); font-weight: 600; width: 19px; text-align: right; padding-top: 8px; opacity: .85; }
    .w-reader .vrse .vt { flex: 1; font-family: 'Cormorant Garamond', serif; font-size: 21px; line-height: 1.58; letter-spacing: .005em; color: var(--text); padding: 2px 8px; border-radius: 8px; cursor: pointer; transition: background .25s ease; }
    @media (hover: hover) { .w-reader .vrse:not(.hl):not(.sel) .vt:hover { background: color-mix(in srgb, var(--text) 4%, transparent); } }
    .w-reader .vrse.flash .vt { animation: vflash 2s ease; }
    @keyframes vflash { 0%, 30% { background: rgba(216, 184, 95, .3); } 100% { background: transparent; } }
    .w-reader .vrse.sel .vt { box-shadow: 0 0 0 2px rgba(216, 184, 95, .55); }
    .w-reader .vrse.hl .vt, .w-reader .pverse.hl { background: rgba(216, 184, 95, .2); }  /* gold = default + legacy */
    .w-reader .vrse.hl[data-hlc='rose'] .vt,  .w-reader .pverse.hl[data-hlc='rose']  { background: rgba(226, 150, 170, .26); }
    .w-reader .vrse.hl[data-hlc='sky'] .vt,   .w-reader .pverse.hl[data-hlc='sky']   { background: rgba(140, 180, 224, .26); }
    .w-reader .vrse.hl[data-hlc='mint'] .vt,  .w-reader .pverse.hl[data-hlc='mint']  { background: rgba(150, 205, 172, .26); }
    .w-reader .vrse.hl[data-hlc='lilac'] .vt, .w-reader .pverse.hl[data-hlc='lilac'] { background: rgba(190, 160, 224, .26); }
    /* a touch more presence over the cream (light) background */
    html[data-theme="light"] .w-reader .vrse.hl[data-hlc='rose'] .vt  { background: rgba(220, 120, 150, .32); }
    html[data-theme="light"] .w-reader .vrse.hl[data-hlc='sky'] .vt   { background: rgba(110, 160, 220, .30); }
    html[data-theme="light"] .w-reader .vrse.hl[data-hlc='mint'] .vt  { background: rgba(110, 190, 150, .30); }
    html[data-theme="light"] .w-reader .vrse.hl[data-hlc='lilac'] .vt { background: rgba(170, 140, 220, .30); }
    .w-reader .vrse.hl-land .vt { background: rgba(216, 184, 95, .18); }
    /* highlight color palette in the action bar */
    .w-reader .hlpalette { display: flex; gap: 14px; justify-content: center; align-items: center; padding: 2px 0 12px; }
    .w-reader .hlpalette[hidden] { display: none; }
    .w-reader .hlsw { width: 30px; height: 30px; border: 0; border-radius: 50%; padding: 0; cursor: pointer; box-shadow: inset 0 0 0 1px rgba(255, 255, 255, .22); transition: transform .14s ease; }
    .w-reader .hlsw:active { transform: scale(.88); }
    .w-reader .hlsw.on { outline: 2px solid rgba(255, 255, 255, .9); outline-offset: 2px; }
    .w-reader .hlsw.c-gold { background: #C9A84C; }
    .w-reader .hlsw.c-rose { background: #E29CB0; }
    .w-reader .hlsw.c-sky { background: #9CC0E6; }
    .w-reader .hlsw.c-mint { background: #A6D4AC; }
    .w-reader .hlsw.c-lilac { background: #C2A8E0; }
    .w-reader .hlsw-none { background: transparent; box-shadow: inset 0 0 0 1.5px var(--muted); color: var(--muted); display: inline-flex; align-items: center; justify-content: center; }
    .w-reader .hlsw-none svg { width: 16px; height: 16px; }

    .w-reader .pcols { display: grid; gap: 14px; }
    .w-reader .pverse { border-top: 1px solid var(--line); padding: 13px 7px 5px; border-radius: 8px; cursor: pointer; }
    .w-reader .pverse.flash { animation: vflash 2s ease; }
    .w-reader .pverse.sel { box-shadow: 0 0 0 2px rgba(216, 184, 95, .45); }
    .w-reader .pverse .pn { font-size: 11px; color: var(--goldd); font-weight: 600; margin-bottom: 8px; }
    .w-reader .pgrid { display: grid; gap: 12px; }
    .w-reader .pcell .pcl { font-size: 9px; letter-spacing: .16em; text-transform: uppercase; color: var(--muted); margin-bottom: 4px; }
    .w-reader .pcell .pcx { font-family: 'Cormorant Garamond', serif; font-size: 16px; line-height: 1.42; color: var(--text); }

    .w-reader .rcopyright { max-width: 680px; margin: 6px auto 0; padding: 10px 26px 18px; font-size: 10.5px; line-height: 1.55; color: var(--muted); }
    .w-reader .rcopyright div { margin-top: 6px; }

    .w-reader .rsoon { text-align: center; padding: 40px 18px; }
    .w-reader .rsoon .ri { width: 46px; height: 46px; margin: 0 auto 14px; border-radius: 50%; background: var(--field); display: flex; align-items: center; justify-content: center; color: var(--goldd); }
    .w-reader .rsoon .ri svg { width: 21px; height: 21px; }
    .w-reader .rsoon .rt2 { font-family: 'Cormorant Garamond', serif; font-size: 20px; color: var(--text); }
    .w-reader .rsoon .rd { font-size: 13px; color: var(--muted); margin-top: 7px; line-height: 1.5; max-width: 32ch; margin-left: auto; margin-right: auto; }

    .w-reader .rloading { padding: 8px 0; }
    .w-reader .shrow { display: flex; gap: 11px; margin-bottom: 16px; align-items: flex-start; }
    .w-reader .shn { flex: 0 0 auto; width: 14px; height: 12px; border-radius: 4px; background: var(--field); margin-top: 5px; }
    .w-reader .shl { flex: 1; height: 16px; border-radius: 8px; background: linear-gradient(90deg, var(--field), rgba(216, 184, 95, .14), var(--field)); background-size: 200% 100%; animation: shim 1.3s ease-in-out infinite; }
    @keyframes shim { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

    /* in-reader tab bar (design): relative at the reader's foot on mobile */
    .w-reader .tabbar { position: relative !important; left: auto !important; right: auto !important; bottom: auto !important; z-index: 3; flex: 0 0 auto; }

    /* verse jump overlay */
    .w-reader .vjump { position: absolute; inset: 0; z-index: 42; display: none; }
    .w-reader .vjump.open { display: block; }
    .w-reader .vjback { position: absolute; inset: 0; background: rgba(0, 0, 0, .42); backdrop-filter: blur(2px); }
    .w-reader .vjsheet { position: absolute; left: 0; right: 0; bottom: 0; background: var(--surface); border-radius: 24px 24px 0 0; padding: 10px 20px calc(24px + env(safe-area-inset-bottom)); max-height: 72%; overflow-y: auto; box-shadow: 0 -20px 50px -18px rgba(0, 0, 0, .5); scrollbar-width: none; }
    .w-reader .vjsheet::-webkit-scrollbar { display: none; }
    .w-reader .vjtitle { text-align: center; font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 600; color: var(--text); margin: 8px 0 16px; }
    .w-reader .vjgrid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 9px; }
    .w-reader .vjtile { aspect-ratio: 1/1; border-radius: 11px; border: 1px solid var(--line2); background: transparent; color: var(--text); font-size: 14px; font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: .15s; }
    .w-reader .vjtile:hover { background: var(--field); }

    /* verse action bar */
    .w-reader .vbar { position: absolute; left: 10px; right: 10px; bottom: 96px; background: var(--surface); border-radius: 22px; box-shadow: 0 -18px 50px -18px rgba(0, 0, 0, .5), var(--card-shadow); padding: 6px 16px 14px; z-index: 41; display: none; touch-action: none; }
    .w-reader .vbar.open { display: block; animation: vbup .28s cubic-bezier(.2, .7, .2, 1); }
    @keyframes vbup { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: none; } }
    .w-reader .vbar .grabber { margin: 6px auto 8px; }
    .w-reader .vbref { font-size: 11px; letter-spacing: .04em; color: var(--goldd); font-weight: 600; text-align: center; padding: 4px 0 9px; }
    .w-reader .vbacts { display: flex; gap: 4px; }
    .w-reader .vbtn { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 5px; padding: 9px 4px; border: 0; background: transparent; color: var(--text); cursor: pointer; border-radius: 12px; font-family: inherit; font-size: 10.5px; transition: background .2s; }
    .w-reader .vbtn:hover { background: var(--field); }
    .w-reader .vbtn svg { width: 19px; height: 19px; color: var(--goldd); }
    .w-reader .vbtn.on svg { color: var(--gold); fill: rgba(216, 184, 95, .25); }

    /* sheets: translation · display · share fallback */
    .w-reader .rsheet { position: absolute; inset: 0; z-index: 43; display: none; }
    .w-reader .rsheet.open { display: block; }
