      for (let i = 1; i <= curChaps; i++) {
        const has = Object.keys(hl).some((k) => k.indexOf(curBook + ' ' + i + ':') === 0);
        h += '<button class="chaptile' + (has ? ' has' : '') + '" data-c="' + i + '">' + i + '</button>';
      }
      chapgrid.innerHTML = h;
      rsub.textContent = curChaps + (esW() ? (curChaps === 1 ? ' capítulo' : ' capítulos') : (curChaps === 1 ? ' chapter' : ' chapters'));
      chapPick.hidden = false; versePick.hidden = true; rbody.hidden = true; rcopyright.hidden = true;
      readctl.hidden = true; rtrans.hidden = true; verseJump.style.visibility = 'hidden';
