      hintEl.innerHTML = local + '<div class="sh-api"><div class="vp-loading">' + (esW() ? 'Buscando en la Palabra…' : 'Searching the Word&hellip;') + '</div></div>';
      if (noteEl) { noteEl.style.display = 'none'; }
      fetch(WORKER + '/bible/search?translation=' + readT + '&q=' + encodeURIComponent(q))
        .then((r) => (r.ok ? r.json() : null))
        .then((j) => {
          if (myReq !== reqRef.n) return;
          const api = hintEl.querySelector('.sh-api'); if (!api) return;
          if (!j || !j.results) { api.innerHTML = local ? '' : '<div class="vp-loading">' + (esW() ? 'La búsqueda no está disponible ahora.' : 'Search is unavailable right now.') + '</div>'; return; }
          if (!j.results.length) {
            api.innerHTML = local ? '' : (esW() ? ('<div class="vp-loading">Nada encontrado para &ldquo;' + esc(q) + '&rdquo; en ' + esc(j.translation) + '. Prueba una referencia como &ldquo;Salmos 21&rdquo; o una frase como &ldquo;agua en vino&rdquo;.</div>') : ('<div class="vp-loading">Nothing found for &ldquo;' + esc(q) + '&rdquo; in ' + esc(j.translation) + '. Try a reference like &ldquo;Psalms 21&rdquo; or a phrase like &ldquo;water into wine&rdquo;.</div>'));
            return;
          }
          const base = hintEl.querySelectorAll('.shitem').length;
          api.innerHTML = j.results.map((r, i) => {
            const txt = r.text.replace(/¶\s*/g, '');
            return shitemHTML(base + i, r.book, r.chapter, r.verse, r.ref, txt.length > 90 ? txt.slice(0, 90) + '…' : txt);
          }).join('');
          if (noteEl && j.copyright) { noteEl.textContent = j.copyright; noteEl.style.display = 'block'; }
          if (j.fumsToken) fireFums(j.fumsToken); // copyrighted snippets are a licensed display
        })
        .catch(() => {
