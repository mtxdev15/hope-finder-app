      const tr = el.getBoundingClientRect(), cr = rscroll.getBoundingClientRect();
      rscroll.scrollTo({ top: rscroll.scrollTop + (tr.top - cr.top) - 90, behavior: opts.smooth ? 'smooth' : 'auto' });
