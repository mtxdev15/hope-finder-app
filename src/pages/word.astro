    /* library search */
    const sInput = $('searchInput'), sHint = $('searchHint'), sNote = $('searchNote');
    let sTimer = null; const sReq = { n: 0 };
    function clearSearch() { sHint.style.display = 'none'; sHint.innerHTML = ''; sNote.style.display = 'none'; groupsEl.style.display = ''; }
