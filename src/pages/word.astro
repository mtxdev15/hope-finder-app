---
// /word — The Word. SURFACE rebuilt verbatim from design-source-v3.2/declare/TheWord.html
// (library: THE LIBRARY header, Scripture search, DEFAULT TRANSLATION pills, OT/NT toggle;
// reader: chapter grid → verse picker → reading, translation/Aa/Compare row, display sheet,
// verse action bar with Highlight/Save/Copy/Share, verse-jump, in-reader tab bar).
// MACHINERY: the Cloudflare Worker /bible + /bible/search routes (API.Bible key server-side;
// public-domain cached, copyrighted live + FUMS + copyright line) and vault-store.js
// (device-local saves). One persisted translation: 'declare-reader-translation'.
import DeclareLayout from '../layouts/DeclareLayout.astro';
import TabBar from '../components/TabBar.astro';
import { DB_BIBLE } from '../data/bible.js';
import { USFM } from '../data/usfm.js';

const sections = [
  { testament: 'OT', groups: DB_BIBLE.OT.groups },
  { testament: 'NT', groups: DB_BIBLE.NT.groups },
];
const chev = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>`;
---
<DeclareLayout
  title="Declare — The Word"
  description="Read and search the Bible — free and ad-free, in six translations."
  activeTab="word"
>
  <main class="word">
    <div class="topglow" aria-hidden="true"></div>

    {/* ================= LIBRARY (design: browse view) ================= */}
    <div class="w-col" id="browse">
      <div class="whead">
        <span class="wlbl">The library</span>
        <a class="gear" href="/you" aria-label="Reader settings"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="7" x2="20" y2="7"></line><line x1="4" y1="17" x2="20" y2="17"></line><circle cx="9" cy="7" r="2.4"></circle><circle cx="15" cy="17" r="2.4"></circle></svg></a>
      </div>
      <div class="wtitle">The Word</div>

      <form class="search" id="searchForm" autocomplete="off">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.5" y2="16.5"></line></svg>
        <input id="searchInput" placeholder="Search Scripture — try &ldquo;water into wine&rdquo;" aria-label="Search Scripture" />
      </form>

      <div class="wlbl tlanslbl">Default translation</div>
      <div class="trow" id="pills">
        <button class="pill" data-t="kjv">KJV</button>
        <button class="pill" data-t="web">WEB</button>
        <button class="pill" data-t="asv">ASV</button>
        <button class="pill" data-t="nkjv">NKJV</button>
        <button class="pill" data-t="niv">NIV</button>
        <button class="pill" data-t="nlt">NLT</button>
      </div>

      <div class="seg" id="testament">
        <button data-t="OT">Old Testament</button>
        <button class="on" data-t="NT">New Testament</button>
      </div>

      <div class="wscroll" id="browseScroll">
        <div class="searchhint" id="searchHint" style="display:none"></div>
        <div class="searchnote" id="searchNote" style="display:none"></div>
        <div id="groups">
          {sections.map((sec) => (
            <div class="tsec" data-test={sec.testament} style={sec.testament === 'OT' ? 'display:none' : ''}>
              {sec.groups.map((g) => (
                <section class="grp m-rise">
                  <div class="grphead">
                    <span class="grptitle">{g.title}</span>
                    <span class="grpsub">{g.books.length} {g.books.length === 1 ? 'BOOK' : 'BOOKS'}</span>
                  </div>
                  <div class="books">
                    {g.books.map((b) => (
                      <button class="book" data-usfm={USFM[b.name]} data-chaps={b.chapters} data-name={b.name}>
                        <span class="bmain">
                          <span class="bname">{b.name}</span>
                          {b.tag && <span class="bdesc">{b.tag}</span>}
                          <span class="bchap">{b.chapters} {b.chapters === 1 ? 'chapter' : 'chapters'}</span>
                        </span>
                        <span class="chev" set:html={chev} />
                      </button>
                    ))}
                  </div>
                </section>
              ))}
            </div>
          ))}
        </div>
        <div class="foot-sp"></div>
      </div>
    </div>

    {/* ================= READER (design: reader view) ================= */}
    <div class="w-reader" id="reader">
      <div class="topglow" aria-hidden="true"></div>
      <div class="rtop">
        <div class="rhead">
          <button class="iconbtn" id="readerBack" aria-label="Back"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 5l-7 7 7 7"></path></svg></button>
          <button class="rbook" id="rbook" aria-label="Back to the library">John</button>
          <button class="iconbtn" id="verseJump" aria-label="Jump to a verse" style="visibility:hidden"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><line x1="9" y1="6" x2="20" y2="6"></line><line x1="9" y1="12" x2="20" y2="12"></line><line x1="9" y1="18" x2="20" y2="18"></line><circle cx="4.5" cy="6" r="1.3" fill="currentColor" stroke="none"></circle><circle cx="4.5" cy="12" r="1.3" fill="currentColor" stroke="none"></circle><circle cx="4.5" cy="18" r="1.3" fill="currentColor" stroke="none"></circle></svg></button>
        </div>
        <div class="rsub" id="rsub">21 chapters</div>
        <div class="readctl" id="readctl" hidden>
          <button class="navchap" id="prevChap" aria-label="Previous chapter"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M15 5l-7 7 7 7"></path></svg></button>
          <button class="chaplabel" id="chapLabel"><span id="chapLabelText">Chapter 1</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"></path></svg></button>
          <button class="navchap" id="nextChap" aria-label="Next chapter"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5l7 7-7 7"></path></svg></button>
        </div>
        <div class="rtrans" id="rtrans" hidden></div>
      </div>
      <div class="rscroll" id="rscroll">
        <div class="chappick" id="chapPick">
          <div class="picklbl">Choose a chapter</div>
          <div class="chapgrid" id="chapgrid"></div>
        </div>
        <div class="versepick" id="versePick" hidden>
          <button class="vp-all" id="readAll">Read the whole chapter <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></button>
          <div class="picklbl">Or jump to a verse</div>
          <div class="chapgrid" id="versegrid"></div>
        </div>
        <div class="rbody" id="rbody" hidden></div>
        <div class="rcopyright" id="rcopyright" hidden></div>
      </div>

      {/* in-reader tab bar (design): jump to any section without backing out */}
      <TabBar active="word" />

      <div class="vjump" id="vjump">
        <div class="vjback" id="vjback"></div>
        <div class="vjsheet">
          <div class="grabber"></div>
          <div class="vjtitle">Jump to a verse</div>
          <div class="vjgrid" id="vjgrid"></div>
        </div>
      </div>

      {/* verse action bar */}
      <div class="vbar" id="vbar">
        <div class="grabber"></div>
        <div class="vbref" id="vbref">Verse</div>
        <div class="vbacts">
          <button class="vbtn" id="vbHl"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16"></path><path d="M6.5 16.5L14 9l3 3-7.5 7.5H6.5z"></path><path d="M14 9l2.5-2.5a1.6 1.6 0 0 1 2.3 0l.7.7a1.6 1.6 0 0 1 0 2.3L17 12"></path></svg><span>Highlight</span></button>
          <button class="vbtn" id="vbSave"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4.5h12v15l-6-4-6 4z"></path></svg><span>Save</span></button>
          <button class="vbtn" id="vbCopy"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="11" height="11" rx="2"></rect><path d="M5 15V5a2 2 0 0 1 2-2h10"></path></svg><span>Copy</span></button>
          <button class="vbtn" id="vbShare"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v7a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-7"></path><path d="M12 3v13M8 7l4-4 4 4"></path></svg><span>Share</span></button>
          <button class="vbtn" id="vbClose"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"></path></svg><span>Close</span></button>
        </div>
      </div>

      {/* translation menu */}
      <div class="rsheet" id="tmenu">
        <div class="rsback"></div>
        <div class="rspanel"><div class="grabber"></div><div class="rstitle">Translation</div><div id="tmlist"></div></div>
      </div>

      {/* display sheet */}
      <div class="rsheet" id="dsheet">
        <div class="rsback"></div>
        <div class="rspanel">
          <div class="grabber"></div>
          <div class="rstitle">Display</div>
          <div class="dspreview" id="dsPreview">For God so loved the world that he gave his only Son.</div>
          <div class="dssec">
            <div class="dslbl">Brightness</div>
            <div class="bright">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 6.5V6M6.5 12H6M12 17.5v.5M17.5 12h.5"></path></svg>
              <input type="range" id="brightRange" min="40" max="100" value="100" aria-label="Brightness" />
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><path d="M12 1.5v2.5M12 20v2.5M1.5 12H4M20 12h2.5M4.5 4.5l1.8 1.8M17.7 17.7l1.8 1.8M19.5 4.5l-1.8 1.8M6.3 17.7l-1.8 1.8"></path></svg>
            </div>
          </div>
          <div class="dssec">
            <div class="dslbl">Text size</div>
            <div class="dsseg" id="sizeSeg">
              <button class="sz1" data-s="Small">A</button>
              <button class="sz2 on" data-s="Medium">A</button>
              <button class="sz3" data-s="Large">A</button>
            </div>
          </div>
          <div class="dssec">
            <div class="dslbl">Font style</div>
            <div class="dsseg" id="fontSeg">
              <button class="ff-cormorant on" data-f="cormorant">Cormorant</button>
              <button class="ff-lora" data-f="lora">Lora</button>
              <button class="ff-sans" data-f="sans">DM&nbsp;Sans</button>
            </div>
          </div>
        </div>
      </div>

      {/* share sheet (fallback when the Card Studio stack is unavailable) */}
      <div class="rsheet" id="sharesheet">
        <div class="rsback"></div>
        <div class="rspanel">
          <div class="grabber"></div>
          <div class="rstitle">Share this verse</div>
          <div class="sharprev" id="sharePrev"></div>
          <button class="sopt" id="shSystem"><span class="si"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v7a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-7"></path><path d="M12 3v13M8 7l4-4 4 4"></path></svg></span><span class="sl">Share via&hellip;</span><span class="sc" set:html={chev} /></button>
          <button class="sopt" id="shCopy"><span class="si"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="11" height="11" rx="2"></rect><path d="M5 15V5a2 2 0 0 1 2-2h10"></path></svg></span><span class="sl">Copy verse</span><span class="sc" set:html={chev} /></button>
        </div>
      </div>

      <div class="dim" id="dim" aria-hidden="true"></div>
      <div class="wtoast" id="wtoast"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"></path></svg><span id="wtoastMsg"></span></div>
    </div>
  </main>

  <script>
    import { saveItem, removeItem, isSaved } from '../app/declare/vault-store.js';

    const WORKER = 'https://hope-finder-worker.thinktoro.workers.dev';
    const $ = (id) => document.getElementById(id);
    const esc = (s) => (s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

    /* one source of truth for the default translation (library pills + reader) */
    const TRANSLATIONS = [
      { id: 'kjv', label: 'KJV', name: 'King James Version' },
      { id: 'web', label: 'WEB', name: 'World English Bible' },
      { id: 'asv', label: 'ASV', name: 'American Standard Version' },
      { id: 'nkjv', label: 'NKJV', name: 'New King James Version' },
      { id: 'niv', label: 'NIV', name: 'New International Version (2011)' },
      { id: 'nlt', label: 'NLT', name: 'New Living Translation' },
    ];
    const byId = (id) => TRANSLATIONS.find((t) => t.id === id);
    const byLabel = (l) => TRANSLATIONS.find((t) => t.label === l);
    let readT = (() => { try { const t = localStorage.getItem('declare-reader-translation'); return byId(t) ? t : 'web'; } catch (e) { return 'web'; } })();
    function setReadT(id) { readT = id; try { localStorage.setItem('declare-reader-translation', id); } catch (e) {} paintPills(); }

    /* ---------- library: pills · testament · groups ---------- */
    const pills = $('pills');
    function paintPills() { pills.querySelectorAll('.pill').forEach((p) => p.classList.toggle('on', p.dataset.t === readT)); }
    pills.addEventListener('click', (e) => {
      const p = e.target.closest('.pill'); if (!p) return;
      setReadT(p.dataset.t);
    });

    const seg = $('testament');
    seg.addEventListener('click', (e) => {
      const b = e.target.closest('button'); if (!b) return;
      seg.querySelectorAll('button').forEach((x) => x.classList.remove('on'));
      b.classList.add('on');
      document.querySelectorAll('.tsec').forEach((s) => { s.style.display = s.dataset.test === b.dataset.t ? '' : 'none'; });
      if (window.DeclareMotion) window.DeclareMotion.reveal($('groups'), { stagger: 60 });
    });

    const groupsEl = $('groups');
    groupsEl.addEventListener('click', (e) => {
      const bk = e.target.closest('.book'); if (!bk) return;
      openReader(bk.dataset.name, bk.dataset.usfm, parseInt(bk.dataset.chaps, 10));
    });
    function bookByName(name) {
      const n = (name || '').toLowerCase();
      return [...document.querySelectorAll('.book')].find((b) => (b.dataset.name || '').toLowerCase() === n) || null;
    }

    /* ---------- library: real Scripture search (Worker /bible/search) ---------- */
    const sInput = $('searchInput'), sHint = $('searchHint'), sNote = $('searchNote');
    let sTimer = null, sReq = 0;
    function clearSearch() { sHint.style.display = 'none'; sHint.innerHTML = ''; sNote.style.display = 'none'; groupsEl.style.display = ''; }
    function runSearch(q) {
      const myReq = ++sReq;
      sHint.style.display = 'block'; groupsEl.style.display = 'none'; sNote.style.display = 'none';
      sHint.innerHTML = '<div class="vp-loading">Searching the Word&hellip;</div>';
      fetch(WORKER + '/bible/search?translation=' + readT + '&q=' + encodeURIComponent(q))
        .then((r) => (r.ok ? r.json() : null))
        .then((j) => {
          if (myReq !== sReq) return;
          if (!j || !j.results) { sHint.innerHTML = '<div class="vp-loading">Search is unavailable right now.</div>'; return; }
          if (!j.results.length) { sHint.innerHTML = '<div class="vp-loading">Nothing found for &ldquo;' + esc(q) + '&rdquo; in ' + esc(j.translation) + '.</div>'; return; }
          sHint.innerHTML = j.results.map((r, i) => {
            const txt = r.text.replace(/¶\s*/g, ''); // KJV paragraph marks (chapter route strips these server-side)
            return '<button class="shitem" style="animation-delay:' + (i * 34) + 'ms" data-book="' + esc(r.book) + '" data-chapter="' + r.chapter + '" data-verse="' + r.verse + '">'
              + '<span class="shref">' + esc(r.ref) + '</span><span class="shlabel">' + esc(txt.length > 90 ? txt.slice(0, 90) + '…' : txt) + '</span></button>';
          }).join('');
          if (j.copyright) { sNote.textContent = j.copyright; sNote.style.display = 'block'; }
          if (j.fumsToken) fireFums(j.fumsToken); // copyrighted snippets are a licensed display
        })
        .catch(() => { if (myReq === sReq) sHint.innerHTML = '<div class="vp-loading">Search is unavailable right now.</div>'; });
    }
    sInput.addEventListener('input', function () {
      const q = this.value.trim();
      clearTimeout(sTimer);
      if (q.length < 3) { clearSearch(); return; }
      sTimer = setTimeout(() => runSearch(q), 320);
    });
    $('searchForm').addEventListener('submit', (e) => {
      e.preventDefault();
      const q = sInput.value.trim();
      if (q.length >= 3) { clearTimeout(sTimer); runSearch(q); }
    });
    sHint.addEventListener('click', (e) => {
      const it = e.target.closest('.shitem'); if (!it) return;
      const btn = bookByName(it.dataset.book); if (!btn) return;
      openReader(btn.dataset.name, btn.dataset.usfm, parseInt(btn.dataset.chaps, 10));
      readChapter(parseInt(it.dataset.chapter, 10), parseInt(it.dataset.verse, 10) || null);
    });

    /* ---------- FUMS (required view tracking for copyrighted text) ---------- */
    let fumsReady = false, fumsLoading = false, fumsQueue = [];
    function loadFums() {
      if (fumsReady || fumsLoading) return;
      fumsLoading = true;
      const s = document.createElement('script');
      s.src = 'https://pkg.api.bible/fumsV3.min.js'; s.async = true;
      s.onload = () => { fumsReady = true; fumsQueue.forEach(trackView); fumsQueue = []; };
      document.head.appendChild(s);
    }
    function trackView(token) { try { if (window.fums) window.fums('trackView', token); } catch (e) {} }
    function fireFums(token) {
      if (!token) return;
      if (fumsReady && window.fums) { trackView(token); return; }
      fumsQueue.push(token); loadFums();
    }

    /* ---------- chapter fetch (Worker /bible; payload-driven cache) ---------- */
    const CACHE = {};
    function fetchChapter(usfm, chap, transId) {
      const key = transId + ':' + usfm + '.' + chap;
      if (CACHE[key]) return Promise.resolve(CACHE[key]);
      const url = WORKER + '/bible?translation=' + transId + '&book=' + encodeURIComponent(usfm) + '&chapter=' + chap;
      return fetch(url).then((r) => (r.ok ? r.json() : null)).then((j) => {
        if (!j || !j.verses) return null;
        if (!j.fumsToken) CACHE[key] = j; // public-domain only; copyrighted always refetches live
        return j;
      }).catch(() => null);
    }

    /* ---------- reader state ---------- */
    const reader = $('reader'), rbook = $('rbook'), rsub = $('rsub'),
      chapgrid = $('chapgrid'), chapPick = $('chapPick'),
      versePick = $('versePick'), versegrid = $('versegrid'),
      rscroll = $('rscroll'), rbody = $('rbody'), rcopyright = $('rcopyright'),
      readctl = $('readctl'), rtrans = $('rtrans'),
      chapLabelText = $('chapLabelText'), prevChapBtn = $('prevChap'), nextChapBtn = $('nextChap'),
      verseJump = $('verseJump'), vjump = $('vjump'), vjgrid = $('vjgrid');

    let curBook = 'John', curUsfm = 'JHN', curChaps = 21, curChap = 1;
    let compare = false, cmpSet = ['KJV', 'WEB'];
    let reqId = 0;

    function openReader(book, usfm, chaps, chap) {
      curBook = book; curUsfm = usfm; curChaps = chaps || 1; compare = false;
      reader.classList.add('open');
      rbook.textContent = book;
      showPicker();
      if (chap) readChapter(chap);
    }
    function closeReader() {
      reader.classList.remove('open');
      closeVbar();
    }
    /* unseen-grade view entrance: soft rise + fade on every reader view swap */
    function enter(el) { el.classList.remove('view-enter'); void el.offsetWidth; el.classList.add('view-enter'); }
    function showPicker() {
      const hl = getHL();
      let h = '';
      for (let i = 1; i <= curChaps; i++) {
        const has = Object.keys(hl).some((k) => k.indexOf(curBook + ' ' + i + ':') === 0);
        h += '<button class="chaptile' + (has ? ' has' : '') + '" data-c="' + i + '">' + i + '</button>';
      }
      chapgrid.innerHTML = h;
      rsub.textContent = curChaps + (curChaps === 1 ? ' chapter' : ' chapters');
      chapPick.hidden = false; versePick.hidden = true; rbody.hidden = true; rcopyright.hidden = true;
      readctl.hidden = true; rtrans.hidden = true; verseJump.style.visibility = 'hidden';
      closeVbar(); rscroll.scrollTop = 0;
      enter(chapPick);
    }
    /* chapter tile → verse picker (design: "Read the whole chapter" + jump grid) */
    function openChapter(ch) {
      curChap = ch;
      chapPick.hidden = true; rbody.hidden = true; rcopyright.hidden = true; versePick.hidden = false;
      readctl.hidden = false; rtrans.hidden = true;
      chapLabelText.textContent = 'Chapter ' + ch;
      prevChapBtn.disabled = ch <= 1; nextChapBtn.disabled = ch >= curChaps;
      verseJump.style.visibility = 'hidden';
      closeVbar(); rscroll.scrollTop = 0;
      enter(versePick);
      versegrid.innerHTML = '<div class="vp-loading">Loading verses&hellip;</div>';
      fetchChapter(curUsfm, ch, readT).then((j) => {
        if (curChap !== ch || versePick.hidden) return;
        if (j && j.verses.length) {
          versegrid.innerHTML = j.verses.map((v) => '<button class="chaptile" data-v="' + v.n + '">' + v.n + '</button>').join('');
        } else {
          versegrid.innerHTML = '<div class="vp-loading">Tap &ldquo;Read the whole chapter&rdquo; to begin.</div>';
        }
      });
    }
    /* reading view (optionally scrolled to a verse) */
    function readChapter(ch, toVerse) {
      curChap = ch;
      chapPick.hidden = true; versePick.hidden = true; rbody.hidden = false;
      readctl.hidden = false; rtrans.hidden = false;
      chapLabelText.textContent = 'Chapter ' + ch;
      prevChapBtn.disabled = ch <= 1; nextChapBtn.disabled = ch >= curChaps;
      closeVbar();
      renderTrans(); renderBody(); rscroll.scrollTop = 0;
      enter(rbody);
      if (toVerse) {
        let tries = 0;
        (function seek() {
          const el = rbody.querySelector('[data-n="' + toVerse + '"]');
          if (el) {
            const tr = el.getBoundingClientRect(), cr = rscroll.getBoundingClientRect();
            rscroll.scrollTo({ top: rscroll.scrollTop + (tr.top - cr.top) - 90, behavior: 'smooth' });
            el.classList.add('hl-land'); el.classList.remove('flash'); void el.offsetWidth; el.classList.add('flash');
            setTimeout(() => el.classList.remove('flash'), 2200);
            return;
          }
