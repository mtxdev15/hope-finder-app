      { q: ['armor of god', 'armour of god'], ref: 'Ephesians 6', label: 'The armor of God' },
      { q: ['love is patient', 'love chapter', 'love is kind'], ref: '1 Corinthians 13', label: 'Love is patient' },
      { q: ['faith chapter', 'by faith', 'hall of faith'], ref: 'Hebrews 11', label: 'By faith' },
      { q: ['sermon on the mount', 'beatitudes', 'blessed are'], ref: 'Matthew 5', label: 'The Sermon on the Mount' },
      { q: ['lords prayer', 'our father'], ref: 'Matthew 6', label: 'The Lord’s Prayer' },
      { q: ['garden of eden', 'adam and eve'], ref: 'Genesis 2', label: 'The garden of Eden' },
      { q: ['crucifixion', 'the cross', 'calvary', 'golgotha'], ref: 'John 19', label: 'The crucifixion' },
      { q: ['pentecost', 'holy spirit came', 'tongues of fire'], ref: 'Acts 2', label: 'Pentecost' },
      { q: ['valley of dry bones', 'dry bones'], ref: 'Ezekiel 37', label: 'The valley of dry bones' },
    ];
    const BOOK_ALIASES = { 'psalm': 'Psalms', 'song of songs': 'Song of Solomon', 'songs of solomon': 'Song of Solomon', 'revelations': 'Revelation' };
    function norm(s) { return s.toLowerCase().replace(/[’'".,!?]/g, '').replace(/\s+/g, ' ').trim(); }
    // "psalms 21", "proverbs 1:5", "1 john 4" -> { btn, chapter?, verse? }
    function parseRefQuery(q) {
      const m = norm(q).match(/^([1-3]?\s?[a-z ]+?)\s*(\d{1,3})?\s*(?:[:.]\s*(\d{1,3}))?$/);
      if (!m || !m[1] || m[1].trim().length < 3) return null;
      const name = m[1].trim();
      const resolved = BOOK_ALIASES[name] || name;
      let btn = bookByName(resolved);
      if (!btn) { // prefix match: "prover" -> Proverbs (unique only)
        const cands = [...document.querySelectorAll('.book')].filter((b) => (b.dataset.name || '').toLowerCase().startsWith(resolved.toLowerCase()));
        if (cands.length === 1) btn = cands[0]; else return null;
      }
      const chaps = parseInt(btn.dataset.chaps, 10);
      const chapter = m[2] ? parseInt(m[2], 10) : null;
      if (chapter && (chapter < 1 || chapter > chaps)) return null;
      return { btn, chapter, verse: m[3] ? parseInt(m[3], 10) : null };
    }
    function storyHits(q) {
      const n = norm(q);
