      { q: ['red sea', 'parted the sea', 'crossing the sea'], ref: 'Exodus 14', label: 'Crossing the Red Sea' },
      { q: ['burning bush'], ref: 'Exodus 3', label: 'The burning bush' },
      { q: ['ten commandments', 'commandments'], ref: 'Exodus 20', label: 'The Ten Commandments' },
      { q: ['jonah', 'whale', 'great fish'], ref: 'Jonah 1', label: 'Jonah and the great fish' },
      { q: ['feeding the five thousand', 'loaves and fish', 'five loaves'], ref: 'John 6', label: 'Feeding the five thousand' },
