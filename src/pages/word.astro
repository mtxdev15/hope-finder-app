      return STORIES.filter((s) => s.q.some((k) => n.indexOf(k) >= 0 || k.indexOf(n) >= 0)).slice(0, 3);
    }
    function shitemHTML(i, book, chapter, verse, kicker, label) {
      return '<button class="shitem" style="animation-delay:' + (i * 34) + 'ms" data-book="' + esc(book) + '" data-chapter="' + (chapter || '') + '" data-verse="' + (verse || '') + '">'
        + '<span class="shref">' + esc(kicker) + '</span><span class="shlabel">' + esc(label) + '</span></button>';
    }
    // local layers (instant, no network): reference + stories
    function localResultsHTML(q) {
      let html = '', i = 0;
      const ref = parseRefQuery(q);
      if (ref) {
        const name = ref.btn.dataset.name;
        const kicker = name + (ref.chapter ? ' ' + ref.chapter : '') + (ref.verse ? ':' + ref.verse : '');
        html += shitemHTML(i++, name, ref.chapter || 1, ref.verse, kicker, ref.chapter ? 'Open this ' + (ref.verse ? 'verse' : 'chapter') + ' →' : 'Open ' + name + ' →');
      }
      storyHits(q).forEach((s) => {
        const m = s.ref.match(/^(.+?)\s+(\d+)$/);
        if (m && bookByName(m[1])) html += shitemHTML(i++, m[1], parseInt(m[2], 10), null, s.ref, s.label);
