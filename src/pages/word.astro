---
// /word — The Word. SURFACE rebuilt verbatim from design-source-v3.2/declare/TheWord.html
// (library: THE LIBRARY header, Scripture search, DEFAULT TRANSLATION pills, OT/NT toggle;
// reader: chapter grid → verse picker → reading, translation/Aa/Compare row, display sheet,
// verse action bar with Highlight/Save/Copy/Share, verse-jump, in-reader tab bar).
// MACHINERY: the Cloudflare Worker /bible + /bible/search routes (API.Bible key server-side;
// public-domain cached, copyrighted live + FUMS + copyright line) and vault-store.js
// (device-local saves). One persisted translation: 'declare-reader-translation'.
import DeclareLayout from '../layouts/DeclareLayout.astro';
import TabBar from '../components/TabBar.astro';
import { DB_BIBLE } from '../data/bible.js';
import { USFM } from '../data/usfm.js';

const sections = [
  { testament: 'OT', groups: DB_BIBLE.OT.groups },
  { testament: 'NT', groups: DB_BIBLE.NT.groups },
];
const chev = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>`;
---
<DeclareLayout
  title="Declare — The Word"
  description="Read and search the Bible — free and ad-free, in six translations."
  activeTab="word"
>
  <main class="word">
    <div class="topglow" aria-hidden="true"></div>
    {/* global brightness dim — driven by the Reading-preferences slider; sits below the sheet */}
    <div class="appdim" id="appDim" aria-hidden="true"></div>

    {/* ================= LIBRARY (design: browse view) ================= */}
    <div class="w-col" id="browse">
      <div class="whead">
        <span class="wlbl" data-i18n="word.library">The library</span>
        <button class="gear" id="libPrefs" type="button" aria-label="Reading preferences" data-i18n-aria="word.readingPrefs"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="7" x2="20" y2="7"></line><line x1="4" y1="17" x2="20" y2="17"></line><circle cx="9" cy="7" r="2.4"></circle><circle cx="15" cy="17" r="2.4"></circle></svg></button>
      </div>
      <div class="wtitle" data-i18n="word.title">The Word</div>

      <form class="search" id="searchForm" autocomplete="off">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.5" y2="16.5"></line></svg>
        <input id="searchInput" placeholder="Search Scripture — try &ldquo;water into wine&rdquo;" data-i18n-ph="word.searchPh" aria-label="Search Scripture" data-i18n-aria="word.searchAria" />
      </form>

      <div class="wlbl tlanslbl" data-i18n="word.defaultTranslation">Default translation</div>
      <div class="trow" id="pills">
        <button class="pill" data-t="kjv">KJV</button>
        <button class="pill" data-t="web">WEB</button>
        <button class="pill" data-t="asv">ASV</button>
        <button class="pill" data-t="nkjv">NKJV</button>
        <button class="pill" data-t="niv">NIV</button>
        <button class="pill" data-t="nlt">NLT</button>
        <button class="pill" data-t="rvr1909">RVR1909</button>
      </div>

      <div class="seg" id="testament">
        <button data-t="OT" data-i18n="word.ot">Old Testament</button>
        <button class="on" data-t="NT" data-i18n="word.nt">New Testament</button>
      </div>

      <div class="wscroll" id="browseScroll">
        <div class="searchhint" id="searchHint" style="display:none"></div>
        <div class="searchnote" id="searchNote" style="display:none"></div>
        <div id="groups">
          {sections.map((sec) => (
            <div class="tsec" data-test={sec.testament} style={sec.testament === 'OT' ? 'display:none' : ''}>
              {sec.groups.map((g) => (
                <section class="grp m-rise">
                  <div class="grphead">
                    <span class="grptitle">{g.title}</span>
                    <span class="grpsub">{g.books.length} {g.books.length === 1 ? 'BOOK' : 'BOOKS'}</span>
                  </div>
                  <div class="books">
                    {g.books.map((b) => (
                      <button class="book" data-usfm={USFM[b.name]} data-chaps={b.chapters} data-name={b.name}>
                        <span class="bmain">
                          <span class="bname">{b.name}</span>
                          {b.tag && <span class="bdesc">{b.tag}</span>}
                          <span class="bchap">{b.chapters} {b.chapters === 1 ? 'chapter' : 'chapters'}</span>
                        </span>
                        <span class="chev" set:html={chev} />
                      </button>
                    ))}
                  </div>
                </section>
              ))}
            </div>
          ))}
        </div>
        <div class="foot-sp"></div>
      </div>
    </div>

    {/* ===== Reading preferences — one Display sheet, opened from the library gear AND the
            reader's Aa button. Responsive: bottom sheet on mobile, centered modal on desktop. ===== */}
    <div class="lsheet" id="lsheet" hidden>
      <div class="lsback" data-lsclose></div>
      <div class="lspanel" role="dialog" aria-label="Reading preferences" data-i18n-aria="word.readingPrefs">
        <div class="lsgrab"></div>
        <div class="lstitle" data-i18n="word.readingPrefs">Reading preferences</div>
        <div class="lssub" data-i18n="word.prefsSub">How Scripture looks across the app.</div>
        <div class="lspreview" id="lsPreview" data-i18n="word.prefsPreview">For God so loved the world that he gave his only Son.</div>
        <div class="lssec">
          <div class="lslbl" data-i18n="word.theme">Theme</div>
          <div class="lsseg" id="libThemeSeg">
            <button type="button" data-mode="light" data-i18n="word.themeLight">Light</button>
            <button type="button" data-mode="dark" data-i18n="word.themeDark">Dark</button>
            <button type="button" data-mode="system" data-i18n="word.themeAuto">Auto</button>
          </div>
        </div>
        <div class="lssec">
          <div class="lslbl" data-i18n="word.brightness">Brightness</div>
          <div class="lsbright">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 6.5V6M6.5 12H6M12 17.5v.5M17.5 12h.5"></path></svg>
            <input type="range" id="libBright" min="40" max="100" value="100" aria-label="Brightness" data-i18n-aria="word.brightness" />
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><path d="M12 1.5v2.5M12 20v2.5M1.5 12H4M20 12h2.5M4.5 4.5l1.8 1.8M17.7 17.7l1.8 1.8M19.5 4.5l-1.8 1.8M6.3 17.7l-1.8 1.8"></path></svg>
          </div>
        </div>
        <div class="lssec">
          <div class="lslbl" data-i18n="word.fontStyle">Font style</div>
          <div class="lsseg" id="libFontSeg">
            <button type="button" class="ff-cormorant" data-f="cormorant">Cormorant</button>
            <button type="button" class="ff-lora" data-f="lora">Lora</button>
            <button type="button" class="ff-sans" data-f="sans">DM&nbsp;Sans</button>
          </div>
        </div>
        <div class="lssec">
          <div class="lslbl" data-i18n="word.textSize">Text size</div>
          <div class="lsseg" id="libSizeSeg">
            <button type="button" class="sz1" data-s="Small">A</button>
            <button type="button" class="sz2" data-s="Medium">A</button>
            <button type="button" class="sz3" data-s="Large">A</button>
          </div>
        </div>
        <button type="button" class="lsdone" data-lsclose data-i18n="word.done">Done</button>
      </div>
    </div>

    {/* ================= READER (design: reader view) ================= */}
    <div class="w-reader" id="reader">
      <div class="topglow" aria-hidden="true"></div>
      <div class="rtop">
        <div class="rhead">
          <span class="rh-lead"><button class="iconbtn" id="readerBack" aria-label="Back" data-i18n-aria="word.back"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 5l-7 7 7 7"></path></svg></button></span>
          <button class="rbook" id="rbook" aria-label="Back to the library" data-i18n-aria="word.backLibrary">John</button>
          <span class="rh-actions">
            <button class="iconbtn rsglass" id="readerSearch" aria-label="Search the Word" data-i18n-aria="word.searchWord"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.5" y2="16.5"></line></svg></button>
            <button class="iconbtn" id="verseJump" aria-label="Jump to a verse" data-i18n-aria="word.jumpVerse" style="visibility:hidden"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><line x1="9" y1="6" x2="20" y2="6"></line><line x1="9" y1="12" x2="20" y2="12"></line><line x1="9" y1="18" x2="20" y2="18"></line><circle cx="4.5" cy="6" r="1.3" fill="currentColor" stroke="none"></circle><circle cx="4.5" cy="12" r="1.3" fill="currentColor" stroke="none"></circle><circle cx="4.5" cy="18" r="1.3" fill="currentColor" stroke="none"></circle></svg></button>
          </span>
        </div>
        <div class="rsub" id="rsub">21 chapters</div>
        <div class="readctl" id="readctl" hidden>
          <button class="navchap" id="prevChap" aria-label="Previous chapter" data-i18n-aria="word.prevChapter"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M15 5l-7 7 7 7"></path></svg></button>
          <button class="chaplabel" id="chapLabel"><span id="chapLabelText">Chapter 1</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"></path></svg></button>
          <button class="navchap" id="nextChap" aria-label="Next chapter" data-i18n-aria="word.nextChapter"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5l7 7-7 7"></path></svg></button>
        </div>
        <div class="rtrans" id="rtrans" hidden></div>
      </div>
      <div class="rscroll" id="rscroll">
        <div class="chappick" id="chapPick">
          <div class="picklbl" data-i18n="word.chooseChapter">Choose a chapter</div>
          <div class="chapgrid" id="chapgrid"></div>
        </div>
        <div class="versepick" id="versePick" hidden>
          <button class="vp-all" id="readAll"><span data-i18n="word.readWholeChapter">Read the whole chapter</span> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg></button>
          <div class="picklbl" data-i18n="word.orJumpVerse">Or jump to a verse</div>
          <div class="chapgrid" id="versegrid"></div>
        </div>
        <div class="rbody" id="rbody" hidden></div>
        <div class="rcopyright" id="rcopyright" hidden></div>
      </div>

      {/* in-reader tab bar (design): jump to any section without backing out */}
      <TabBar active="word" />

      <div class="vjump" id="vjump">
        <div class="vjback" id="vjback"></div>
        <div class="vjsheet">
          <div class="grabber"></div>
          <div class="vjtitle" data-i18n="word.jumpVerse">Jump to a verse</div>
          <div class="vjgrid" id="vjgrid"></div>
        </div>
      </div>

      {/* verse action bar */}
      <div class="vbar" id="vbar">
        <div class="grabber"></div>
        <div class="vbref" id="vbref">Verse</div>
        <div class="hlpalette" id="hlPalette" hidden>
          <button class="hlsw c-gold" data-c="gold" aria-label="Gold highlight" data-i18n-aria="word.hlGold"></button>
          <button class="hlsw c-rose" data-c="rose" aria-label="Rose highlight" data-i18n-aria="word.hlRose"></button>
          <button class="hlsw c-sky" data-c="sky" aria-label="Sky highlight" data-i18n-aria="word.hlSky"></button>
          <button class="hlsw c-mint" data-c="mint" aria-label="Mint highlight" data-i18n-aria="word.hlMint"></button>
          <button class="hlsw c-lilac" data-c="lilac" aria-label="Lilac highlight" data-i18n-aria="word.hlLilac"></button>
          <button class="hlsw hlsw-none" data-c="none" aria-label="Remove highlight" data-i18n-aria="word.hlRemove"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 5l14 14"></path><circle cx="12" cy="12" r="9"></circle></svg></button>
        </div>
        <div class="vbacts">
          <button class="vbtn" id="vbHl"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16"></path><path d="M6.5 16.5L14 9l3 3-7.5 7.5H6.5z"></path><path d="M14 9l2.5-2.5a1.6 1.6 0 0 1 2.3 0l.7.7a1.6 1.6 0 0 1 0 2.3L17 12"></path></svg><span data-i18n="word.highlight">Highlight</span></button>
          <button class="vbtn" id="vbSave"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4.5h12v15l-6-4-6 4z"></path></svg><span data-i18n="word.save">Save</span></button>
          <button class="vbtn" id="vbCopy"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="11" height="11" rx="2"></rect><path d="M5 15V5a2 2 0 0 1 2-2h10"></path></svg><span data-i18n="word.copy">Copy</span></button>
          <button class="vbtn" id="vbShare"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v7a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-7"></path><path d="M12 3v13M8 7l4-4 4 4"></path></svg><span data-i18n="word.share">Share</span></button>
          <button class="vbtn" id="vbClose"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"></path></svg><span>Close</span></button>
        </div>
      </div>

      {/* in-reader Scripture search */}
      <div class="rsheet" id="rsearch">
        <div class="rsback"></div>
        <div class="rspanel rs-search">
          <div class="grabber"></div>
          <div class="rstitle" data-i18n="word.searchWord">Search the Word</div>
          <form class="search rs-field" id="rsForm" autocomplete="off">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.5" y2="16.5"></line></svg>
            <input id="rsInput" placeholder="A verse, a reference, or a story&hellip;" data-i18n-ph="word.rsPh" aria-label="Search Scripture" data-i18n-aria="word.searchAria" />
          </form>
          <div class="rs-results" id="rsResults"></div>
        </div>
      </div>

      {/* translation menu */}
      <div class="rsheet" id="tmenu">
        <div class="rsback"></div>
        <div class="rspanel"><div class="grabber"></div><div class="rstitle" data-i18n="word.translation">Translation</div><div id="tmlist"></div></div>
      </div>

      {/* display sheet */}
      {/* Display settings now live in the unified #lsheet (opened from the reader's Aa button
          and the library gear) — see "Reading preferences" above. */}

      {/* share sheet (fallback when the Card Studio stack is unavailable) */}
      <div class="rsheet" id="sharesheet">
        <div class="rsback"></div>
        <div class="rspanel">
          <div class="grabber"></div>
          <div class="rstitle" data-i18n="word.shareVerse">Share this verse</div>
          <div class="sharprev" id="sharePrev"></div>
          <button class="sopt" id="shSystem"><span class="si"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v7a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-7"></path><path d="M12 3v13M8 7l4-4 4 4"></path></svg></span><span class="sl" data-i18n="word.shareVia">Share via&hellip;</span><span class="sc" set:html={chev} /></button>
          <button class="sopt" id="shCopy"><span class="si"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="11" height="11" rx="2"></rect><path d="M5 15V5a2 2 0 0 1 2-2h10"></path></svg></span><span class="sl" data-i18n="word.copyVerse">Copy verse</span><span class="sc" set:html={chev} /></button>
        </div>
      </div>

      <div class="dim" id="dim" aria-hidden="true"></div>
      <div class="wtoast" id="wtoast"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"></path></svg><span id="wtoastMsg"></span></div>
    </div>
  </main>

  <script is:inline src="/declare/i18n-bible-es.js?v=3.16.2" defer></script>
  <script>
    import { saveItem, removeItem, isSaved } from '../app/declare/vault-store.js';
    import { initAuth } from '../app/declare/auth-store.js';
    import { ensureSignedIn } from '../app/declare/auth-gate.js';
    initAuth(); // resolve any saved session before the user reaches a gate

    const WORKER = 'https://hope-finder-worker.thinktoro.workers.dev';
    const $ = (id) => document.getElementById(id);
    const esc = (s) => (s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

    /* one source of truth for the default translation (library pills + reader) */
    const TRANSLATIONS = [
      { id: 'kjv', label: 'KJV', name: 'King James Version' },
      { id: 'web', label: 'WEB', name: 'World English Bible' },
      { id: 'asv', label: 'ASV', name: 'American Standard Version' },
      { id: 'nkjv', label: 'NKJV', name: 'New King James Version' },
      { id: 'niv', label: 'NIV', name: 'New International Version (2011)' },
      { id: 'nlt', label: 'NLT', name: 'New Living Translation' },
      { id: 'rvr1909', label: 'RVR1909', name: 'Reina-Valera 1909 (Español)' },
    ];
    const byId = (id) => TRANSLATIONS.find((t) => t.id === id);
    const byLabel = (l) => TRANSLATIONS.find((t) => t.label === l);
    function esLock(){ try { return !!(window.I18N && window.I18N.lang() === 'es'); } catch(e){ return false; } }
    // Spanish PRESENTATION of the Word content: on when the app is Spanish OR the
    // reader translation is RVR1909 — an English user picking RVR1909 gets Spanish
    // book names, chapter labels, and pickers, not just Spanish verse text.
    function esW(){ return esLock() || readT === 'rvr1909'; }
    function wes(k, fb){ try { var d = window.__I18N_STRINGS; if (d && d.es && d.es[k] != null) return d.es[k]; } catch(e){} return fb; }
    function tW(k, fb){ try { return window.I18N ? window.I18N.t(k, fb) : fb; } catch(e){ return fb; } }
    function bookNameES(en){ try { if (esW() && window.__I18N_BIBLE_ES) return window.__I18N_BIBLE_ES.books[en] || en; } catch(e){} return en; }
    function localizeLibraryES(){ localizeLibrary(esW()); }
    // Reversible: stash the English once, then swap either way — so switching the
    // reader between RVR1909 and an English translation re-renders the library live.
    function localizeLibrary(es){
      var M = window.__I18N_BIBLE_ES; if (!M) return;
      function stash(el){ if (el && el.__en == null) el.__en = el.textContent; }
      document.querySelectorAll('#groups .grptitle').forEach(function(el){
        stash(el); el.textContent = es ? (M.groups[el.__en.trim()] || el.__en) : el.__en;
      });
      document.querySelectorAll('#groups .grpsub').forEach(function(el){
        stash(el); el.textContent = es ? el.__en.replace('BOOKS','LIBROS').replace(/BOOK$/,'LIBRO') : el.__en;
      });
      document.querySelectorAll('#groups .book').forEach(function(b){
        var en = b.getAttribute('data-name');
        var bn = b.querySelector('.bname'); if (bn) { stash(bn); bn.textContent = es ? (M.books[en] || bn.__en) : bn.__en; }
        var bd = b.querySelector('.bdesc'); if (bd) { stash(bd); bd.textContent = es ? (M.tags[bd.__en.trim()] || bd.__en) : bd.__en; }
        var bc = b.querySelector('.bchap'); if (bc) { stash(bc); bc.textContent = es ? bc.__en.replace('chapters','capítulos').replace(/chapter$/,'capítulo') : bc.__en; }
      });
    }
    /* Re-present the whole Word section in the reader translation's language.
       Static picker labels only need the manual swap when the APP is English
       (when the app is Spanish, I18N handles them); .__en mirrors i18n's stash. */
    function updateWordLangUI(){
      var es = esW();
      localizeLibrary(es);
      if (!esLock()) {
        [['#reader .chappick .picklbl', 'word.chooseChapter', 'Choose a chapter'],
         ['#versePick .picklbl', 'word.orJumpVerse', 'Or jump to a verse'],
         ['#readAll [data-i18n]', 'word.readWholeChapter', 'Read the whole chapter'],
         ['.vjtitle', 'word.jumpVerse', 'Jump to a verse']].forEach(function(row){
          var el = document.querySelector(row[0]); if (!el) return;
          if (el.__en == null) el.__en = el.textContent;
          el.textContent = es ? wes(row[1], el.__en) : el.__en;
        });
      }
      try {
        if (reader && reader.classList.contains('open') && curBook) {
          rbook.textContent = bookNameES(curBook);
          rsub.textContent = curChaps + (es ? (curChaps === 1 ? ' capítulo' : ' capítulos') : (curChaps === 1 ? ' chapter' : ' chapters'));
          if (typeof curChap === 'number' && curChap >= 1 && chapLabelText)
            chapLabelText.textContent = (es ? 'Capítulo ' : tW('word.chapter', 'Chapter ')) + curChap;
        }
      } catch (e) {}
    }
    let readT = (() => { try { if (esLock()) return 'rvr1909'; const t = localStorage.getItem('declare-reader-translation'); return byId(t) ? t : 'web'; } catch (e) { return 'web'; } })();
    function setReadT(id) { readT = id; try { localStorage.setItem('declare-reader-translation', id); } catch (e) {} paintPills(); try { updateWordLangUI(); } catch (e) {} }

    /* ---------- library: pills · testament · groups ---------- */
    const pills = $('pills');
    function paintPills() { pills.querySelectorAll('.pill').forEach((p) => p.classList.toggle('on', p.dataset.t === readT)); }
    pills.addEventListener('click', (e) => {
      const p = e.target.closest('.pill'); if (!p) return;
      setReadT(p.dataset.t);
    });
    // Spanish: RVR1909 is the ONLY and default translation — hide the chooser entirely.
    if (esLock()) {
      readT = 'rvr1909'; try { localStorage.setItem('declare-reader-translation', 'rvr1909'); } catch (e) {}
