---
// /word — the Word reader (slice 1: read a book/chapter in WEB end to end).
// Static Astro page on DeclareLayout; all behaviour is vanilla JS (matches the
// design source). The browser asks the Cloudflare Worker's /bible route for a
// chapter; the Worker fetches WEB from API.Bible (key server-side) and caches it
// forever in KV. WEB only this slice — translation switching, verse-jump, compare,
// and the Aa sheet are deferred to later slices.
import DeclareLayout from '../layouts/DeclareLayout.astro';
import { DB_BIBLE } from '../data/bible.js';
import { USFM } from '../data/usfm.js';

// flatten the grouped book data for server-rendering the list
const sections = [
  { testament: 'OT', groups: DB_BIBLE.OT.groups },
  { testament: 'NT', groups: DB_BIBLE.NT.groups },
];
const chev = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>`;
---
<DeclareLayout
  title="Declare — The Word"
  description="Read the Bible — free and ad-free."
  activeTab="word"
>
  <main class="word">
    <div class="topglow" aria-hidden="true"></div>

    {/* ---------- book list ---------- */}
    <div class="w-bookview" id="bookView">
      <div class="w-col">
        <div class="wtitle rise d1">The Word</div>
        <div class="wsub rise d1">Free &amp; ad-free &middot; choose your translation</div>

        {sections.map((sec) => sec.groups.map((g) => (
          <section class="grp">
            <div class="grphead">
              <span class="grptitle">{g.title}</span>
              <span class="grpsub">{g.sub}</span>
            </div>
            <div class="books">
              {g.books.map((b) => (
                <button class="book" data-usfm={USFM[b.name]} data-chaps={b.chapters} data-name={b.name}>
                  <span class="bmain">
                    <span class="bname">{b.name}</span>
                    {b.tag && <span class="bdesc">{b.tag}</span>}
                    <span class="bchap">{b.chapters} {b.chapters === 1 ? 'chapter' : 'chapters'}</span>
                  </span>
                  <span class="chev" set:html={chev} />
                </button>
              ))}
            </div>
          </section>
        )))}
        <div class="foot-sp"></div>
      </div>
    </div>

    {/* ---------- reader overlay ---------- */}
    <div class="w-reader" id="reader">
      <div class="topglow" aria-hidden="true"></div>
      <div class="rtop">
        <div class="rhead">
          <button class="iconbtn" id="readerBack" aria-label="Back">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 5l-7 7 7 7"/></svg>
          </button>
          <span class="rbook" id="rbook">John</span>
          <span class="iconbtn-spacer" aria-hidden="true"></span>
        </div>
        <div class="rsub" id="rsub">21 chapters</div>
        <div class="readctl" id="readctl" hidden>
          <button class="navchap" id="prevChap" aria-label="Previous chapter"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M15 5l-7 7 7 7"/></svg></button>
          <button class="chaplabel" id="chapLabel"><span id="chapLabelText">Chapter 1</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></button>
          <button class="navchap" id="nextChap" aria-label="Next chapter"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5l7 7-7 7"/></svg></button>
        </div>
        <div class="rtrans" id="rtrans" hidden>
          <button class="transsel" id="transsel">
            <span id="transselLabel">WEB</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
          </button>
        </div>
      </div>
      <div class="rscroll" id="rscroll">
        <div class="chappick" id="chapPick">
          <div class="picklbl">Choose a chapter</div>
          <div class="chapgrid" id="chapgrid"></div>
        </div>
        <div class="rbody" id="rbody" hidden></div>
        <div class="rcopyright" id="rcopyright" hidden></div>
      </div>

      {/* translation chooser sheet (WEB / NLT) */}
      <div class="rsheet" id="tmenu">
        <div class="rsback" id="tmback"></div>
        <div class="rspanel">
          <div class="tmgrab" aria-hidden="true"></div>
          <div class="rstitle">Translation</div>
          <div id="tmlist"></div>
        </div>
      </div>
    </div>
  </main>

  <script is:inline>
    (function () {
      var WORKER = 'https://hope-finder-worker.thinktoro.workers.dev/bible';
      var $ = function (id) { return document.getElementById(id); };
      var esc = function (s) { return (s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); };

      var reader = $('reader'), bookView = $('bookView');
      var rbook = $('rbook'), rsub = $('rsub'), chapgrid = $('chapgrid'), chapPick = $('chapPick'),
          rbody = $('rbody'), readctl = $('readctl'), rtrans = $('rtrans'),
          chapLabelText = $('chapLabelText'), prevChapBtn = $('prevChap'), nextChapBtn = $('nextChap'),
          rscroll = $('rscroll'), rcopyright = $('rcopyright'),
          transsel = $('transsel'), transselLabel = $('transselLabel'),
          tmenu = $('tmenu'), tmlist = $('tmlist');

      // WEB (public domain) + the copyrighted translations, in switcher order. The Worker
      // serves WEB cached and NLT/NKJV/NIV live (FUMS + copyright); the page treats any
      // non-WEB translation the same way (no client cache, copyright line, FUMS ping).
      var TRANSLATIONS = [
        { id: 'kjv', label: 'KJV', name: 'King James Version' },
        { id: 'web', label: 'WEB', name: 'World English Bible' },
        { id: 'asv', label: 'ASV', name: 'American Standard Version' },
        { id: 'nkjv', label: 'NKJV', name: 'New King James Version' },
        { id: 'niv', label: 'NIV', name: 'New International Version (2011)' },
        { id: 'nlt', label: 'NLT', name: 'New Living Translation' },
      ];
      function transLabel(id) { for (var i = 0; i < TRANSLATIONS.length; i++) if (TRANSLATIONS[i].id === id) return TRANSLATIONS[i].label; return 'WEB'; }
      function knownTrans(t) { for (var i = 0; i < TRANSLATIONS.length; i++) if (TRANSLATIONS[i].id === t) return true; return false; }
      var curTrans = (function () { try { var t = localStorage.getItem('declare-reader-translation'); return knownTrans(t) ? t : 'web'; } catch (e) { return 'web'; } })();

      var curName = '', curUsfm = '', curChaps = 1, curChap = 1;
      var CACHE = {}, reqId = 0;

      // Returns the full Worker payload {verses, fumsToken, copyright, translation}.
      // WEB is cached client-side; copyrighted translations (NLT/NKJV/NIV) are NEVER
      // cached — each view must hit the Worker live for a fresh FUMS token (every
      // display is a tracked view).
      function fetchChapter(usfm, chap, trans) {
        var key = trans + ':' + usfm + '.' + chap;
        // Only public-domain results are ever written to CACHE (see below), so a present
        // key is always safe to serve; copyrighted translations always refetch live.
        if (CACHE[key]) return Promise.resolve(CACHE[key]);
        var url = WORKER + '?translation=' + trans + '&book=' + encodeURIComponent(usfm) + '&chapter=' + chap;
        return fetch(url).then(function (r) { return r.ok ? r.json() : null; }).then(function (j) {
          if (!j || !j.verses) return null;
          // Cache only public-domain (no FUMS token) — copyrighted must hit the Worker live every view.
          if (!j.fumsToken) CACHE[key] = j;
          return j;
        }).catch(function () { return null; });
      }

      // ---- FUMS (API.Bible's required view tracking for copyrighted text) ----
      // The official tracker is loaded lazily — only when copyrighted text is first
      // read — so WEB-only readers never load a third-party script. WEB fires nothing.
      var fumsReady = false, fumsLoading = false, fumsQueue = [];
      function loadFums() {
        if (fumsReady || fumsLoading) return;
        fumsLoading = true;
        var s = document.createElement('script');
        s.src = 'https://pkg.api.bible/fumsV3.min.js';
        s.async = true;
        s.onload = function () { fumsReady = true; fumsQueue.forEach(trackView); fumsQueue = []; };
        document.head.appendChild(s);
      }
      function trackView(token) { try { if (window.fums) window.fums('trackView', token); } catch (e) {} }
      function fireFums(token) {
        if (!token) return;
        if (fumsReady && window.fums) { trackView(token); return; }
        fumsQueue.push(token); loadFums();
      }

      function openReader(name, usfm, chaps) {
        curName = name; curUsfm = usfm; curChaps = chaps || 1;
        rbook.textContent = name;
        transselLabel.textContent = transLabel(curTrans);
        reader.classList.add('open');
        showPicker();
      }
      function showPicker() {
        var h = ''; for (var i = 1; i <= curChaps; i++) { h += '<button class="chaptile" data-c="' + i + '">' + i + '</button>'; }
        chapgrid.innerHTML = h;
        rsub.textContent = curChaps + (curChaps === 1 ? ' chapter' : ' chapters');
        chapPick.hidden = false; rbody.hidden = true; readctl.hidden = true; rtrans.hidden = true; rcopyright.hidden = true;
        rscroll.scrollTop = 0;
      }
      function readChapter(ch) {
        curChap = ch;
        chapPick.hidden = true; rbody.hidden = false; readctl.hidden = false; rtrans.hidden = false;
        chapLabelText.textContent = 'Chapter ' + ch;
        prevChapBtn.disabled = ch <= 1; nextChapBtn.disabled = ch >= curChaps;
        rscroll.scrollTop = 0;
        renderBody();
      }
      function loadingPanel() {
        var rows = ''; for (var i = 0; i < 6; i++) { rows += '<div class="shrow"><span class="shn"></span><span class="shl" style="width:' + (70 + (i % 3) * 9) + '%"></span></div>'; }
        return '<div class="rloading">' + rows + '</div>';
      }
      function errorPanel() {
        return '<div class="rsoon"><div class="ri"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5.4A1.4 1.4 0 0 1 5.4 4H11v15.2H5.4A1.4 1.4 0 0 0 4 20.6z"/><path d="M20 5.4A1.4 1.4 0 0 0 18.6 4H13v15.2h5.6A1.4 1.4 0 0 1 20 20.6z"/></svg></div>'
          + '<div class="rt2">' + esc(curName + ' ' + curChap) + '</div>'
          + '<div class="rd">Couldn’t load this chapter. Check your connection and try again.</div></div>';
      }
      function renderBody() {
        var myReq = ++reqId;
        var trans = curTrans;
        rbody.innerHTML = loadingPanel();
        rcopyright.hidden = true;
        fetchChapter(curUsfm, curChap, trans).then(function (payload) {
          if (myReq !== reqId) return;
          if (!payload || !payload.verses || !payload.verses.length) { rbody.innerHTML = errorPanel(); return; }
          rbody.innerHTML = payload.verses.map(function (v) {
            return '<div class="vrse" data-n="' + esc(v.n) + '"><span class="vn">' + esc(v.n) + '</span><span class="vt">' + esc(v.t) + '</span></div>';
          }).join('');
          // copyright line — copyrighted translations only (Worker returns it; WEB returns none)
          if (payload.copyright) { rcopyright.textContent = payload.copyright; rcopyright.hidden = false; }
          else { rcopyright.textContent = ''; rcopyright.hidden = true; }
          // FUMS view ping — copyrighted text only; WEB fires nothing
          // FUMS view ping — copyrighted text only; the Worker returns a token iff one is required.
          if (payload.fumsToken) fireFums(payload.fumsToken);
        });
      }

      chapgrid.addEventListener('click', function (e) { var t = e.target.closest('.chaptile'); if (t) readChapter(parseInt(t.dataset.c, 10)); });
      $('chapLabel').addEventListener('click', showPicker);
      prevChapBtn.addEventListener('click', function () { if (curChap > 1) readChapter(curChap - 1); });
      nextChapBtn.addEventListener('click', function () { if (curChap < curChaps) readChapter(curChap + 1); });
      $('readerBack').addEventListener('click', function () {
        if (!rbody.hidden) { showPicker(); }       // reading -> chapter picker
        else { reader.classList.remove('open'); }   // chapter picker -> book list
      });

      bookView.addEventListener('click', function (e) {
        var b = e.target.closest('.book'); if (!b) return;
        openReader(b.dataset.name, b.dataset.usfm, parseInt(b.dataset.chaps, 10));
      });

      // ---- translation switcher (WEB <-> NLT) ----
      function openTmenu() {
        tmlist.innerHTML = TRANSLATIONS.map(function (t) {
          return '<button class="tmrow' + (t.id === curTrans ? ' on' : '') + '" data-t="' + t.id + '">'
            + '<span class="tmtx"><span class="tmn">' + t.label + '</span><span class="tmd">' + t.name + '</span></span>'
            + '<span class="tmck"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg></span></button>';
        }).join('');
        tmenu.classList.add('open');
      }
      transsel.addEventListener('click', openTmenu);
      $('tmback').addEventListener('click', function () { tmenu.classList.remove('open'); });
      tmlist.addEventListener('click', function (e) {
        var r = e.target.closest('.tmrow'); if (!r) return;
        var t = r.dataset.t;
        tmenu.classList.remove('open');
        if (t === curTrans) return;
        curTrans = t;
        try { localStorage.setItem('declare-reader-translation', curTrans); } catch (_) {}
        transselLabel.textContent = transLabel(curTrans);
        if (!rbody.hidden) renderBody(); // refetch the current chapter in the new translation
      });
    })();
  </script>

  <!-- is:global because much of the reader (chapter tiles, verses, translation rows,
       loaders) is built at runtime via innerHTML; Astro's scoped attribute is only on
       static markup, so scoped rules would silently miss those JS-created elements.
       These classes are word-only and a page's styles load only on its own route, so
       there is no cross-page leakage. -->
  <style is:global>
    /* page-local Word reader styles (subset of TheWord.html; .topglow / .btn /
       .rise / tokens come from global declare.css). */
    .word { position: relative; min-height: 100dvh; }

    /* ---------- book list ---------- */
    .w-bookview { position: relative; z-index: 1; }
    .w-col {
      width: 100%; max-width: 680px; margin: 0 auto;
      padding: 0 22px calc(120px + env(safe-area-inset-bottom, 0));
    }
    .wtitle { font-family: 'Cormorant Garamond', serif; font-size: 34px; font-weight: 600; color: var(--text); padding: 34px 2px 0; text-align: center; }
    .wsub { text-align: center; font-size: 12px; letter-spacing: .04em; color: var(--goldd); margin-top: 6px; }

    .grp { padding: 26px 0 0; }
    .grphead { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 12px; }
    .grptitle { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; color: var(--text); }
    .grpsub { font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: var(--goldd); font-weight: 500; }
    .books { display: flex; flex-direction: column; gap: 10px; }
    .book { display: flex; align-items: center; gap: 14px; padding: 15px 16px; background: var(--surface); border-radius: 16px; box-shadow: var(--card-shadow); cursor: pointer; border: 0; width: 100%; text-align: left; font-family: inherit; transition: transform .25s; }
    @media (hover: hover) { .book:hover { transform: translateY(-3px); } }
    .book .bmain { flex: 1; min-width: 0; }
    .book .bname { display: block; font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 600; color: var(--text); line-height: 1.1; }
    .book .bdesc { display: block; font-size: 12.5px; color: var(--muted); margin-top: 3px; }
    .book .bchap { display: block; font-size: 11px; color: var(--text2); margin-top: 5px; opacity: .8; }
    .book .chev { flex: 0 0 auto; color: var(--goldd); display: flex; }
    .book .chev svg { width: 18px; height: 18px; }
    .foot-sp { height: 26px; }

    /* ---------- reader overlay ---------- */
    .w-reader { position: fixed; inset: 0; z-index: 40; background: var(--bgfield); display: none; flex-direction: column; }
    .w-reader.open { display: flex; }
    .rtop { position: relative; z-index: 2; flex: 0 0 auto; padding-top: env(safe-area-inset-top, 0); }
    .rhead { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 14px 18px 2px; }
    .rhead .iconbtn, .rhead .iconbtn-spacer { width: 38px; height: 38px; flex: 0 0 auto; }
    .rhead .iconbtn { border: 0; background: transparent; color: var(--text); cursor: pointer; display: flex; align-items: center; justify-content: center; border-radius: 10px; }
    .rhead .iconbtn svg { width: 20px; height: 20px; }
    .rbook { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; color: var(--text); text-align: center; flex: 1; }
    .rsub { text-align: center; font-size: 11px; letter-spacing: .06em; color: var(--goldd); padding-bottom: 6px; }
    /* translation switcher pill */
    .rtrans { display: flex; justify-content: center; align-items: center; padding: 0 18px 12px; }
    .transsel { display: inline-flex; align-items: center; gap: 7px; font-size: 12px; font-weight: 600; letter-spacing: .04em; color: var(--text); background: var(--field); border: 1px solid var(--line2); border-radius: 999px; padding: 8px 14px; cursor: pointer; font-family: inherit; }
    .transsel svg { width: 13px; height: 13px; color: var(--goldd); }

    /* translation chooser sheet */
    .rsheet { position: fixed; inset: 0; z-index: 50; display: none; }
    .rsheet.open { display: block; }
    .rsback { position: absolute; inset: 0; background: rgba(0, 0, 0, .42); backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px); }
    .rspanel { position: absolute; left: 0; right: 0; bottom: 0; max-width: 560px; margin: 0 auto; background: var(--surface); border-radius: 24px 24px 0 0; padding: 10px 20px calc(24px + env(safe-area-inset-bottom, 0)); box-shadow: 0 -20px 50px -18px rgba(0, 0, 0, .5); animation: tmup .3s cubic-bezier(.2, .7, .2, 1); }
    @keyframes tmup { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: none; } }
    .tmgrab { width: 40px; height: 5px; border-radius: 100px; background: var(--line2); margin: 4px auto 8px; }
    .rstitle { text-align: center; font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; color: var(--text); margin: 8px 0 10px; }
    .tmrow { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 15px 4px; border: 0; border-top: 1px solid var(--line); background: none; width: 100%; text-align: left; font-family: inherit; cursor: pointer; }
    #tmlist .tmrow:first-child { border-top: 0; }
    .tmtx { display: flex; flex-direction: column; }
    .tmn { font-size: 16px; color: var(--text); font-weight: 600; }
    .tmd { font-size: 12px; color: var(--muted); margin-top: 2px; }
    .tmck { color: var(--gold); display: none; }
    .tmrow.on .tmck { display: flex; }
    .tmck svg { width: 18px; height: 18px; }

    /* copyright notice (copyrighted translations only) */
    .rcopyright { max-width: 680px; margin: 8px auto 0; padding: 14px 22px calc(40px + env(safe-area-inset-bottom, 0)); border-top: 1px solid var(--line); font-size: 11px; line-height: 1.55; color: var(--muted); }

    .readctl { display: flex; align-items: center; justify-content: center; gap: 12px; padding: 6px 18px 10px; }
    .navchap { width: 38px; height: 38px; border-radius: 11px; border: 1px solid var(--line2); background: transparent; color: var(--text); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: .2s; }
    .navchap svg { width: 18px; height: 18px; }
    .navchap:disabled { opacity: .32; cursor: default; }
    .chaplabel { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; color: var(--text); background: var(--field); border: 1px solid var(--line2); border-radius: 12px; padding: 9px 18px; cursor: pointer; display: inline-flex; align-items: center; gap: 9px; }
    .chaplabel svg { width: 13px; height: 13px; color: var(--goldd); }

    .rscroll { position: relative; z-index: 1; flex: 1; min-height: 0; overflow-y: auto; scrollbar-width: none; padding-bottom: calc(96px + env(safe-area-inset-bottom, 0)); }
    .rscroll::-webkit-scrollbar { display: none; }

    .chappick { padding: 10px 22px 30px; max-width: 680px; margin: 0 auto; width: 100%; }
    .picklbl { font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--goldd); font-weight: 500; margin: 8px 2px 14px; }
    .chapgrid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; }
    .chaptile { aspect-ratio: 1/1; border-radius: 14px; border: 1px solid var(--line2); background: var(--surface); box-shadow: var(--card-shadow); color: var(--text); font-family: 'Cormorant Garamond', serif; font-size: 19px; font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: transform .2s; }
    @media (hover: hover) { .chaptile:hover { transform: translateY(-2px); } }

    .rbody { padding: 6px 22px 36px; max-width: 680px; margin: 0 auto; width: 100%; }
    .vrse { display: flex; gap: 11px; margin-bottom: 15px; }
    .vrse .vn { flex: 0 0 auto; font-size: 11px; color: var(--goldd); font-weight: 600; width: 18px; text-align: right; padding-top: 6px; }
    .vrse .vt { flex: 1; font-family: 'Cormorant Garamond', serif; font-size: 20px; line-height: 1.5; color: var(--text); }

    /* loading shimmer + error panel */
    .rloading { padding: 8px 22px; max-width: 680px; margin: 0 auto; }
    .shrow { display: flex; gap: 11px; margin-bottom: 16px; align-items: flex-start; }
    .shn { flex: 0 0 auto; width: 14px; height: 12px; border-radius: 4px; background: var(--field); margin-top: 5px; }
    .shl { flex: 1; height: 16px; border-radius: 8px; background: linear-gradient(90deg, var(--field), rgba(216, 184, 95, .14), var(--field)); background-size: 200% 100%; animation: wshim 1.3s ease-in-out infinite; }
    @keyframes wshim { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
    .rsoon { text-align: center; padding: 40px 18px; }
    .rsoon .ri { width: 46px; height: 46px; margin: 0 auto 14px; border-radius: 50%; background: var(--field); display: flex; align-items: center; justify-content: center; color: var(--goldd); }
    .rsoon .ri svg { width: 21px; height: 21px; }
    .rsoon .rt2 { font-family: 'Cormorant Garamond', serif; font-size: 20px; color: var(--text); }
    .rsoon .rd { font-size: 13px; color: var(--muted); margin-top: 7px; line-height: 1.5; max-width: 32ch; margin-left: auto; margin-right: auto; }
  </style>
</DeclareLayout>
