          rbody.innerHTML = j.verses.map((v) => '<div class="vrse m-veil" data-n="' + v.n + '"><span class="vn">' + v.n + '</span><span class="vt">' + esc(v.t) + '</span></div>').join('');
          if (window.DeclareMotion) { rbody.style.setProperty('--m-stagger', '34ms'); rbody.style.setProperty('--m-premium', '640ms'); window.DeclareMotion.reveal(rbody, { stagger: 30 }); }
