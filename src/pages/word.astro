    }
    function setCopyright(lines) {
      const uniq = [...new Set(lines.filter(Boolean))];
      if (uniq.length) { rcopyright.innerHTML = uniq.map((c) => '<div>' + esc(c) + '</div>').join(''); rcopyright.hidden = false; }
      else { rcopyright.hidden = true; rcopyright.innerHTML = ''; }
    }
    function renderBody(keepN) {
      const myReq = ++reqId;
      rbody.innerHTML = loadingPanel(); rcopyright.hidden = true;
      if (!compare) {
        fetchChapter(curUsfm, curChap, readT).then((j) => {
          if (myReq !== reqId) return;
          if (!j) { rbody.innerHTML = panel(curBook + ' ' + curChap, (esW() ? 'No se pudo cargar este capítulo. Revisa tu conexión e inténtalo de nuevo.' : 'Couldn’t load this chapter. Check your connection and try again.')); verseJump.style.visibility = 'hidden'; return; }
          rbody.innerHTML = j.verses.map((v) => '<div class="vrse m-veil" data-n="' + v.n + '"><span class="vn">' + v.n + '</span><span class="vt">' + esc(v.t) + '</span></div>').join('');
          if (window.DeclareMotion) { rbody.style.setProperty('--m-stagger', '34ms'); rbody.style.setProperty('--m-premium', '640ms'); window.DeclareMotion.reveal(rbody, { stagger: 30 }); }
          setCopyright([j.copyright]);
          fireFums(j.fumsToken);
          updateVerseJump(j.verses);
          applyHighlights();
          if (keepN) requestAnimationFrame(() => scrollToVerseN(keepN));
        });
      } else {
        Promise.all(cmpSet.map((label) => fetchChapter(curUsfm, curChap, byLabel(label).id).then((j) => ({ t: label, j })))).then((res) => {
          if (myReq !== reqId) return;
          let base = null;
          for (const r of res) if (r.j && r.j.verses.length) { base = r.j.verses; break; }
          if (!base) { rbody.innerHTML = panel(curBook + ' ' + curChap, (esW() ? 'No se pudo cargar este capítulo. Revisa tu conexión e inténtalo de nuevo.' : 'Couldn’t load this chapter. Check your connection and try again.')); verseJump.style.visibility = 'hidden'; return; }
          const maps = {};
          res.forEach((r) => { const m = {}; (r.j ? r.j.verses : []).forEach((v) => { m[v.n] = v.t; }); maps[r.t] = m; });
          rbody.innerHTML = '<div class="pcols">' + base.map((v) => (
            '<div class="pverse" data-n="' + v.n + '"><div class="pn">' + (esW() ? 'Versículo ' : 'Verse ') + v.n + '</div><div class="pgrid" style="grid-template-columns:repeat(' + cmpSet.length + ',1fr)">'
            + cmpSet.map((t) => '<div class="pcell"><div class="pcl">' + t + '</div><div class="pcx">' + esc((maps[t] && maps[t][v.n]) || '—') + '</div></div>').join('')
            + '</div></div>'
          )).join('') + '</div>';
          // licensing: every copyrighted leg is a fresh tracked display + shows its line
          setCopyright(res.map((r) => r.j && r.j.copyright));
          res.forEach((r) => { if (r.j) fireFums(r.j.fumsToken); });
          updateVerseJump(base);
          applyHighlights();
          if (keepN) requestAnimationFrame(() => scrollToVerseN(keepN));
        });
      }
    }

    /* ---------- verse jump ---------- */
    function updateVerseJump(vs) {
      if (vs && vs.length) {
        verseJump.style.visibility = 'visible';
        vjgrid.innerHTML = vs.map((v) => '<button class="vjtile" data-n="' + v.n + '">' + v.n + '</button>').join('');
      } else { verseJump.style.visibility = 'hidden'; }
    }
    verseJump.addEventListener('click', () => { if (verseJump.style.visibility !== 'hidden') vjump.classList.add('open'); });
    $('vjback').addEventListener('click', () => vjump.classList.remove('open'));
    vjgrid.addEventListener('click', (e) => {
      const t = e.target.closest('.vjtile'); if (!t) return;
      vjump.classList.remove('open');
      scrollToVerseN(t.dataset.n, { smooth: true, flash: true });
    });

    /* ---------- reader tools: toast · translation menu · display ---------- */
    const wtoast = $('wtoast'), wtoastMsg = $('wtoastMsg'); let _wtt;
    function toast(m) { wtoastMsg.textContent = m; wtoast.classList.add('show'); clearTimeout(_wtt); _wtt = setTimeout(() => wtoast.classList.remove('show'), 1800); }

    const dim = $('appDim') || $('dim'), tmenu = $('tmenu'), tmlist = $('tmlist');
    document.querySelectorAll('.rsheet .rsback').forEach((b) => b.addEventListener('click', () => b.closest('.rsheet').classList.remove('open')));

    function openTmenu() {
      tmlist.innerHTML = TRANSLATIONS.filter((t) => !esLock() || t.id === 'rvr1909').map((t) => (
        '<div class="tmrow' + (t.id === readT ? ' on' : '') + '" data-t="' + t.id + '"><div><div class="tmn">' + t.label + '</div><div class="tmd">' + t.name + '</div></div><span class="tmck"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg></span></div>'
      )).join('');
      tmenu.classList.add('open');
    }
    tmlist.addEventListener('click', (e) => {
      const r = e.target.closest('.tmrow'); if (!r) return;
      const keep = topVerseN();
      setReadT(r.dataset.t);
      tmenu.classList.remove('open');
