---
// /crisis — Find help now. SURFACE verbatim from design-source-v3.2/declare/Crisis.html.
// Safety-critical page: real tel:/sms:/web links only. The design's "Talk to a pastor"
// row targets Find-a-Church-Flow.html (unbuilt) — omitted until the church chapter ships;
// a dead link on a crisis page is worse than a missing row (flagged at review).
import DeclareLayout from '../layouts/DeclareLayout.astro';
---
<DeclareLayout
  title="Declare — Find Help Now"
  description="You are not alone. Reach trained, caring people right now — any time, day or night."
  activeTab=""
>
  <main class="crisisp">
    <div class="topglow" aria-hidden="true"></div>
    <div class="in">
      <div class="sub-top">
        <a class="iconbtn" href="/today" aria-label="Back" data-i18n-aria="crisis.back"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 5l-7 7 7 7"></path></svg></a>
        <span class="ttl" data-i18n="crisis.ttl">Find help now</span>
        <span class="iconbtn" style="visibility:hidden"></span>
      </div>
      <div class="cscroll">
        <div class="chero rise d1">
          <div class="ci"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7Z"></path></svg></div>
          <h1 data-i18n="crisis.h1">You are not alone</h1>
          <div class="csub" data-i18n="crisis.csub">If you&rsquo;re thinking about harming yourself, please reach out right now. Trained, caring people are ready to talk &mdash; any time, day or night.</div>
        </div>

        <div class="verse rise d2" data-i18n="crisis.verse">&ldquo;The Lord is near to the brokenhearted and saves the crushed in spirit.&rdquo;</div>
        <div class="vref rise d2" data-i18n="crisis.vref">Psalm 34:18</div>

        <div class="lbl rise d3" data-i18n="crisis.reachNow">Reach someone now</div>
        <div class="urgent rise d3">
          <a class="ubtn call" href="tel:988">
            <span class="ui"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2z"></path></svg></span>
            <span class="um"><span class="ut" data-i18n="crisis.call988">Call 988</span><span class="ud" data-i18n="crisis.call988D">Suicide &amp; Crisis Lifeline &middot; 24/7, free</span></span>
            <span class="uarr"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg></span>
          </a>
          <a class="ubtn text" href="sms:988&body=HOME">
            <span class="ui"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.4 8.4 0 0 1-8.5 8.5 8.5 8.5 0 0 1-3.8-.9L3 21l1.9-5.7a8.5 8.5 0 0 1-.9-3.8A8.4 8.4 0 0 1 12.5 3 8.4 8.4 0 0 1 21 11.5z"></path></svg></span>
            <span class="um"><span class="ut" data-i18n="crisis.text988">Text 988</span><span class="ud" data-i18n="crisis.text988D">Prefer to text? Connect by message</span></span>
            <span class="uarr"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg></span>
          </a>
          <a class="ubtn emerg" href="tel:911">
            <span class="ui"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 9v4M12 17v.01M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z"></path></svg></span>
            <span class="um"><span class="ut" data-i18n="crisis.call911">Call 911</span><span class="ud" data-i18n="crisis.call911D">For an immediate, life-threatening emergency</span></span>
            <span class="uarr"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg></span>
          </a>
        </div>

        <div class="lbl m-rise" data-i18n="crisis.moreWays">More ways to talk</div>
        <div class="res" data-m-stagger>
          <a class="rrow m-rise" href="https://www.crisistextline.org" target="_blank" rel="noopener">
            <span class="ri"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.4 8.4 0 0 1-8.5 8.5 8.5 8.5 0 0 1-3.8-.9L3 21l1.9-5.7a8.5 8.5 0 0 1-.9-3.8A8.4 8.4 0 0 1 12.5 3 8.4 8.4 0 0 1 21 11.5z"></path></svg></span>
            <span class="rm"><span class="rt">Crisis Text Line</span><span class="rd" data-i18n="crisis.ctlD">Text HOME to 741741 &middot; 24/7</span></span>
            <span class="rarr"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg></span>
          </a>
          <a class="rrow m-rise" href="https://988lifeline.org" target="_blank" rel="noopener">
            <span class="ri"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M3 12h18M12 3a14 14 0 0 1 0 18 14 14 0 0 1 0-18z"></path></svg></span>
            <span class="rm"><span class="rt">988lifeline.org</span><span class="rd" data-i18n="crisis.lifelineD">Chat online &middot; resources &amp; support</span></span>
            <span class="rarr"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg></span>
          </a>
          <a class="rrow m-rise" href="mailto:care@declareandbelieve.com">
            <span class="ri"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="M3 7l9 6 9-6"></path></svg></span>
            <span class="rm"><span class="rt" data-i18n="crisis.emailTeam">Email our care team</span><span class="rd">care@declareandbelieve.com</span></span>
            <span class="rarr"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"></path></svg></span>
          </a>
        </div>

        <div class="reassure m-rise"><span class="rline"><span data-i18n="crisis.rline1">Your life matters.</span><br /><span data-i18n="crisis.rline2">This moment is not the end of your story.</span></span><span class="rsmall" data-i18n="crisis.rsmall">He is near. Hold on.</span></div>
        <div class="note m-fade"><span data-i18n="crisis.note1">If you are outside the U.S., call your local emergency number or visit </span><b>findahelpline.com</b><span data-i18n="crisis.note2"> for help in your country.</span></div>
      </div>
    </div>
  </main>

  <style is:global>
    /* /crisis page styles — verbatim from Crisis.html's page-local <style>,
       namespaced under .crisisp (base components + tokens from declare.css) */
    .crisisp { position: relative; min-height: 100dvh; }
    .crisisp .in { position: relative; z-index: 1; display: flex; flex-direction: column; padding-bottom: 120px; }
    .crisisp .sub-top { position: relative; z-index: 2; display: flex; align-items: center; justify-content: space-between; padding: 12px 16px 0; }
    .crisisp .sub-top .ttl { font-size: 11px; letter-spacing: .22em; text-transform: uppercase; color: var(--muted); white-space: nowrap; }
    .crisisp .iconbtn { width: 38px; height: 38px; border-radius: 50%; border: 0; background: transparent; color: var(--text); cursor: pointer; display: flex; align-items: center; justify-content: center; }
    .crisisp .iconbtn svg { width: 20px; height: 20px; }
    .crisisp .cscroll { flex: 1; padding: 8px 24px 40px; }

    .crisisp .chero { text-align: center; padding: 14px 4px 4px; }
    .crisisp .chero .ci { width: 58px; height: 58px; margin: 0 auto 18px; border-radius: 50%; background: rgba(208, 138, 91, .16); border: 1px solid rgba(208, 138, 91, .4); display: flex; align-items: center; justify-content: center; color: var(--clay); }
    .crisisp .chero .ci svg { width: 26px; height: 26px; }
    .crisisp .chero h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(34px, 9.4vw, 40px); font-weight: 600; color: var(--text); line-height: 1.05; letter-spacing: .005em; text-shadow: 0 0 50px rgba(222, 190, 100, .26); }
    .crisisp .chero .csub { font-size: 14.5px; line-height: 1.6; color: var(--text2); margin-top: 15px; max-width: 30ch; margin-left: auto; margin-right: auto; }
    .crisisp .verse { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 18px; line-height: 1.5; color: var(--soft); text-align: center; margin: 22px 4px 0; }
    .crisisp .vref { text-align: center; font-size: 10.5px; letter-spacing: .18em; text-transform: uppercase; color: var(--goldd); font-weight: 500; margin-top: 9px; }

    .crisisp .lbl { font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--goldd); font-weight: 500; margin: 30px 0 12px; }

    .crisisp .urgent { display: flex; flex-direction: column; gap: 11px; }
    .crisisp .ubtn { display: flex; align-items: center; gap: 15px; padding: 17px 18px; border-radius: 17px; text-decoration: none; box-shadow: var(--card-shadow); transition: transform .16s ease, box-shadow .22s ease; }
    .crisisp .ubtn:active { transform: translateY(1px) scale(.992); }
    @media (hover: hover) {
      .crisisp .ubtn:hover { transform: translateY(-2px); box-shadow: 0 22px 50px -18px rgba(0, 0, 0, .6); }
      .crisisp .ubtn.emerg:hover { box-shadow: 0 16px 38px -16px rgba(181, 112, 63, .45); }
    }
    .crisisp .ubtn .ui { flex: 0 0 auto; width: 46px; height: 46px; border-radius: 13px; display: flex; align-items: center; justify-content: center; }
    .crisisp .ubtn .ui svg { width: 22px; height: 22px; }
    .crisisp .ubtn .um { flex: 1; min-width: 0; }
    .crisisp .ubtn .ut { display: block; font-size: 17px; font-weight: 600; line-height: 1.15; }
    .crisisp .ubtn .ud { display: block; font-size: 12.5px; margin-top: 3px; }
    .crisisp .ubtn .uarr { flex: 0 0 auto; display: flex; }
    .crisisp .ubtn .uarr svg { width: 17px; height: 17px; }
    .crisisp .ubtn.call { background: linear-gradient(180deg, #356552, #234438); }
    .crisisp .ubtn.call .ui { background: rgba(255, 255, 255, .16); color: #FBF7EF; }
    .crisisp .ubtn.call .ut { color: #FBF7EF; }
    .crisisp .ubtn.call .ud { color: rgba(251, 247, 239, .75); }
    .crisisp .ubtn.call .uarr { color: rgba(251, 247, 239, .8); }
    .crisisp .ubtn.text { background: var(--surface); }
    .crisisp .ubtn.text .ui { background: var(--field); color: var(--goldd); }
    .crisisp .ubtn.text .ut { color: var(--text); }
    .crisisp .ubtn.text .ud { color: var(--muted); }
    .crisisp .ubtn.text .uarr { color: var(--muted); }
    .crisisp .ubtn.emerg { background: rgba(181, 112, 63, .12); border: 1px solid rgba(181, 112, 63, .34); box-shadow: none; }
    .crisisp .ubtn.emerg .ui { background: rgba(181, 112, 63, .18); color: var(--clay); }
    .crisisp .ubtn.emerg .ut { color: var(--text); }
    .crisisp .ubtn.emerg .ud { color: var(--muted); }
    .crisisp .ubtn.emerg .uarr { color: var(--clay); }

    .crisisp .res { display: flex; flex-direction: column; gap: 10px; }
    .crisisp .rrow { display: flex; align-items: center; gap: 14px; padding: 15px 16px; background: var(--surface); border-radius: 15px; box-shadow: var(--card-shadow); text-decoration: none; transition: transform .26s cubic-bezier(.2, .7, .2, 1); }
    @media (hover: hover) { .crisisp .rrow:hover { transform: translateY(-3px); } }
    .crisisp .rrow .ri { flex: 0 0 auto; width: 36px; height: 36px; border-radius: 11px; background: var(--field); display: flex; align-items: center; justify-content: center; color: var(--goldd); }
    .crisisp .rrow .ri svg { width: 17px; height: 17px; }
    .crisisp .rrow .rm { flex: 1; min-width: 0; }
    .crisisp .rrow .rt { display: block; font-size: 15px; font-weight: 500; color: var(--text); }
    .crisisp .rrow .rd { display: block; font-size: 12px; color: var(--muted); margin-top: 2px; }
    .crisisp .rrow .rarr { flex: 0 0 auto; color: var(--muted); display: flex; }
    .crisisp .rrow .rarr svg { width: 16px; height: 16px; }

    .crisisp .reassure { position: relative; text-align: center; margin: 38px 6px 0; padding-top: 26px; }
    .crisisp .reassure::before { content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 30px; height: 1px; background: var(--gold); opacity: .7; box-shadow: 0 0 10px rgba(216, 184, 95, .6); }
    .crisisp .reassure .rline { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 22px; line-height: 1.45; color: var(--text); text-shadow: 0 0 40px rgba(222, 190, 100, .3); }
    .crisisp .reassure .rsmall { display: block; font-family: 'DM Sans', sans-serif; font-style: normal; font-size: 13px; color: var(--muted); margin-top: 12px; letter-spacing: .01em; }
    .crisisp .note { text-align: center; font-size: 12px; color: var(--muted); margin-top: 20px; line-height: 1.6; }
    .crisisp .note b { color: var(--text2); font-weight: 600; }

    @media (min-width: 481px) {
      .crisisp .in { max-width: 720px; margin: 0 auto; width: 100%; padding-top: 78px; }
    }
    @media (min-width: 1100px) { .crisisp .in { max-width: 760px; } }
  </style>
</DeclareLayout>
