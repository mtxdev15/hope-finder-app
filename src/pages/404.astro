---
// /404 — not-found page. Astro emits this as dist/404.html, which Cloudflare
// Pages serves (with a real 404 status) for any unmatched path — so dead/typo'd
// URLs no longer soft-404 to the homepage. Calm and on-brand, in the v3.2 shell.
import DeclareLayout from '../layouts/DeclareLayout.astro';
---
<DeclareLayout
  title="Declare — Page not found"
  description="This page wandered off — but you are not lost to Him. Return home or receive a word for this moment."
  activeTab=""
>
  <main class="nf">
    <div class="topglow" aria-hidden="true"></div>
    <div class="nf-col">
      <div class="nf-mark serif" aria-hidden="true">✝</div>
      <div class="nf-code">404</div>
      <h1 class="serif">This page wandered off.</h1>
      <p class="nf-sub">The link may be old or mistyped — but you are not lost to Him.</p>

      <blockquote class="nf-verse serif">
        &ldquo;What man among you, having a hundred sheep, if he loses one of them,
        does not leave the ninety-nine&hellip; and go after the one which is lost
        until he finds it?&rdquo;
      </blockquote>
      <div class="nf-ref">Luke 15:4</div>

      <div class="nf-actions">
        <a class="nf-btn nf-primary" href="/today">Receive a word</a>
        <a class="nf-btn nf-ghost" href="/">Return home</a>
      </div>
    </div>
  </main>
</DeclareLayout>

<style>
  .nf {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 22px 120px;
    color: var(--text);
  }
  .topglow {
    position: absolute;
    top: 0; left: 50%;
    width: 120%; height: 320px;
    transform: translateX(-50%);
    background: radial-gradient(60% 100% at 50% 0%, rgba(216, 184, 95, .10), transparent 70%);
    pointer-events: none;
  }
  .nf-col {
    position: relative;
    max-width: 520px;
    text-align: center;
    animation: nf-rise .7s cubic-bezier(.22, .61, .36, 1) both;
  }
  .nf-mark {
    font-size: 30px;
    color: var(--gold);
    opacity: .9;
    margin-bottom: 6px;
  }
  .nf-code {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    letter-spacing: .32em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 14px;
  }
  h1 {
    font-size: clamp(30px, 8vw, 44px);
    line-height: 1.12;
    font-weight: 600;
    margin: 0 0 12px;
  }
  .nf-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    line-height: 1.65;
    color: var(--muted);
    margin: 0 auto 30px;
    max-width: 40ch;
  }
  .nf-verse {
    font-size: clamp(19px, 5vw, 23px);
    line-height: 1.55;
    color: var(--text);
    margin: 0 auto 8px;
    max-width: 34ch;
    border: 0;
  }
  .nf-ref {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 36px;
  }
  .nf-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: stretch;
    max-width: 320px;
    margin: 0 auto;
  }
  .nf-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 26px;
    border-radius: 14px;
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    transition: transform .18s ease, opacity .18s ease;
  }
  .nf-btn:active { transform: scale(.98); }
  .nf-primary {
    background: var(--gold);
    color: var(--ctatext);
  }
  .nf-ghost {
    border: 1px solid var(--line);
    color: var(--text);
  }
  @keyframes nf-rise {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .nf-col { animation: none; }
  }
  @media (min-width: 600px) {
    .nf-actions { flex-direction: row; justify-content: center; }
    .nf-btn { min-width: 160px; }
  }
</style>
