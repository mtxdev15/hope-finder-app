# Cloudflare Pages headers.
# The vendored design-system assets (/declare/*.css, /declare/*.js) have fixed
# filenames, so the default 4h browser cache made style/JS changes look stale
# until a hard refresh. Revalidate them on every load instead (304 when
# unchanged, so it's cheap). Images and fonts under /declare/brand stay cached.

/declare/*.css
  Cache-Control: public, max-age=0, must-revalidate

/declare/*.js
  Cache-Control: public, max-age=0, must-revalidate
